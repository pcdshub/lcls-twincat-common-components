<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_IPM" Id="{5686e09b-32c7-4e77-9d6e-c0baf6046a0f}" SpecialFunc="None">
    <Declaration><![CDATA[(*
    Function block for Intensity Profile Monitor (IPM) controls under
    the LCLS_Tc_Motion (ND) framework:
    - Y target-state mover via FB_PositionStatePMPSND with five states
      (OUT, TARGET1, TARGET2, TARGET3, TARGET4)

    FB_IPM is a thin wrapper for the state-mover plumbing. Motors,
    motion-stage interface array, position-state slot array, fast-fault
    output and arbiter are caller-owned; FB_IPM receives them by
    FB_Init REFERENCE TO and forwards them to fbStates via inline-init.
    The state enum bridge (eEnumSet / eEnumGet, UINT) and the four
    run-time toggles (bEnableMotion / bEnableBeamParams /
    bEnablePositionLimits / bReadDBNow, plain BOOL) are device-specific
    and live as classic VAR_INPUT; the caller writes them each cycle
    (or pins them at startup) and the body re-forwards them into
    fbStates.

    The legacy 1D FB also owned an X (align-to-beam) motor and declared
    two RTD thermocouples (fbRTD1 / fbRTD2) whose bodies were never
    invoked, so they had no runtime effect. Under the ND framework the
    X motor is the integrator's concern. The dead RTD slots are kept
    here as a commented stub in the VAR section so the historical PV
    layout (RTD:01 / RTD:02) is discoverable and re-enabling them only
    requires uncommenting plus a cyclic tick.

    Per-state configuration is split across two configurators that
    co-operate on each ST_PositionState slot:
      - integrator's FB_CC_StatePMPSConfig array (per-install, declared
        in the caller PRG) wraps motion-lib's FB_StateSetup and writes
        fPosition + sPmpsState plus a caller-owned stDefault baseline
        (bMoveOk / bValid / bUseRawCounts / template fDelta).
      - FB_IPM.afbStateDefaults (device-side, hardcoded here) writes
        per-state sName and fDelta last, overriding the template
        baseline that FB_StateSetup just laid down. Ordering matters:
        the integrator must tick its PMPS array BEFORE calling fbIPM.
    Both configurators are idempotent once the parent state FB sets
    stPositionState.bUpdated := TRUE.
*)
{attribute 'call_after_init'}
FUNCTION_BLOCK FB_IPM
VAR_INPUT
    (* Device-specific state-enum bridges. Typed as E_IPM_States (UINT
       base) so the caller surface is enum-checked; the inline-init
       below binds them to FB_PositionStatePMPSND's REFERENCE TO UINT
       params via the shared UINT base. Callers drive moves with
       `fbIPM.eEnumSet := E_IPM_States.TARGET1;` and read
       `fbIPM.eEnumGet`. *)
    eEnumSet : E_IPM_States;
    eEnumGet : E_IPM_States;
END_VAR
VAR
    fbStates : FB_PositionStatePMPSND(
        aiMotionStage         := aiMotionStage,
        astPositionState      := astPositionState,
        nActiveMotorCount     := 1,
        eEnumSet              := eEnumSet,
        eEnumGet              := eEnumGet,
        bEnableMotion         := bEnableMotion,
        eMotionRequestPolicy  := E_MotionRequestPolicy.INTERRUPT,
        bEnableBeamParams     := bEnableBeamParams,
        bEnablePositionLimits := bEnablePositionLimits,
        bReadDBNow            := bReadDBNow,
        bFileReaderBusy       := MOTION_GVL.fbPmpsFileReader.bBusy,
        bFileReaderError      := MOTION_GVL.fbPmpsFileReader.bError,
        fbFFHWO               := fbFFHWO,
        fbArbiter             := fbArbiter,
        sDeviceName           := sDeviceName,
        sTransitionKey        := sTransitionKey
    );

    (* REFERENCE TO backing fields populated by FB_Init. Same names as
       FB_Init params; THIS^. disambiguates inside FB_Init.
       Live-bound to caller storage for the lifetime of the FB. *)
    {attribute 'no_copy'}
    aiMotionStage         : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage;
    {attribute 'no_copy'}
    astPositionState      : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                                            OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;
    {attribute 'no_copy'}
    fbFFHWO               : REFERENCE TO FB_HardwareFFOutput;
    {attribute 'no_copy'}
    fbArbiter             : REFERENCE TO FB_Arbiter;
    sDeviceName           : STRING;
    sTransitionKey        : STRING;
    bEnableMotion         : BOOL := TRUE;
    bEnableBeamParams     : BOOL;
    bEnablePositionLimits : BOOL;
    bReadDBNow            : BOOL;

    (* One configurator per IPM state (OUT + 4 targets). Writes the
       per-state sName and fDelta. Ticked cyclically in the body AFTER
       fbStates so its writes win over the template baseline
       FB_StateSetup applied via FB_CC_StatePMPSConfig. Idempotent once
       stPositionState.bUpdated trips. *)
    afbStateDefaults : ARRAY[1..5] OF FB_CC_DeviceStateDefaults[
        (stPositionState := astPositionState[1][E_IPM_States.OUT],
         sName           := 'OUT',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_IPM_States.TARGET1],
         sName           := 'TARGET1',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_IPM_States.TARGET2],
         sName           := 'TARGET2',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_IPM_States.TARGET3],
         sName           := 'TARGET3',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_IPM_States.TARGET4],
         sName           := 'TARGET4',
         fDelta          := FDELTA_DEFAULT)
    ];

    i : UINT;

    (* Legacy FB_IPM declared two RTD thermocouples with pytmc PVs
       (RTD:01 / RTD:02) but never called their bodies, so they had
       no runtime effect and exposed no live values to EPICS. Kept
       commented for traceability and to make re-enabling trivial:
       drop the comment, add a cyclic
           fbRTD1();
           fbRTD2();
       below the state-defaults loop, and decide whether to gate them
       with bVeto (e.g. on eEnumGet = E_IPM_States.OUT) per the GBS
       in-beam RTD pattern.

    {attribute 'pytmc' := 'pv: RTD:01'}
    fbRTD1 : FB_CC_TempSensor;

    {attribute 'pytmc' := 'pv: RTD:02'}
    fbRTD2 : FB_CC_TempSensor;
    *)
END_VAR
VAR CONSTANT
    (* IPM-wide default tolerance for state in-position detection,
       applied per-state by afbStateDefaults. *)
    FDELTA_DEFAULT : LREAL := 2;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* Nil-ref guards: every REFERENCE TO backing field must be bound. *)
IF NOT __ISVALIDREF(aiMotionStage)
   OR NOT __ISVALIDREF(astPositionState)
   OR NOT __ISVALIDREF(fbFFHWO)
   OR NOT __ISVALIDREF(fbArbiter) THEN
    RETURN;
END_IF

(* Device-side per-state defaults (afbStateDefaults) are written
   once in FB_CC_DeviceStateDefaults.CallAfterInit; no cyclic tick. *)
fbStates();]]></ST>
    </Implementation>
    <Method Name="CallAfterInit" Id="{5686e09c-32c7-4e77-9d6e-c0baf6046a10}">
      <Declaration><![CDATA[(*
    {attribute 'call_after_init'} on FB_IPM causes TwinCAT to auto-fire
    THIS^.CallAfterInit() after FB_IPM.FB_Init completes.

    fbStates was constructed via inline-init in FB_IPM's VAR section,
    which ran BEFORE FB_IPM.FB_Init bound the REF fields on THIS^.
    Consequently fbStates' inline-init forwarded nil REFs into
    fbStates.FB_Init, and the auto-fired fbStates.CallAfterInit guards
    on those nil REFs and bails. This method re-supplies the now-valid
    refs through fbStates.CallAfterInitStateMover, which re-binds them and runs
    the full child-FB wiring chain (Core / ND / PMPSND).
*)
{attribute 'call_after_init'}
METHOD CallAfterInit
]]></Declaration>
      <Implementation>
        <ST><![CDATA[afbStateDefaults[1].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_IPM_States.OUT]);
afbStateDefaults[2].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_IPM_States.TARGET1]);
afbStateDefaults[3].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_IPM_States.TARGET2]);
afbStateDefaults[4].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_IPM_States.TARGET3]);
afbStateDefaults[5].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_IPM_States.TARGET4]);

THIS^.fbStates.CallAfterInitStateMover(
    aiMotionStage         := aiMotionStage,
    astPositionState      := astPositionState,
    nActiveMotorCount     := 1,
    eEnumSet              := eEnumSet,
    eEnumGet              := eEnumGet,
    bEnableMotion         := bEnableMotion,
    eMotionRequestPolicy  := E_MotionRequestPolicy.INTERRUPT,
);

THIS^.fbStates.CallAfterInitPMPS(
    aiMotionStage         := aiMotionStage,
    astPositionState      := astPositionState,
    bEnableBeamParams     := bEnableBeamParams,
    bEnablePositionLimits := bEnablePositionLimits,
    bReadDBNow            := bReadDBNow,
    bFileReaderBusy       := MOTION_GVL.fbPmpsFileReader.bBusy,
    bFileReaderError      := MOTION_GVL.fbPmpsFileReader.bError,
    fbFFHWO               := fbFFHWO,
    fbArbiter             := fbArbiter,
    sDeviceName           := sDeviceName,
    sTransitionKey        := sTransitionKey
);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_init" Id="{5686e09d-32c7-4e77-9d6e-c0baf6046a11}">
      <Declaration><![CDATA[(* Stores all FB_Init inputs into instance fields. Every non-value
   input is REFERENCE TO and is REF= bound for the lifetime of the FB
   (matches the rule: non-interface FB_Init inputs are taken by ref).
   Inline-init of fbStates above runs first, capturing the FB_Init
   params at construction time; this method then records the same
   references on THIS^ for body-side use and live caller writes.
   The file-reader busy/error inputs are bound straight to
   MOTION_GVL.fbPmpsFileReader inside fbStates' inline-init. *)
{attribute 'analysis' := '-33'}
METHOD FB_Init : BOOL
VAR_INPUT
    bInitRetains           : BOOL;
    bInCopyCode            : BOOL;
    aiMotionStage          : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage;
    astPositionState       : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                                            OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;
    fbFFHWO                : REFERENCE TO FB_HardwareFFOutput;
    fbArbiter              : REFERENCE TO FB_Arbiter;
    sDeviceName            : STRING;
    sTransitionKey         : STRING;
    bEnableBeamParams      : BOOL;
    bEnablePositionLimits  : BOOL;
    bReadDBNow             : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.aiMotionStage    REF= aiMotionStage;
THIS^.astPositionState REF= astPositionState;
THIS^.fbFFHWO          REF= fbFFHWO;
THIS^.fbArbiter        REF= fbArbiter;
THIS^.sDeviceName      := sDeviceName;
THIS^.sTransitionKey   := sTransitionKey;
THIS^.bEnableBeamParams     := bEnableBeamParams;
THIS^.bEnablePositionLimits := bEnablePositionLimits;
THIS^.bReadDBNow            := bReadDBNow;]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>