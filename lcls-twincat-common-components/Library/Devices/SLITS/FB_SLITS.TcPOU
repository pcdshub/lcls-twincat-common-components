<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_SLITS" Id="{e16e0f37-b04b-4e2b-a3f3-e910fdc91095}" SpecialFunc="None">
    <Declaration><![CDATA[(*
    Four-blade slit aperture controller (Top / Bottom / North / South)
    under the LCLS_Tc_Motion (ND) framework. Each blade is driven by
    one FB_StatePTPMove single-shot mover, NOT by the multi-state
    FB_PositionStateND mover: slit targets are recomputed every cycle
    from EPICS-requested aperture width + center (and per-blade encoder
    zero-offsets), so there is no fixed enum of named positions.

    Motion stages, PMPS hardware fault output and device name are
    caller-owned and injected through FB_Init as REFERENCE TO. The
    auto-fired CallAfterInit wires the four blade interfaces from
    aiMotionStage[1..4] into each FB_StatePTPMove's iMotionStage field
    (FB_StatePTPMove has no setter post-init, so the wiring must
    happen there once REFs are bound).

    The integrator PRG instantiates the four FB_MotionStageNC blade
    motors (passing AxisRef + iPersistentDataStorage + sName) and
    hands them to FB_SLITS through FB_Init; the device then owns its
    own canonical velocity / accel / decel + mode + enable / limit
    configuration, applied per-blade on the first scan via
    SetMotionParam + SetModeEnableLimits. The integrator only needs
    to take care of concrete-FB-only fields (RestoreMotionParams,
    DoNotRestoreNcParameters) on each motor before the first scan.

    PMPS aperture-safety FFO and request-vs-actual reconciliation live
    on the FB_SLITS_POWER subclass via M_UpdatePMPS, which the
    integrator calls each cycle with the device's aperture index into
    PMPS_GVL.stCurrentBeamParameters.astApertures.

    bOpen / bClose / bBlock are kept as EPICS PV stubs for downstream
    integrator compatibility: the rising edge is consumed and the
    flag cleared each cycle, but no preset move is dispatched (the
    legacy preset-position branch was never implemented).
*)
{attribute 'analysis' := '-33'}
FUNCTION_BLOCK FB_SLITS
VAR_INPUT
    {attribute 'pytmc' := '
    pv: PMPS_OK
    io: i
    field: ZNAM False
    field: ONAM True
    '}
    bMoveOk : BOOL;

    (* Per-blade encoder zero-offsets (EPICS-settable). *)
    {attribute 'pytmc' := '
    pv: Offset_Top
    io: io
    '}
    rEncoderOffsetTop : REAL;

    {attribute 'pytmc' := '
    pv: ZeroOffset_Bottom
    io: io
    '}
    rEncoderOffsetBottom : REAL;

    {attribute 'pytmc' := '
    pv: ZeroOffset_North
    io: io
    '}
    rEncoderOffsetNorth : REAL;

    {attribute 'pytmc' := '
    pv: ZeroOffset_South
    io: io
    '}
    rEncoderOffsetSouth : REAL;
END_VAR
VAR
    (* Per-blade scratch ST_PositionState. Static fields seeded here;
       fPosition and bMoveOk are refreshed each cycle in the body. *)
        (*Motion Parameters*)
    fSmallDelta: LREAL := 0.01;
    fBigDelta: LREAL := 10;

    stTop    : ST_PositionState := (sName := 'Top',    bValid := TRUE, bUseRawCounts := FALSE);
    stBottom : ST_PositionState := (sName := 'Bottom', bValid := TRUE, bUseRawCounts := FALSE);
    stNorth  : ST_PositionState := (sName := 'North',  bValid := TRUE, bUseRawCounts := FALSE);
    stSouth  : ST_PositionState := (sName := 'South',  bValid := TRUE, bUseRawCounts := FALSE);

    (* Per-blade PTP movers. iMotionStage is wired in CallAfterInit;
       FB_StatePTPMove tolerates a nil interface until then. *)
    {attribute 'pytmc' := 'pv: TOP'}
    fbTop    : FB_StatePTPMove(
        stPositionState := stTop,
        iMotionStage:=aiMotionStage[IDX_TOP]
    );
    {attribute 'pytmc' := 'pv: BOTTOM'}
    fbBottom : FB_StatePTPMove(
        stPositionState := stBottom,
        iMotionStage:=aiMotionStage[IDX_BOTTOM]
    );
    {attribute 'pytmc' := 'pv: NORTH'}
    fbNorth  : FB_StatePTPMove(
        stPositionState := stNorth,
        iMotionStage:=aiMotionStage[IDX_NORTH]
    );
    {attribute 'pytmc' := 'pv: SOUTH'}
    fbSouth  : FB_StatePTPMove(
        stPositionState := stSouth,
        iMotionStage:=aiMotionStage[IDX_SOUTH]
    );

    (* Aperture-math intermediate targets. *)
    fPosTopBlade    : LREAL;
    fPosBottomBlade : LREAL;
    fPosNorthBlade  : LREAL;
    fPosSouthBlade  : LREAL;

    (* EPICS request / actual aperture geometry. *)
    {attribute 'pytmc' := '
    pv: XWID_REQ
    io: io
    '}
    rReqApertureSizeX : REAL;
    {attribute 'pytmc' := '
    pv: YWID_REQ
    io: io
    '}
    rReqApertureSizeY : REAL;
    {attribute 'pytmc' := '
    pv: XCEN_REQ
    io: io
    '}
    rReqCenterX : REAL;
    {attribute 'pytmc' := '
    pv: YCEN_REQ
    io: io
    '}
    rReqCenterY : REAL;

    {attribute 'pytmc' := '
    pv: ACTUAL_XWIDTH
    io: io
    '}
    rActApertureSizeX : REAL;
    {attribute 'pytmc' := '
    pv: ACTUAL_YWIDTH
    io: io
    '}
    rActApertureSizeY : REAL;
    {attribute 'pytmc' := '
    pv: ACTUAL_XCENTER
    io: io
    '}
    rActCenterX : REAL;
    {attribute 'pytmc' := '
    pv: ACTUAL_YCENTER
    io: io
    '}
    rActCenterY : REAL;

    (* Edge-trigger request flags. Cleared on the rising edge each
       cycle but no preset move is dispatched (stub: legacy parity). *)
    {attribute 'pytmc' := '
    pv: OPEN
    io: io
    field: ZNAM False
    field: ONAM True
    '}
    bOpen : BOOL;

    {attribute 'pytmc' := '
    pv: CLOSE
    io: io
    field: ZNAM False
    field: ONAM True
    '}
    bClose : BOOL;

    {attribute 'pytmc' := '
    pv: BLOCK
    io: io
    field: ZNAM False
    field: ONAM True
    '}
    bBlock : BOOL;

    rTrig_Block : R_TRIG;
    rTrig_Open  : R_TRIG;
    rTrig_Close : R_TRIG;

    (* Change-detection latches for EPICS request fields. *)
    rOldReqApertureSizeX : REAL;
    rOldReqApertureSizeY : REAL;
    rOldReqCenterX       : REAL;
    rOldReqCenterY       : REAL;

    bExecuteMotionX : BOOL;
    bExecuteMotionY : BOOL;

    (* First-scan guard for M_Init. *)
    bInit : BOOL := TRUE;

    fbLogger : FB_LogMessage := (eSubsystem := E_SubSystem.MOTION);

    (* PMPS aperture-safety fault (driven by FB_SLITS_POWER.M_UpdatePMPS). *)
    FFO : FB_FastFault := (
        i_DevName  := 'Slits',
        i_Desc     := 'Fault occurs when gaps and/or centers are not within safe margins, or PMPS mode is switched OFF',
        i_TypeCode := 16#FAA
    );

    (* PMPS aperture IO (caller-mapped to terminals). *)
    AptArrayStatus AT %Q* : ST_PMPS_Aperture_IO;
    AptArrayReq    AT %I* : ST_PMPS_Aperture_IO;

    (* REF backing fields, populated by FB_Init. *)
    {attribute 'no_copy'}
    aiMotionStage : REFERENCE TO ARRAY[1..4] OF I_MotionStage;
    {attribute 'no_copy'}
    fbFFHWO       : REFERENCE TO FB_HardwareFFOutput;
    {attribute 'no_copy'}
    sDeviceName   : REFERENCE TO STRING;
    nMotor : UINT;
END_VAR
VAR CONSTANT
    IDX_TOP    : UDINT := 1;
    IDX_BOTTOM : UDINT := 2;
    IDX_NORTH  : UDINT := 3;
    IDX_SOUTH  : UDINT := 4;

    (* Canonical blade motion parameters, applied to every injected
       motor on the first scan. Legacy: fMaxVelocity := 0.2,
       fHighAccel := 0.8 (used for both accel and decel). *)
    FVEL_BLADE   : LREAL := 0.2;
    FACCEL_BLADE : LREAL := 0.8;
    FDECEL_BLADE : LREAL := 0.8;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF NOT __ISVALIDREF(aiMotionStage)
   OR NOT __ISVALIDREF(fbFFHWO)
   OR NOT __ISVALIDREF(sDeviceName) THEN
    RETURN;
END_IF

IF bInit THEN

    FOR nMotor := 1 TO 4 DO
        aiMotionStage[nMotor].SetMotionParam(
            Velocity     := FVEL_BLADE,
            Acceleration := FACCEL_BLADE,
            Deceleration := FDECEL_BLADE,
            Jerk         := 0
        );
        aiMotionStage[nMotor].SetModeEnableLimits(
            LimBackward    := TRUE,
            LimForward     := TRUE,
            HomeEnable     := FALSE,
            BrakeMode      := E_StageBrakeMode.NO_BRAKE,
            EnableMode     := E_StageEnableMode.DURING_MOTION,
            HomeMode       := E_EpicsHomeCmd.NONE,
            UserEnable     := TRUE,
            HardwareEnable := TRUE
        );
    END_FOR

    FFO.i_DevName := sDeviceName;

    bInit := FALSE;
END_IF

HandleRequests();
M_CalculatePositions();
M_Motion();
]]></ST>
    </Implementation>
    <Method Name="CallAfterInit" Id="{2bf5a8b9-6045-4972-b69a-4ac8a54c0162}">
      <Declaration><![CDATA[(*
    {attribute 'call_after_init'} on FB_SXR_SATT_Stage causes TwinCAT
    to auto-fire THIS^.CallAfterInit() after FB_SXR_SATT_Stage.FB_Init
    completes.

    fbStates was constructed via inline-init in this FB's VAR section,
    which ran BEFORE FB_Init bound the REF fields on THIS^.
    Consequently fbStates' inline-init forwarded nil REFs into
    fbStates.FB_Init, and the auto-fired fbStates.CallAfterInit guards
    on those nil REFs and bails. This method re-supplies the now-valid
    refs through fbStates.CallAfterInitEx, which re-binds them and
    runs the Core / ND child-FB wiring chain.
*)
{attribute 'call_after_init'}
METHOD CallAfterInit
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
fbTop.CallAfterInit( stPositionState := stTop,iMotionStage:=aiMotionStage[IDX_TOP]);
fbBottom.CallAfterInit( stPositionState := stTop,iMotionStage:=aiMotionStage[IDX_BOTTOM]);
fbNorth.CallAfterInit( stPositionState := stTop,iMotionStage:=aiMotionStage[IDX_NORTH]);
fbSouth.CallAfterInit( stPositionState := stTop,iMotionStage:=aiMotionStage[IDX_SOUTH]);

]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_Init" Id="{e16e0f37-b04b-4e2b-a3f3-e910fdc91097}">
      <Declaration><![CDATA[(*
    REF-binds caller-owned aiMotionStage (4 blades), fbFFHWO and
    sDeviceName at instantiation. Interface wiring into each blade
    mover happens in M_Init on the first scan (after the body's
    nil-guard validates the REFs).
*)
{attribute 'analysis' := '-33'}
METHOD FB_Init : BOOL
VAR_INPUT
    bInitRetains  : BOOL;
    bInCopyCode   : BOOL;
    aiMotionStage : REFERENCE TO ARRAY[1..4] OF I_MotionStage;
    fbFFHWO       : REFERENCE TO FB_HardwareFFOutput;
    sDeviceName   : REFERENCE TO STRING;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.aiMotionStage REF= aiMotionStage;
THIS^.fbFFHWO       REF= fbFFHWO;
THIS^.sDeviceName   REF= sDeviceName;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="HandleRequests" Id="{e16e0f37-b04b-4e2b-a3f3-e910fdc91099}">
      <Declaration><![CDATA[(*
    Consume the EPICS Open / Close / Block rising-edge requests and
    self-clear the flags. No preset move is dispatched (legacy stub).
*)
METHOD HandleRequests
]]></Declaration>
      <Implementation>
        <ST><![CDATA[rTrig_Block(CLK := bBlock);
rTrig_Open(CLK := bOpen);
rTrig_Close(CLK := bClose);

IF rTrig_Block.Q THEN
    bBlock := FALSE;
END_IF
IF rTrig_Open.Q THEN
    bOpen := FALSE;
END_IF
IF rTrig_Close.Q THEN
    bClose := FALSE;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_CalculatePositions" Id="{e16e0f37-b04b-4e2b-a3f3-e910fdc9109a}">
      <Declaration><![CDATA[(*
    Legacy ACT_CalculatePositions equivalent.

    Detects EPICS request changes (rejecting aperture-size requests
    that exceed the PMPS-authorized envelope), recomputes per-blade
    target positions from requested gap + center + per-blade encoder
    offset, and refreshes actual aperture geometry feedback (size +
    center on both axes) from the caller-owned motor positions.
*)
METHOD M_CalculatePositions
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// EPICS request change detection. Aperture-size branches reject (and
// log) requests exceeding the PMPS-authorized envelope; center
// branches accept unconditionally.
IF rOldReqApertureSizeX <> rReqApertureSizeX THEN
    IF rReqApertureSizeX <= AptArrayReq.Width THEN
        rOldReqApertureSizeX := rReqApertureSizeX;
        bExecuteMotionX      := TRUE;
        fbLogger(sMsg := 'Requested new X gap.', eSevr := TcEventSeverity.Verbose);
    ELSE
        fbLogger(
            sMsg := 'Requested new X gap is larger than PMPS request.',
            eSevr := TcEventSeverity.Verbose
        );
    END_IF
END_IF
IF rOldReqCenterX <> rReqCenterX THEN
    rOldReqCenterX  := rReqCenterX;
    bExecuteMotionX := TRUE;
    fbLogger(sMsg := 'Requested new X center', eSevr := TcEventSeverity.Verbose);
END_IF
IF rOldReqApertureSizeY <> rReqApertureSizeY THEN
    IF rReqApertureSizeY <= AptArrayReq.Height THEN
        rOldReqApertureSizeY := rReqApertureSizeY;
        bExecuteMotionY      := TRUE;
        fbLogger(sMsg := 'Requested new Y gap.', eSevr := TcEventSeverity.Verbose);
    ELSE
        fbLogger(
            sMsg := 'Requested new Y gap is larger than PMPS request.',
            eSevr := TcEventSeverity.Verbose
        );
    END_IF
END_IF
IF rOldReqCenterY <> rReqCenterY THEN
    rOldReqCenterY  := rReqCenterY;
    bExecuteMotionY := TRUE;
    fbLogger(sMsg := 'Requested new Y center.', eSevr := TcEventSeverity.Verbose);
END_IF

// Per-blade target positions from requested gap + center + per-blade
// encoder offset.
fPosTopBlade    :=  (rReqApertureSizeY / 2) + (rReqCenterY + rEncoderOffsetTop);
fPosBottomBlade := -(rReqApertureSizeY / 2) + (rReqCenterY + rEncoderOffsetBottom);
fPosNorthBlade  :=  (rReqApertureSizeX / 2) + (rReqCenterX + rEncoderOffsetNorth);
fPosSouthBlade  := -(rReqApertureSizeX / 2) + (rReqCenterX + rEncoderOffsetSouth);

// Actual aperture geometry feedback from caller-owned motors.
rActApertureSizeX := LREAL_TO_REAL(
    (aiMotionStage[IDX_NORTH].MotionStatus.fActPosition - rEncoderOffsetNorth)
  - (aiMotionStage[IDX_SOUTH].MotionStatus.fActPosition - rEncoderOffsetSouth)
);
rActApertureSizeY := LREAL_TO_REAL(
    (aiMotionStage[IDX_TOP].MotionStatus.fActPosition    - rEncoderOffsetTop)
  - (aiMotionStage[IDX_BOTTOM].MotionStatus.fActPosition - rEncoderOffsetBottom)
);
rActCenterX := LREAL_TO_REAL(
    ((aiMotionStage[IDX_NORTH].MotionStatus.fActPosition - rEncoderOffsetNorth)
   + (aiMotionStage[IDX_SOUTH].MotionStatus.fActPosition - rEncoderOffsetSouth)) / 2
);
rActCenterY := LREAL_TO_REAL(
    ((aiMotionStage[IDX_TOP].MotionStatus.fActPosition    - rEncoderOffsetTop)
   + (aiMotionStage[IDX_BOTTOM].MotionStatus.fActPosition - rEncoderOffsetBottom)) / 2
);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_Motion" Id="{e16e0f37-b04b-4e2b-a3f3-e910fdc9109b}">
      <Declaration><![CDATA[(*
    Legacy ACT_Motion equivalent.

    Refreshes per-blade ST_PositionState dynamic fields (fPosition +
    bMoveOk: static fields are seeded by the declaration inline-init),
    asserts bExecute on the bound FB_StatePTPMove on aperture change
    (FB_StatePTPMove self-clears bExecute on bDone / bError, so
    re-asserting TRUE only re-dispatches once the previous move
    completes, matching legacy behaviour), and ticks the four per-blade
    movers cyclically.
*)
METHOD M_Motion
]]></Declaration>
      <Implementation>
        <ST><![CDATA[stTop.fPosition    := fPosTopBlade;
stTop.fDelta := fSmallDelta;
stTop.bMoveOk      := bMoveOk;

stBottom.fPosition := fPosBottomBlade;
stBottom.fDelta    := fSmallDelta;
stBottom.bMoveOk   := bMoveOk;

stNorth.fPosition  := fPosNorthBlade;
stNorth.fDelta    := fSmallDelta;
stNorth.bMoveOk    := bMoveOk;

stSouth.fPosition  := fPosSouthBlade;
stSouth.fDelta    := fSmallDelta;
stSouth.bMoveOk    := bMoveOk;

IF bExecuteMotionY THEN
    fbTop.bExecute    := TRUE;
    fbBottom.bExecute := TRUE;
END_IF
IF bExecuteMotionX THEN
    fbNorth.bExecute := TRUE;
    fbSouth.bExecute := TRUE;
END_IF
bExecuteMotionX := FALSE;
bExecuteMotionY := FALSE;

fbTop(bMoveOk    := bMoveOk);
fbBottom(bMoveOk := bMoveOk);
fbNorth(bMoveOk  := bMoveOk);
fbSouth(bMoveOk  := bMoveOk);
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>