<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_SLITS_POWER" Id="{f2a7b61c-c24f-40b8-8c2e-4d94fdfd3c86}" SpecialFunc="None">
    <Declaration><![CDATA[(*
    PMPS-aware (power-class) variant of FB_SLITS. Adds:
    - 8 thermocouple RTDs (TOP / BOTTOM / NORTH / SOUTH x 2 channels each).
    - Flow switch (FB_XTES_Flowswitch).
    - Reactive temperature DB lookup via FB_JsonDocToSafeBP, keyed by
      sPmpsState; the resolved threshold drives every RTD's fault.
    - PMPS-mode toggle (xPMPSMode) defaulting to TRUE.
    - M_UpdatePMPS method (called by the integrator each cycle with
      the device's aperture index).

    EXTENDS FB_SLITS so the per-blade FB_StatePTPMove movers, aperture
    math, EPICS request / actual PVs and PMPS aperture-safety FFO live
    on the parent. Dispatch ownership mirrors the legacy ACT-based
    layout: the parent's body only consumes the EPICS edge-triggers
    (via HandleRequests); this subclass body invokes SUPER^() to run
    that trigger consumption, then drives the parent's
    M_CalculatePositions / M_Motion dispatch directly, after a REF
    nil-guard that gates every REF-touching call. Blade configuration
    runs once in the parent's CallAfterInit (M_Init).
*)
{attribute 'analysis' := '-33'}
{attribute 'call_after_init'}
FUNCTION_BLOCK FB_SLITS_POWER EXTENDS FB_SLITS

VAR
    {attribute 'pytmc' := '
    pv: MODE
    field: ZNAM Local
    field: ONAM PMPS
    io: io
    '}
    xPMPSMode : BOOL := TRUE;

    {attribute 'pytmc' := 'pv: FSW'}
    fbFlowSwitch : FB_XTES_Flowswitch;

    {attribute 'pytmc' := 'pv: TOP:RTD:01'}
    RTD_TOP_1 : FB_CC_TempSensor;
    {attribute 'pytmc' := 'pv: TOP:RTD:02'}
    RTD_TOP_2 : FB_CC_TempSensor;
    {attribute 'pytmc' := 'pv: BOTTOM:RTD:01'}
    RTD_Bottom_1 : FB_CC_TempSensor;
    {attribute 'pytmc' := 'pv: BOTTOM:RTD:02'}
    RTD_Bottom_2 : FB_CC_TempSensor;
    {attribute 'pytmc' := 'pv: NORTH:RTD:01'}
    RTD_North_1 : FB_CC_TempSensor;
    {attribute 'pytmc' := 'pv: NORTH:RTD:02'}
    RTD_North_2 : FB_CC_TempSensor;
    {attribute 'pytmc' := 'pv: SOUTH:RTD:01'}
    RTD_South_1 : FB_CC_TempSensor;
    {attribute 'pytmc' := 'pv: SOUTH:RTD:02'}
    RTD_South_2 : FB_CC_TempSensor;
    (* PMPS reactive-DB key for the device's allowed temperature. *)
    sPmpsState : STRING;
    fbReadPMPSDB : FB_JsonDocToSafeBP;
    astTempDB    : ARRAY[1..1] OF ST_DbStateParams;
    (* Caller-injected file-reader busy flag. fbReadPMPSDB.bExecute needs a
       rising edge; a real PMPS file read produces one as bBusy falls. Taken
       as REFERENCE TO so a test can drive its own BOOL and simulate the edge
       instead of reaching into MOTION_GVL.fbPmpsFileReader directly. *)
    bFileReaderBusy : REFERENCE TO BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[// REF nil-guard for every REF-touching call below (dispatch + PMPS DB
// + RTDs all consume sDeviceName / fbFFHWO; M_CalculatePositions also
// indexes aiMotionStage). The parent's body no longer holds this
// guard so we must.
IF NOT __ISVALIDREF(THIS^.aiMotionStage)
   OR NOT __ISVALIDREF(THIS^.fbFFHWO) THEN
    RETURN;
END_IF


// Parent body: EPICS edge-trigger consumption only (no REF touch).
SUPER^();


// Inherited dispatch (parity with legacy FB_SLITS_POWER body
// invoking ACT_CalculatePositions / ACT_Motion). Blade mode / enable
// / limits ran once in the parent's CallAfterInit via M_Init.
M_CalculatePositions();
M_Motion();

// PMPS reactive temperature DB lookup. bExecute needs a rising edge,
// produced as the caller-injected file-reader busy flag falls. Guard
// the REF (single condition, no short-circuit hazard) so an unbound
// instance stays inert rather than dereferencing a nil ref.
astTempDB[1].sPmpsState := sPmpsState;
IF __ISVALIDREF(bFileReaderBusy) THEN
    fbReadPMPSDB(
        bExecute    := NOT bFileReaderBusy,
        jsonDoc     := PMPS_GVL.BP_jsonDoc,
        sDeviceName := sDeviceName,
        arrStates   := astTempDB,
        io_fbFFHWO  := fbFFHWO
    );
END_IF

// All 8 RTDs share the same fault threshold (resolved from the DB).
RTD_TOP_1(
    fFaultThreshold := astTempDB[1].stReactiveParams.nTempSP,
    sDevName        := sDeviceName,
    io_fbFFHWO      := fbFFHWO
);
RTD_TOP_2(
    fFaultThreshold := astTempDB[1].stReactiveParams.nTempSP,
    sDevName        := sDeviceName,
    io_fbFFHWO      := fbFFHWO
);
RTD_Bottom_1(
    fFaultThreshold := astTempDB[1].stReactiveParams.nTempSP,
    sDevName        := sDeviceName,
    io_fbFFHWO      := fbFFHWO
);
RTD_Bottom_2(
    fFaultThreshold := astTempDB[1].stReactiveParams.nTempSP,
    sDevName        := sDeviceName,
    io_fbFFHWO      := fbFFHWO
);
RTD_North_1(
    fFaultThreshold := astTempDB[1].stReactiveParams.nTempSP,
    sDevName        := sDeviceName,
    io_fbFFHWO      := fbFFHWO
);
RTD_North_2(
    fFaultThreshold := astTempDB[1].stReactiveParams.nTempSP,
    sDevName        := sDeviceName,
    io_fbFFHWO      := fbFFHWO
);
RTD_South_1(
    fFaultThreshold := astTempDB[1].stReactiveParams.nTempSP,
    sDevName        := sDeviceName,
    io_fbFFHWO      := fbFFHWO
);
RTD_South_2(
    fFaultThreshold := astTempDB[1].stReactiveParams.nTempSP,
    sDevName        := sDeviceName,
    io_fbFFHWO      := fbFFHWO
);

fbFlowSwitch();
]]></ST>
    </Implementation>
    <Method Name="FB_Init" Id="{374dff7e-a7f7-48ec-a96e-6c5ba3e1db5a}">
      <Declaration><![CDATA[(*
    Records sPmpsState and REF-binds the caller-owned file-reader busy
    flag; aiMotionStage (4 blades), fbFFHWO and sDeviceName are bound by
    the base FB_SLITS.FB_Init. Interface wiring into each blade mover,
    and the one-shot M_Init blade configuration, run from CallAfterInit
    once these REFs are bound.
*)
{attribute 'analysis' := '-33'}
METHOD FB_Init : BOOL
VAR_INPUT
    bInitRetains  : BOOL;
    bInCopyCode   : BOOL;
    aiMotionStage : REFERENCE TO ARRAY[1..4] OF I_MotionStage;
    fbFFHWO       : REFERENCE TO FB_HardwareFFOutput;
    sDeviceName   : STRING;
    sPmpsState 	  : STRING;
    bFileReaderBusy : REFERENCE TO BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.sPmpsState := sPmpsState;
THIS^.bFileReaderBusy REF= bFileReaderBusy;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_UpdatePMPS" Id="{d82078ab-8935-40b4-85a2-97a1fdb15da8}">
      <Declaration><![CDATA[(*
    Integrator-driven PMPS aperture-safety reconciliation. Called each
    cycle with index = this device's slot in
    PMPS_GVL.stCurrentBeamParameters.astApertures.

    - Mirrors actual aperture geometry into AptArrayStatus.
    - Drives FFO false when actual gap exceeds (PMPS_authorized -
      2 * |center|) on either axis, gated by the authorized width /
      height being > 0 (skip evaluation if PMPS has not yet published
      an envelope).
    - In PMPS mode, snaps the requested gap to (PMPS_authorized -
      0.01) if the actual gap already exceeds the authorized envelope
      so the next dispatch closes the gap into compliance.
    - Out of PMPS mode, always faults.

    TwinCAT does not short-circuit, so the caller must ensure `index`
    is valid for PMPS_GVL.stCurrentBeamParameters.astApertures before
    invoking this method.
*)
METHOD M_UpdatePMPS : BOOL
VAR_INPUT
    index : INT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Mirror current actual aperture geometry and any-blade error state.
THIS^.AptArrayStatus.Height := THIS^.rActApertureSizeY;
THIS^.AptArrayStatus.Width  := THIS^.rActApertureSizeX;
THIS^.AptArrayStatus.xOK    :=
        NOT (THIS^.aiMotionStage[E_SlitsBlade.TOP   ].MotionStatus.bError)
    AND NOT (THIS^.aiMotionStage[E_SlitsBlade.BOTTOM].MotionStatus.bError)
    AND NOT (THIS^.aiMotionStage[E_SlitsBlade.NORTH ].MotionStatus.bError)
    AND NOT (THIS^.aiMotionStage[E_SlitsBlade.SOUTH ].MotionStatus.bError);

// Aperture-envelope evaluation.
IF ( THIS^.rActApertureSizeX > (AptArrayReq.Width  - (2 * ABS(THIS^.rActCenterX)))
     AND PMPS_GVL.stCurrentBeamParameters.astApertures[index].Width  > 0 )
OR ( THIS^.rActApertureSizeY > (AptArrayReq.Height - (2 * ABS(THIS^.rActCenterY)))
     AND PMPS_GVL.stCurrentBeamParameters.astApertures[index].Height > 0 ) THEN
    FFO.i_xOK := FALSE;
ELSE
    FFO.i_xOK := TRUE;
END_IF

IF xPMPSMode THEN
    IF THIS^.rActApertureSizeX > AptArrayReq.Width THEN
        rReqApertureSizeX := AptArrayReq.Width - 0.01;
    END_IF
    IF THIS^.rActApertureSizeY > AptArrayReq.Height THEN
        rReqApertureSizeY := AptArrayReq.Height - 0.01;
    END_IF
ELSE
    FFO.i_xOK := FALSE;
END_IF

FFO(
    i_xAutoReset := TRUE,
    io_fbFFHWO   := fbFFHWO
);
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>