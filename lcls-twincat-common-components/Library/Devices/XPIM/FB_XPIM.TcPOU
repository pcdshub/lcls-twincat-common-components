<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_XPIM" Id="{aa9f645d-c463-4c9e-8962-8aa3b3b2b9c3}" SpecialFunc="None">
    <Declaration><![CDATA[(* XTES Profile Imager (XPIM): thin ND-framework state-mover wrapper.
   Y mover via FB_PositionStatePMPSND (states OUT, YAG, DIAMOND, RETICLE),
   plus a tick site for the serial filter wheel, Opal camera power, LED
   (state-gated) and flow switch. Caller-owned deps, incl. EL6 serial buffers,
   injected via FB_Init REFERENCE TO and forwarded to fbStates each cycle. *)
{attribute 'call_after_init'}
FUNCTION_BLOCK FB_XPIM
VAR_INPUT
    // Set this to a non-unknown value to request a new move.
    {attribute 'pytmc' := '
        pv: MMS:STATE:SET
        io: io
    '}
    eEnumSet : E_XPIM_States;
END_VAR
VAR

    {attribute 'pytmc' := 'pv: MFW'}
    fbFilterWheel : FB_XPIM_FilterWheel;

    {attribute 'pytmc' := 'pv: CAM'}
    fbOpal : FB_XPIM_Opal;

    {attribute 'pytmc' := 'pv: CIL'}
    fbLED : FB_XPIM_LED;

    {attribute 'pytmc' := 'pv: FSW'}
    fbFlowSwitch : FB_XTES_Flowswitch;

    (* REFERENCE TO backing fields populated by FB_Init. Same names as
       FB_Init params; THIS^. disambiguates inside FB_Init.
       Live-bound to caller storage for the lifetime of the FB. *)
    {attribute 'no_copy'}
    aiMotionStage         : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage;
    {attribute 'no_copy'}
    astPositionState      : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                                            OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;
    {attribute 'no_copy'}
    fbFFHWO               : REFERENCE TO FB_HardwareFFOutput;
    {attribute 'no_copy'}
    fbArbiter             : REFERENCE TO FB_Arbiter;
    sDeviceName           : STRING;
    sTransitionKey        : STRING;
    bEnableMotion         : BOOL := TRUE;
    bEnableBeamParams     : BOOL;
    bEnablePositionLimits : BOOL;
    bReadDBNow            : BOOL;
    {attribute 'no_copy'}
    bFileReaderBusy       : REFERENCE TO BOOL;
    {attribute 'no_copy'}
    bFileReaderError      : REFERENCE TO BOOL;

    fbStates : FB_PositionStatePMPSND(
        aiMotionStage         := aiMotionStage,
        astPositionState      := astPositionState,
        nActiveMotorCount     := 1,
        eEnumSet              := eEnumSet,
        eEnumGet              := eEnumGet,
        bEnableMotion         := bEnableMotion,
        eMotionRequestPolicy  := E_MotionRequestPolicy.INTERRUPT,
        bEnableBeamParams     := bEnableBeamParams,
        bEnablePositionLimits := bEnablePositionLimits,
        bReadDBNow            := bReadDBNow,
        bFileReaderBusy       := bFileReaderBusy,
        bFileReaderError      := bFileReaderError,
        fbFFHWO               := fbFFHWO,
        fbArbiter             := fbArbiter,
        sDeviceName           := sDeviceName,
        sTransitionKey        := sTransitionKey
    );

    (* EL6 serial terminal buffers, caller-owned and physically linked
       to the EL6xxx terminal IO. Passed through to FB_XPIM_FilterWheel
       via VAR_IN_OUT each cycle. *)
    {attribute 'no_copy'}
    stEl6In               : REFERENCE TO EL6inData22b;
    {attribute 'no_copy'}
    stEl6Out              : REFERENCE TO EL6outData22b;

    (* One configurator per XPIM state. Writes the per-state sName and
       fDelta. Ticked cyclically in the body AFTER fbStates so its
       writes win over the template baseline FB_StateSetup applied via
       FB_CC_StatePMPSConfig. Idempotent once
       stPositionState.bUpdated trips. *)
    afbStateDefaults : ARRAY[1..4] OF FB_CC_InternalStateConfig[
        (stPositionState := astPositionState[1][E_XPIM_States.OUT],
         sName           := 'OUT',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_XPIM_States.YAG],
         sName           := 'YAG',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_XPIM_States.DIAMOND],
         sName           := 'DIAMOND',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_XPIM_States.RETICLE],
         sName           := 'RETICLE',
         fDelta          := FDELTA_DEFAULT)
    ];

    i : UINT;
END_VAR
VAR_OUTPUT
    // The current position state as an enum.
    {attribute 'pytmc' := '
        pv: MMS:STATE:GET
        io: i
    '}
    eEnumGet: E_XPIM_States;
    // The PMPS database lookup associated with the current position state.
    stDbStateParams: ST_DbStateParams;
END_VAR

VAR CONSTANT
    (* XPIM-wide default tolerance for state in-position detection,
       applied per-state by afbStateDefaults. *)
    FDELTA_DEFAULT : LREAL := 2;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* Nil-ref guards: every REFERENCE TO backing field must be bound. *)
IF NOT __ISVALIDREF(aiMotionStage)
   OR NOT __ISVALIDREF(astPositionState)
   OR NOT __ISVALIDREF(fbFFHWO)
   OR NOT __ISVALIDREF(fbArbiter)
   OR NOT __ISVALIDREF(stEl6In)
   OR NOT __ISVALIDREF(stEl6Out) THEN
    RETURN;
END_IF

(* Device-side per-state defaults (afbStateDefaults) are written
   once in FB_CC_InternalStateConfig.CallAfterInit; no cyclic tick. *)
fbStates(stDbStateParams=> stDbStateParams);

(* Serial filter wheel: bExecute := TRUE keeps the comm state machine
   running continuously. *)
fbFilterWheel(
    bExecute  := TRUE,
    stIn_EL6  := stEl6In,
    stOut_EL6 := stEl6Out
);

fbOpal();
fbLED(enumXPIM := eEnumGet);
fbFlowSwitch();]]></ST>
    </Implementation>
    <Method Name="CallAfterInit" Id="{aa9f645e-c463-4c9e-8962-8aa3b3b2b9c4}">
      <Declaration><![CDATA[(* Auto-fired after FB_Init. fbStates' inline-init ran first and
   forwarded nil refs, so this re-supplies the now-valid refs via
   fbStates.CallAfterInitStateMover / CallAfterInitPMPS and writes the
   per-state device defaults. *)
{attribute 'call_after_init'}
METHOD CallAfterInit
]]></Declaration>
      <Implementation>
        <ST><![CDATA[afbStateDefaults[1].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_XPIM_States.OUT]);
afbStateDefaults[2].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_XPIM_States.YAG]);
afbStateDefaults[3].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_XPIM_States.DIAMOND]);
afbStateDefaults[4].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_XPIM_States.RETICLE]);

THIS^.fbStates.CallAfterInitStateMover(
    aiMotionStage         := aiMotionStage,
    astPositionState      := astPositionState,
    nActiveMotorCount     := 1,
    eEnumSet              := eEnumSet,
    eEnumGet              := eEnumGet,
    bEnableMotion         := bEnableMotion,
    eMotionRequestPolicy  := E_MotionRequestPolicy.INTERRUPT,
);

THIS^.fbStates.CallAfterInitPMPS(
    aiMotionStage         := aiMotionStage,
    astPositionState      := astPositionState,
    bEnableBeamParams     := bEnableBeamParams,
    bEnablePositionLimits := bEnablePositionLimits,
    bReadDBNow            := bReadDBNow,
    bFileReaderBusy       := bFileReaderBusy,
    bFileReaderError      := bFileReaderError,
    fbFFHWO               := fbFFHWO,
    fbArbiter             := fbArbiter,
    sDeviceName           := sDeviceName,
    sTransitionKey        := sTransitionKey
);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_init" Id="{aa9f645f-c463-4c9e-8962-8aa3b3b2b9c5}">
      <Declaration><![CDATA[(* Stores FB_Init inputs into instance fields; every non-value input is
   REFERENCE TO, REF= bound for the FB lifetime. fbStates inline-init
   captured these params at construction, so this records the same refs
   on THIS^ for body use and live caller writes. *)
{attribute 'analysis' := '-33'}
METHOD FB_Init : BOOL
VAR_INPUT
    bInitRetains           : BOOL;
    bInCopyCode            : BOOL;
    aiMotionStage          : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage;
    astPositionState       : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                                            OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;
    fbFFHWO                : REFERENCE TO FB_HardwareFFOutput;
    fbArbiter              : REFERENCE TO FB_Arbiter;
    sDeviceName            : STRING;
    sTransitionKey         : STRING;
    bEnableBeamParams      : BOOL;
    bEnablePositionLimits  : BOOL;
    bReadDBNow             : BOOL;
    bFileReaderBusy        : REFERENCE TO BOOL;
    bFileReaderError       : REFERENCE TO BOOL;
    stEl6In                : REFERENCE TO EL6inData22b;
    stEl6Out               : REFERENCE TO EL6outData22b;

END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.aiMotionStage    REF= aiMotionStage;
THIS^.astPositionState REF= astPositionState;
THIS^.fbFFHWO          REF= fbFFHWO;
THIS^.fbArbiter        REF= fbArbiter;
THIS^.sDeviceName      := sDeviceName;
THIS^.sTransitionKey   := sTransitionKey;
THIS^.bEnableBeamParams     := bEnableBeamParams;
THIS^.bEnablePositionLimits := bEnablePositionLimits;
THIS^.bReadDBNow            := bReadDBNow;
THIS^.bFileReaderBusy       REF= bFileReaderBusy;
THIS^.bFileReaderError      REF= bFileReaderError;
THIS^.stEl6In          REF= stEl6In;
THIS^.stEl6Out         REF= stEl6Out;]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>