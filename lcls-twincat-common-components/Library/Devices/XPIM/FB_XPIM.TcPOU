<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_XPIM" Id="{aa9f645d-c463-4c9e-8962-8aa3b3b2b9c3}" SpecialFunc="None">
    <Declaration><![CDATA[(*
    Function block for XTES Imager (XPIM = XTES PIM = Profile Imager)
    controls under the LCLS_Tc_Motion (ND) framework:
    - Y target-state mover via FB_PositionStatePMPSND with four states
      (OUT, YAG, DIAMOND, RETICLE)
    - serial-driven filter wheel (FB_XPIM_FilterWheel)
    - Opal camera power (FB_XPIM_Opal)
    - LED control gated on the current state (FB_XPIM_LED)
    - flow switch (FB_XTES_Flowswitch)

    FB_XPIM is a thin wrapper for the state-mover plumbing and a tick
    site for the four sub-devices. Motors, motion-stage interface
    array, position-state slot array, fast-fault output, arbiter and
    EL6 serial terminal buffers are caller-owned; FB_XPIM receives
    them by FB_Init REFERENCE TO and forwards them via inline-init.
    The state enum bridge (eEnumSet / eEnumGet, E_XPIM_States) and
    the four run-time toggles (bEnableMotion / bEnableBeamParams /
    bEnablePositionLimits / bReadDBNow) are device-specific and live
    as classic VAR_INPUT; the body re-forwards them into fbStates
    each cycle.

    The legacy 1D FB also owned the Zoom and Focus motors (with their
    own lock + limit-switch inputs); under the ND framework, non-state
    motors are the integrator's concern and FB_XPIM no longer touches
    them. The integrator instantiates FB_MotionStageNC for Zoom/Focus
    in their PRG and wires the lock + limit-switch logic there.

    Per-state configuration is split across two configurators that
    co-operate on each ST_PositionState slot:
      - integrator's FB_CC_StatePMPSConfig array (per-install, declared
        in the caller PRG) wraps motion-lib's FB_StateSetup and writes
        fPosition + sPmpsState plus a caller-owned stDefault baseline
        (bMoveOk / bValid / bUseRawCounts / template fDelta).
      - FB_XPIM.afbStateDefaults (device-side, hardcoded here) writes
        per-state sName and fDelta last, overriding the template
        baseline that FB_StateSetup just laid down. Ordering matters:
        the integrator must tick its PMPS array BEFORE calling fbXPIM.
    Both configurators are idempotent once the parent state FB sets
    stPositionState.bUpdated := TRUE.

    The following IO link points are included and should be used:
    - FB_XPIM.fbOpal.bOpalPower -> camera power digital output
    - FB_XPIM.fbLED.bLEDPower -> LED power digital output
    - FB_XPIM.fbFlowSwitch.bFlowOk -> flow switch digital input
*)
{attribute 'call_after_init'}
FUNCTION_BLOCK FB_XPIM
VAR_INPUT
    (* Device-specific state-enum bridges. Typed as E_XPIM_States (UINT
       base) so the caller surface is enum-checked; the inline-init
       below binds them to FB_PositionStatePMPSND's REFERENCE TO UINT
       params via the shared UINT base. Callers drive moves with
       `fbXPIM.eEnumSet := E_XPIM_States.YAG;` and read
       `fbXPIM.eEnumGet`. *)
    eEnumSet : E_XPIM_States;
    eEnumGet : E_XPIM_States;
END_VAR
VAR
    fbStates : FB_PositionStatePMPSND(
        aiMotionStage         := aiMotionStage,
        astPositionState      := astPositionState,
        nActiveMotorCount     := 1,
        eEnumSet              := eEnumSet,
        eEnumGet              := eEnumGet,
        bEnableMotion         := bEnableMotion,
        eMotionRequestPolicy  := E_MotionRequestPolicy.INTERRUPT,
        bEnableBeamParams     := bEnableBeamParams,
        bEnablePositionLimits := bEnablePositionLimits,
        bReadDBNow            := bReadDBNow,
        bFileReaderBusy       := MOTION_GVL.fbPmpsFileReader.bBusy,
        bFileReaderError      := MOTION_GVL.fbPmpsFileReader.bError,
        fbFFHWO               := fbFFHWO,
        fbArbiter             := fbArbiter,
        sDeviceName           := sDeviceName,
        sTransitionKey        := sTransitionKey
    );

    {attribute 'pytmc' := 'pv: MFW'}
    fbFilterWheel : FB_XPIM_FilterWheel;

    {attribute 'pytmc' := 'pv: CAM'}
    fbOpal : FB_XPIM_Opal;

    {attribute 'pytmc' := 'pv: CIL'}
    fbLED : FB_XPIM_LED;

    {attribute 'pytmc' := 'pv: FSW'}
    fbFlowSwitch : FB_XTES_Flowswitch;

    (* REFERENCE TO backing fields populated by FB_Init. Same names as
       FB_Init params; THIS^. disambiguates inside FB_Init.
       Live-bound to caller storage for the lifetime of the FB. *)
    {attribute 'no_copy'}
    aiMotionStage         : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage;
    {attribute 'no_copy'}
    astPositionState      : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                                            OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;
    {attribute 'no_copy'}
    fbFFHWO               : REFERENCE TO FB_HardwareFFOutput;
    {attribute 'no_copy'}
    fbArbiter             : REFERENCE TO FB_Arbiter;
    sDeviceName           : STRING;
    sTransitionKey        : STRING;
    bEnableMotion         : BOOL := TRUE;
    bEnableBeamParams     : BOOL;
    bEnablePositionLimits : BOOL;
    bReadDBNow            : BOOL;
    (* EL6 serial terminal buffers, caller-owned and physically linked
       to the EL6xxx terminal IO. Passed through to FB_XPIM_FilterWheel
       via VAR_IN_OUT each cycle. *)
    {attribute 'no_copy'}
    stEl6In               : REFERENCE TO EL6inData22b;
    {attribute 'no_copy'}
    stEl6Out              : REFERENCE TO EL6outData22b;

    (* One configurator per XPIM state. Writes the per-state sName and
       fDelta. Ticked cyclically in the body AFTER fbStates so its
       writes win over the template baseline FB_StateSetup applied via
       FB_CC_StatePMPSConfig. Idempotent once
       stPositionState.bUpdated trips. *)
    afbStateDefaults : ARRAY[1..4] OF FB_CC_DeviceStateDefaults[
        (stPositionState := astPositionState[1][E_XPIM_States.OUT],
         sName           := 'OUT',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_XPIM_States.YAG],
         sName           := 'YAG',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_XPIM_States.DIAMOND],
         sName           := 'DIAMOND',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_XPIM_States.RETICLE],
         sName           := 'RETICLE',
         fDelta          := FDELTA_DEFAULT)
    ];

    i : UINT;
END_VAR
VAR CONSTANT
    (* XPIM-wide default tolerance for state in-position detection,
       applied per-state by afbStateDefaults. *)
    FDELTA_DEFAULT : LREAL := 2;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* Nil-ref guards: every REFERENCE TO backing field must be bound. *)
IF NOT __ISVALIDREF(aiMotionStage)
   OR NOT __ISVALIDREF(astPositionState)
   OR NOT __ISVALIDREF(fbFFHWO)
   OR NOT __ISVALIDREF(fbArbiter)
   OR NOT __ISVALIDREF(stEl6In)
   OR NOT __ISVALIDREF(stEl6Out) THEN
    RETURN;
END_IF

(* Device-side per-state defaults (afbStateDefaults) are written
   once in FB_CC_DeviceStateDefaults.CallAfterInit; no cyclic tick. *)
fbStates();

(* Serial filter wheel: bExecute := TRUE keeps the comm state machine
   running continuously. *)
fbFilterWheel(
    bExecute  := TRUE,
    stIn_EL6  := stEl6In,
    stOut_EL6 := stEl6Out
);

fbOpal();
fbLED(enumXPIM := eEnumGet);
fbFlowSwitch();]]></ST>
    </Implementation>
    <Method Name="CallAfterInit" Id="{aa9f645e-c463-4c9e-8962-8aa3b3b2b9c4}">
      <Declaration><![CDATA[(*
    {attribute 'call_after_init'} on FB_XPIM causes TwinCAT to auto-fire
    THIS^.CallAfterInit() after FB_XPIM.FB_Init completes.

    fbStates was constructed via inline-init in FB_XPIM's VAR section,
    which ran BEFORE FB_XPIM.FB_Init bound the REF fields on THIS^.
    Consequently fbStates' inline-init forwarded nil REFs into
    fbStates.FB_Init, and the auto-fired fbStates.CallAfterInit guards
    on those nil REFs and bails. This method re-supplies the now-valid
    refs through fbStates.CallAfterInitStateMover, which re-binds them and runs
    the full child-FB wiring chain (Core / ND / PMPSND).
*)
{attribute 'call_after_init'}
METHOD CallAfterInit
]]></Declaration>
      <Implementation>
        <ST><![CDATA[afbStateDefaults[1].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_XPIM_States.OUT]);
afbStateDefaults[2].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_XPIM_States.YAG]);
afbStateDefaults[3].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_XPIM_States.DIAMOND]);
afbStateDefaults[4].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_XPIM_States.RETICLE]);

THIS^.fbStates.CallAfterInitStateMover(
    aiMotionStage         := aiMotionStage,
    astPositionState      := astPositionState,
    nActiveMotorCount     := 1,
    eEnumSet              := eEnumSet,
    eEnumGet              := eEnumGet,
    bEnableMotion         := bEnableMotion,
    eMotionRequestPolicy  := E_MotionRequestPolicy.INTERRUPT,
);

THIS^.fbStates.CallAfterInitPMPS(
    aiMotionStage         := aiMotionStage,
    astPositionState      := astPositionState,
    bEnableBeamParams     := bEnableBeamParams,
    bEnablePositionLimits := bEnablePositionLimits,
    bReadDBNow            := bReadDBNow,
    bFileReaderBusy       := MOTION_GVL.fbPmpsFileReader.bBusy,
    bFileReaderError      := MOTION_GVL.fbPmpsFileReader.bError,
    fbFFHWO               := fbFFHWO,
    fbArbiter             := fbArbiter,
    sDeviceName           := sDeviceName,
    sTransitionKey        := sTransitionKey
);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_init" Id="{aa9f645f-c463-4c9e-8962-8aa3b3b2b9c5}">
      <Declaration><![CDATA[(* Stores all FB_Init inputs into instance fields. Every non-value
   input is REFERENCE TO and is REF= bound for the lifetime of the FB.
   Inline-init of fbStates above runs first, capturing the FB_Init
   params at construction time; this method then records the same
   references on THIS^ for body-side use and live caller writes.
   The file-reader busy/error inputs are bound straight to
   MOTION_GVL.fbPmpsFileReader inside fbStates' inline-init. *)
{attribute 'analysis' := '-33'}
METHOD FB_Init : BOOL
VAR_INPUT
    bInitRetains           : BOOL;
    bInCopyCode            : BOOL;
    aiMotionStage          : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage;
    astPositionState       : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                                            OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;
    fbFFHWO                : REFERENCE TO FB_HardwareFFOutput;
    fbArbiter              : REFERENCE TO FB_Arbiter;
    sDeviceName            : STRING;
    sTransitionKey         : STRING;
    bEnableBeamParams      : BOOL;
    bEnablePositionLimits  : BOOL;
    bReadDBNow             : BOOL;
    stEl6In                : REFERENCE TO EL6inData22b;
    stEl6Out               : REFERENCE TO EL6outData22b;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.aiMotionStage    REF= aiMotionStage;
THIS^.astPositionState REF= astPositionState;
THIS^.fbFFHWO          REF= fbFFHWO;
THIS^.fbArbiter        REF= fbArbiter;
THIS^.sDeviceName      := sDeviceName;
THIS^.sTransitionKey   := sTransitionKey;
THIS^.bEnableBeamParams     := bEnableBeamParams;
THIS^.bEnablePositionLimits := bEnablePositionLimits;
THIS^.bReadDBNow            := bReadDBNow;
THIS^.stEl6In          REF= stEl6In;
THIS^.stEl6Out         REF= stEl6Out;]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>