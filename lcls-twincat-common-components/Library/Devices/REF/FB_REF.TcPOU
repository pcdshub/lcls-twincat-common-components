<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_REF" Id="{cf150006-917c-41f6-925d-4a5a53f8485a}" SpecialFunc="None">
    <Declaration><![CDATA[(* Reference laser (REF): thin ND-framework state-mover wrapper.
   Y in/out mover via FB_PositionStatePMPSND, plus a tick site for the
   laser power/dimmer (FB_REF_Laser). Caller-owned motors, stage/state
   arrays, fast-fault and arbiter are injected via FB_Init REFERENCE TO
   and forwarded to fbStates; enum bridge and toggles re-forwarded each cycle. *)
{attribute 'call_after_init'}
FUNCTION_BLOCK FB_REF
VAR_INPUT
    (* Device-specific state-enum bridges. Typed as E_EpicsInOut (UINT
       base) so the caller surface is enum-checked; the inline-init
       below binds them to FB_PositionStatePMPSND's REFERENCE TO UINT
       params via the shared UINT base. Callers drive moves with
       `fbREF.eEnumSet := E_EpicsInOut.OUT;` and read
       `fbREF.eEnumGet`. *)
    // Set this to a non-unknown value to request a new move.
    {attribute 'pytmc' := '
        pv: MMS:STATE:SET
        io: io
    '}
    eEnumSet : E_EpicsInOut;
    (* Run-time toggles forwarded into fbStates each cycle. PMPSND
       captures these by value in its own FB_Init, so the body
       re-writes fbStates.* every cycle to track live caller changes. *)
    fTermMax               : LREAL := 200;
END_VAR
VAR


    {attribute 'pytmc' := 'pv: LAS'}
    fbLaser : FB_REF_Laser;

    (* REFERENCE TO backing fields populated by FB_Init. Same names as
       FB_Init params; THIS^. disambiguates inside FB_Init.
       Live-bound to caller storage for the lifetime of the FB. *)
    {attribute 'no_copy'}
    aiMotionStage         : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage;
    {attribute 'no_copy'}
    astPositionState      : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                                            OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;
    {attribute 'no_copy'}
    fbFFHWO               : REFERENCE TO FB_HardwareFFOutput;
    {attribute 'no_copy'}
    fbArbiter             : REFERENCE TO FB_Arbiter;

    sDeviceName           : STRING;
    sTransitionKey        : STRING;
    bEnableMotion         : BOOL := TRUE;
    bEnableBeamParams     : BOOL;
    bEnablePositionLimits : BOOL;
    bReadDBNow            : BOOL;

    bFileReaderBusy       : REFERENCE TO BOOL;
    bFileReaderError      : REFERENCE TO BOOL;
    (* One configurator per REF state (OUT, IN). Writes the per-state
       sName and fDelta. Ticked cyclically in the body AFTER fbStates
       so its writes win over the template baseline FB_StateSetup
       applied via FB_CC_StatePMPSConfig *)
    afbStateDefaults : ARRAY[1..2] OF FB_CC_InternalStateConfig[
        (stPositionState := astPositionState[1][E_EpicsInOut.OUT],
         sName           := 'OUT',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_EpicsInOut.IN],
         sName           := 'IN',
         fDelta          := FDELTA_DEFAULT)
    ];
    {attribute 'pytmc' := 'pv: MMS'}
    fbStates : FB_PositionStatePMPSND(
        aiMotionStage         := aiMotionStage,
        astPositionState      := astPositionState,
        nActiveMotorCount     := 1,
        eEnumSet              := eEnumSet,
        eEnumGet              := eEnumGet,
        bEnableMotion         := bEnableMotion,
        eMotionRequestPolicy  := E_MotionRequestPolicy.INTERRUPT,
        bEnableBeamParams     := bEnableBeamParams,
        bEnablePositionLimits := bEnablePositionLimits,
        bReadDBNow            := bReadDBNow,
        bFileReaderBusy       := bFileReaderBusy,
        bFileReaderError      := bFileReaderError,
        fbFFHWO               := fbFFHWO,
        fbArbiter             := fbArbiter,
        sDeviceName           := sDeviceName,
        sTransitionKey        := sTransitionKey
    );
    i : UINT;
END_VAR
VAR_OUTPUT
    // The current position state as an enum.
    {attribute 'pytmc' := '
        pv: MMS:STATE:GET
        io: i
    '}
     eEnumGet : E_EpicsInOut;
    // The PMPS database lookup associated with the current position state.
    stDbStateParams: ST_DbStateParams;
END_VAR
VAR CONSTANT
    (* REF-wide default tolerance for state in-position detection,
       applied per-state by afbStateDefaults. *)
    FDELTA_DEFAULT : LREAL := 2;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF NOT __ISVALIDREF(aiMotionStage)
   OR NOT __ISVALIDREF(astPositionState)
   OR NOT __ISVALIDREF(fbFFHWO)
   OR NOT __ISVALIDREF(fbArbiter) THEN
    RETURN;
END_IF

fbStates(stDbStateParams=> stDbStateParams);

fbLaser(fTermMax := fTermMax);
]]></ST>
    </Implementation>
    <Method Name="CallAfterInit" Id="{cf150007-917c-41f6-925d-4a5a53f8485b}">
      <Declaration><![CDATA[(* Auto-fired after FB_Init. fbStates' inline-init ran first and
   forwarded nil refs, so this re-supplies the now-valid refs via
   fbStates.CallAfterInitStateMover / CallAfterInitPMPS and writes the
   per-state device defaults. *)
{attribute 'call_after_init'}
METHOD CallAfterInit
VAR
    i : UINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[afbStateDefaults[1].CallAfterInit(
    stPositionState := THIS^.astPositionState[1][E_EpicsInOut.OUT]
);
afbStateDefaults[2].CallAfterInit(
    stPositionState := THIS^.astPositionState[1][E_EpicsInOut.IN]
);

THIS^.fbStates.CallAfterInitStateMover(
    aiMotionStage         := aiMotionStage,
    astPositionState      := astPositionState,
    nActiveMotorCount     := 1,
    eEnumSet              := eEnumSet,
    eEnumGet              := eEnumGet,
    bEnableMotion         := bEnableMotion,
    eMotionRequestPolicy  := E_MotionRequestPolicy.INTERRUPT,
);

THIS^.fbStates.CallAfterInitPMPS(
    aiMotionStage         := aiMotionStage,
    astPositionState      := astPositionState,
    bEnableBeamParams     := bEnableBeamParams,
    bEnablePositionLimits := bEnablePositionLimits,
    bReadDBNow            := bReadDBNow,
    bFileReaderBusy       := bFileReaderBusy,
    bFileReaderError      := bFileReaderError,
    fbFFHWO               := fbFFHWO,
    fbArbiter             := fbArbiter,
    sDeviceName           := sDeviceName,
    sTransitionKey        := sTransitionKey
);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_Init" Id="{7da30f35-8f99-4688-81ce-5ec9994a1d33}">
      <Declaration><![CDATA[//FB_Init is always available implicitly and it is used primarily for initialization.
//The return value is not evaluated. For a specific influence, you can also declare the
//methods explicitly and provide additional code there with the standard initialization
//code. You can evaluate the return value.
METHOD FB_Init: BOOL
VAR_INPUT
    bInitRetains: BOOL; // TRUE: the retain variables are initialized (reset warm / reset cold)
    bInCopyCode: BOOL;  // TRUE: the instance will be copied to the copy code afterward (online change)
    aiMotionStage          : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage;
    astPositionState       : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                                            OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;
    fbFFHWO                : REFERENCE TO FB_HardwareFFOutput;
    fbArbiter              : REFERENCE TO FB_Arbiter;
    sDeviceName            : STRING;
    sTransitionKey         : STRING;
    bEnableBeamParams      : BOOL;
    bEnablePositionLimits  : BOOL;
    bReadDBNow             : BOOL;
    bFileReaderBusy       : REFERENCE TO BOOL;
    bFileReaderError      : REFERENCE TO BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.aiMotionStage    REF= aiMotionStage;
THIS^.astPositionState REF= astPositionState;
THIS^.fbFFHWO          REF= fbFFHWO;
THIS^.fbArbiter        REF= fbArbiter;
THIS^.sDeviceName      := sDeviceName;
THIS^.sTransitionKey   := sTransitionKey;
THIS^.bEnableBeamParams    := bEnableBeamParams;
THIS^.bEnablePositionLimits:= bEnablePositionLimits;
THIS^.bReadDBNow           := bReadDBNow;
THIS^.bFileReaderBusy       REF= bFileReaderBusy;
THIS^.bFileReaderError      REF= bFileReaderError;]]></ST>
      </Implementation>
    </Method>
    <Property Name="MaintMode" Id="{666c9def-1031-444c-b052-5be27153dffd}">
      <Declaration><![CDATA[PROPERTY MaintMode : BOOL]]></Declaration>
      <Get Name="Get" Id="{e61914cd-8c2b-465a-8c3f-ee9ed709699d}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[MaintMode := fbStates.stPMPSEpicsToPlc.bMaintMode;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{14311ec0-b236-48d5-af42-be1d3ad373fa}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[fbStates.stPMPSEpicsToPlc.bMaintMode := MaintMode;]]></ST>
        </Implementation>
      </Set>
    </Property>
  </POU>
</TcPlcObject>