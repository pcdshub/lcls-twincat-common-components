<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_REF" Id="{cf150006-917c-41f6-925d-4a5a53f8485a}" SpecialFunc="None">
    <Declaration><![CDATA[(*
    Function block for reference laser (REF) controls under the
    LCLS_Tc_Motion (ND) framework:
    - Y in/out state mover via FB_PositionStatePMPSND
    - laser power and dimmer via FB_REF_Laser

    FB_REF is a thin wrapper. It owns only what it ticks each cycle
    (fbStates, fbLaser, and the per-state device-default configurators).
    Motors, motion-stage interface array, position-state slot array,
    enum bridge UINTs, fast-fault output and arbiter are caller-owned;
    FB_REF receives them by FB_Init REFERENCE TO and forwards them to
    fbStates via inline-init.

    Per-state configuration is split across two configurators that
    co-operate on each ST_PositionState slot:
      - integrator's FB_CC_StatePMPSConfig array (per-install, declared
        in the caller PRG) wraps motion-lib's FB_StateSetup and writes
        fPosition + sPmpsState plus the REF-wide baseline from
        FB_REF.stDefault (bMoveOk / bValid / bUseRawCounts / template
        fDelta).
      - FB_REF.afbStateDefaults (device-side, hardcoded here) writes
        per-state sName and fDelta last, overriding the template
        baseline that FB_StateSetup just laid down. Ordering matters:
        the integrator must tick its PMPS array BEFORE calling fbREF.
    Both configurators are idempotent once the parent state FB sets
    stPositionState.bUpdated := TRUE.

    The following IO link points are included and should be used:
    - FB_REF.fbLaser.iShutdownINT should be linked to the output for the
      laser dimmer's shutdown voltage.
    - FB_REF.fbLaser.iLaserINT should be linked to the output for the
      laser dimmer's dimmer.
*)
FUNCTION_BLOCK FB_REF
VAR
    fbStates : FB_PositionStatePMPSND(
        aiMotionStage         := aiMotionStage,
        astPositionState      := astPositionState,
        nActiveMotorCount     := 1,
        eEnumSet              := eEnumSet,
        eEnumGet              := eEnumGet,
        bEnableMotion         := FALSE,
        eMotionRequestPolicy  := E_MotionRequestPolicy.INTERRUPT,
        bEnableBeamParams     := FALSE,
        bEnablePositionLimits := FALSE,
        bReadDBNow            := FALSE,
        bFileReaderBusy       := bFileReaderBusy,
        bFileReaderError      := bFileReaderError,
        fbFFHWO               := fbFFHWO,
        fbArbiter             := fbArbiter,
        sDeviceName           := sDeviceName,
        sTransitionKey        := sTransitionKey
    );

    {attribute 'pytmc' := 'pv: LAS'}
    fbLaser : FB_REF_Laser;

    (* REFERENCE TO backing fields populated by FB_Init. Same names as
       FB_Init params; THIS^. disambiguates inside FB_Init. *)
    bEnableMotion         : REFERENCE TO BOOL;
    bEnableBeamParams     : REFERENCE TO BOOL;
    bEnablePositionLimits : REFERENCE TO BOOL;
    bReadDBNow            : REFERENCE TO BOOL;
    fTermMax              : REFERENCE TO LREAL;

    (* Device-common stDefault template. Exposed publicly so the
       integrator's FB_CC_StatePMPSConfig array can bind a REF to it.
       FB_StateSetup inside that helper preloads its VAR_INPUTs from
       this template each call, so the fields here are the REF-wide
       baseline for every state slot. Per-state sName and fDelta
       are subsequently overridden by afbStateDefaults below; sName
       is left blank here on purpose. *)
    stDefault : ST_PositionState := (
        fDelta        := 2,
        bMoveOk       := TRUE,
        bValid        := TRUE,
        bUseRawCounts := FALSE
    );

    (* One configurator per REF state (OUT, IN). Writes the per-state
       sName and (optionally per-state) fDelta. Ticked cyclically in
       the body AFTER fbStates so its writes win over the template
       baseline FB_StateSetup applied via FB_CC_StatePMPSConfig.
       Idempotent once stPositionState.bUpdated trips. *)
    afbStateDefaults : ARRAY[1..2] OF FB_CC_DeviceStateDefaults[
        (stPositionState := astPositionState[1][E_REF_States.OUT],
         sName           := 'OUT',
         fDelta          := 2),
        (stPositionState := astPositionState[1][E_REF_States.IN],
         sName           := 'IN',
         fDelta          := 2)
    ];

    i : UINT;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* Nil-ref guards: every REFERENCE TO backing field must be bound. *)
IF NOT __ISVALIDREF(bEnableMotion)
   OR NOT __ISVALIDREF(bEnableBeamParams)
   OR NOT __ISVALIDREF(bEnablePositionLimits)
   OR NOT __ISVALIDREF(bReadDBNow)
   OR NOT __ISVALIDREF(fTermMax) THEN
    RETURN;
END_IF

(* Apply device-side per-state defaults each cycle. Sleeps once the
   parent state FB sets stPositionState.bUpdated := TRUE. *)
FOR i := 1 TO 2 DO
    afbStateDefaults[i]();
END_FOR

(* PMPSND captures these in FB_Init only. Re-write into its public VAR
   fields each cycle so caller's REFERENCE TO BOOLs take effect live. *)
fbStates.bEnableBeamParams     := bEnableBeamParams;
fbStates.bEnablePositionLimits := bEnablePositionLimits;
fbStates.bReadDBNow            := bReadDBNow;

fbStates(bEnableMotion := bEnableMotion);

fbLaser(fTermMax := fTermMax);]]></ST>
    </Implementation>
    <Method Name="FB_init" Id="{b5f8c2d1-2e3f-5d4b-ac7d-1e9f8a2b3c4d}">
      <Declaration><![CDATA[(* Stores per-cycle REFERENCE TO inputs into instance fields. The
   construction-time params (aiMotionStage, astPositionState, eEnumSet,
   eEnumGet, fbFFHWO, fbArbiter, bFileReaderBusy, bFileReaderError,
   sDeviceName, sTransitionKey) are consumed directly by the inline-init
   of fbStates above and need no further wiring here. *)
{attribute 'analysis' := '-33'}
METHOD FB_Init : BOOL
VAR_INPUT
    bInitRetains           : BOOL;
    bInCopyCode            : BOOL;
    aiMotionStage          : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage;
    astPositionState       : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                                            OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;
    eEnumSet               : REFERENCE TO UINT;
    eEnumGet               : REFERENCE TO UINT;
    bFileReaderBusy        : REFERENCE TO BOOL;
    bFileReaderError       : REFERENCE TO BOOL;
    fbFFHWO                : REFERENCE TO FB_HardwareFFOutput;
    fbArbiter              : REFERENCE TO FB_Arbiter;
    sDeviceName            : STRING;
    sTransitionKey         : STRING;
    bEnableMotion          : REFERENCE TO BOOL;
    bEnableBeamParams      : REFERENCE TO BOOL;
    bEnablePositionLimits  : REFERENCE TO BOOL;
    bReadDBNow             : REFERENCE TO BOOL;
    fTermMax               : REFERENCE TO LREAL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.bEnableMotion         REF= bEnableMotion;
THIS^.bEnableBeamParams     REF= bEnableBeamParams;
THIS^.bEnablePositionLimits REF= bEnablePositionLimits;
THIS^.bReadDBNow            REF= bReadDBNow;
THIS^.fTermMax              REF= fTermMax;]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>