<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_GBS" Id="{0c826496-bbe5-4d0f-95cc-b97d4fbafab2}" SpecialFunc="None">
    <Declaration><![CDATA[(*
    Function block for Grating Beam Splitter (GBS) controls under the
    LCLS_Tc_Motion (ND) framework:
    - Y target-state mover via FB_PositionStatePMPSND with ten states
      (OUT, TARGET1a/b, TARGET2a/b, TARGET3a/b, TARGET4, TARGET5, TARGET6)
    - 2 in-beam RTD thermocouples (FB_CC_TempSensor) gated on the
      current state and driven by the PMPS DB temp setpoint

    FB_GBS is a thin wrapper for the state-mover plumbing and a tick
    site for the two RTDs. Motors, motion-stage interface array,
    position-state slot array, fast-fault output and arbiter are
    caller-owned; FB_GBS receives them by FB_Init REFERENCE TO and
    forwards them to fbStates via inline-init. The state enum bridge
    (eEnumSet / eEnumGet, UINT) and the four run-time toggles
    (bEnableMotion / bEnableBeamParams / bEnablePositionLimits /
    bReadDBNow, plain BOOL) are device-specific and live as classic
    VAR_INPUT; the body re-forwards them into fbStates each cycle.

    Per-state configuration is split across two configurators that
    co-operate on each ST_PositionState slot:
      - integrator's FB_CC_StatePMPSConfig array (per-install, declared
        in the caller PRG) wraps motion-lib's FB_StateSetup and writes
        fPosition + sPmpsState plus a caller-owned stDefault baseline
        (bMoveOk / bValid / bUseRawCounts / template fDelta).
      - FB_GBS.afbStateDefaults (device-side, hardcoded here) writes
        per-state sName and fDelta last, overriding the template
        baseline that FB_StateSetup just laid down. Ordering matters:
        the integrator must tick its PMPS array BEFORE calling fbGBS.
    Both configurators are idempotent once the parent state FB sets
    stPositionState.bUpdated := TRUE.

    The following IO link points are included and should be used:
    - FB_GBS.fbRTD1.{bError,bUnderrange,bOverrange,iRaw} -> RTD #1
      thermocouple terminal inputs
    - FB_GBS.fbRTD2.{bError,bUnderrange,bOverrange,iRaw} -> RTD #2
      thermocouple terminal inputs
*)
{attribute 'call_after_init'}
FUNCTION_BLOCK FB_GBS
VAR_INPUT
    // Set this to a non-unknown value to request a new move.
    {attribute 'pytmc' := '
        pv: MMS:STATE:SET
        io: io
    '}
    eEnumSet : E_GBS_States;
END_VAR
VAR
    {attribute 'pytmc' := 'pv: RTD:01'}
    fbRTD1 : FB_CC_TempSensor;

    {attribute 'pytmc' := 'pv: RTD:02'}
    fbRTD2 : FB_CC_TempSensor;

    (* REFERENCE TO backing fields populated by FB_Init. Same names as
       FB_Init params; THIS^. disambiguates inside FB_Init.
       Live-bound to caller storage for the lifetime of the FB. *)
    {attribute 'no_copy'}
    aiMotionStage         : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage;
    {attribute 'no_copy'}
    astPositionState      : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                                            OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;
    {attribute 'no_copy'}
    fbFFHWO               : REFERENCE TO FB_HardwareFFOutput;
    {attribute 'no_copy'}
    fbArbiter             : REFERENCE TO FB_Arbiter;
    sDeviceName           : STRING;
    sTransitionKey        : STRING;
    bEnableMotion         : BOOL := TRUE;
    bEnableBeamParams     : BOOL;
    bEnablePositionLimits : BOOL;
    bReadDBNow            : BOOL;
    bFileReaderBusy       : REFERENCE TO BOOL;
    bFileReaderError      : REFERENCE TO BOOL;

    (* One configurator per GBS state (OUT + 9 targets). Writes the
       per-state sName and fDelta. Ticked cyclically in the body AFTER
       fbStates so its writes win over the template baseline
       FB_StateSetup applied via FB_CC_StatePMPSConfig. Idempotent once
       stPositionState.bUpdated trips. *)
    afbStateDefaults : ARRAY[1..10] OF FB_CC_DeviceStateDefaults[
        (stPositionState := astPositionState[1][E_GBS_States.OUT],
         sName           := 'OUT',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_GBS_States.TARGET1a],
         sName           := 'TARGET1a',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_GBS_States.TARGET1b],
         sName           := 'TARGET1b',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_GBS_States.TARGET2a],
         sName           := 'TARGET2a',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_GBS_States.TARGET2b],
         sName           := 'TARGET2b',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_GBS_States.TARGET3a],
         sName           := 'TARGET3a',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_GBS_States.TARGET3b],
         sName           := 'TARGET3b',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_GBS_States.TARGET4],
         sName           := 'TARGET4',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_GBS_States.TARGET5],
         sName           := 'TARGET5',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_GBS_States.TARGET6],
         sName           := 'TARGET6',
         fDelta          := FDELTA_DEFAULT)
    ];

    {attribute 'pytmc' := 'pv: MMS'}
    fbStates : FB_PositionStatePMPSND(
        aiMotionStage         := aiMotionStage,
        astPositionState      := astPositionState,
        nActiveMotorCount     := 1,
        eEnumSet              := eEnumSet,
        eEnumGet              := eEnumGet,
        bEnableMotion         := bEnableMotion,
        eMotionRequestPolicy  := E_MotionRequestPolicy.INTERRUPT,
        bEnableBeamParams     := bEnableBeamParams,
        bEnablePositionLimits := bEnablePositionLimits,
        bReadDBNow            := bReadDBNow,
        bFileReaderBusy       := bFileReaderBusy,
        bFileReaderError      := bFileReaderError,
        fbFFHWO               := fbFFHWO,
        fbArbiter             := fbArbiter,
        sDeviceName           := sDeviceName,
        sTransitionKey        := sTransitionKey
    );
    i : UINT;
END_VAR
VAR_OUTPUT
    // The current position state as an enum.
    {attribute 'pytmc' := '
        pv: MMS:STATE:GET
        io: i
    '}
    eEnumGet: E_GBS_States;
    // The PMPS database lookup associated with the current position state.
    stDbStateParams: ST_DbStateParams;
END_VAR
VAR CONSTANT
    (* GBS-wide default tolerance for state in-position detection,
       applied per-state by afbStateDefaults. *)
    FDELTA_DEFAULT : LREAL := 2;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* Nil-ref guards: every REFERENCE TO backing field must be bound. *)
IF NOT __ISVALIDREF(aiMotionStage)
   OR NOT __ISVALIDREF(astPositionState)
   OR NOT __ISVALIDREF(fbFFHWO)
   OR NOT __ISVALIDREF(fbArbiter) THEN
    RETURN;
END_IF

(* Device-side per-state defaults (afbStateDefaults) are written
   once in FB_CC_DeviceStateDefaults.CallAfterInit; no cyclic tick. *)
fbStates(stDbStateParams=> stDbStateParams);

(* In-beam RTDs: only fault when something is actually in the beam
   (i.e. not OUT). Driven by the PMPS DB temp setpoint. *)
fbRTD1(
    fFaultThreshold := fbStates.stDbStateParams.stReactiveParams.nTempSP,
    bVeto           := eEnumGet = E_GBS_States.OUT,
    sDevName        := sDeviceName,
    io_fbFFHWO      := fbFFHWO
);
fbRTD2(
    fFaultThreshold := fbStates.stDbStateParams.stReactiveParams.nTempSP,
    bVeto           := eEnumGet = E_GBS_States.OUT,
    sDevName        := sDeviceName,
    io_fbFFHWO      := fbFFHWO
);]]></ST>
    </Implementation>
    <Method Name="CallAfterInit" Id="{0c826497-bbe5-4d0f-95cc-b97d4fbafab3}">
      <Declaration><![CDATA[(*
    {attribute 'call_after_init'} on FB_GBS causes TwinCAT to auto-fire
    THIS^.CallAfterInit() after FB_GBS.FB_Init completes.

    fbStates was constructed via inline-init in FB_GBS's VAR section,
    which ran BEFORE FB_GBS.FB_Init bound the REF fields on THIS^.
    Consequently fbStates' inline-init forwarded nil REFs into
    fbStates.FB_Init, and the auto-fired fbStates.CallAfterInit guards
    on those nil REFs and bails. This method re-supplies the now-valid
    refs through fbStates.CallAfterInitStateMover, which re-binds them and runs
    the full child-FB wiring chain (Core / ND / PMPSND).
*)
{attribute 'call_after_init'}
METHOD CallAfterInit
]]></Declaration>
      <Implementation>
        <ST><![CDATA[afbStateDefaults[1].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_GBS_States.OUT]);
afbStateDefaults[2].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_GBS_States.TARGET1a]);
afbStateDefaults[3].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_GBS_States.TARGET1b]);
afbStateDefaults[4].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_GBS_States.TARGET2a]);
afbStateDefaults[5].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_GBS_States.TARGET2b]);
afbStateDefaults[6].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_GBS_States.TARGET3a]);
afbStateDefaults[7].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_GBS_States.TARGET3b]);
afbStateDefaults[8].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_GBS_States.TARGET4]);
afbStateDefaults[9].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_GBS_States.TARGET5]);
afbStateDefaults[10].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_GBS_States.TARGET6]);

THIS^.fbStates.CallAfterInitStateMover(
    aiMotionStage         := aiMotionStage,
    astPositionState      := astPositionState,
    nActiveMotorCount     := 1,
    eEnumSet              := eEnumSet,
    eEnumGet              := eEnumGet,
    bEnableMotion         := bEnableMotion,
    eMotionRequestPolicy  := E_MotionRequestPolicy.INTERRUPT,
);

THIS^.fbStates.CallAfterInitPMPS(
    aiMotionStage         := aiMotionStage,
    astPositionState      := astPositionState,
    bEnableBeamParams     := bEnableBeamParams,
    bEnablePositionLimits := bEnablePositionLimits,
    bReadDBNow            := bReadDBNow,
    bFileReaderBusy       := bFileReaderBusy,
    bFileReaderError      := bFileReaderError,
    fbFFHWO               := fbFFHWO,
    fbArbiter             := fbArbiter,
    sDeviceName           := sDeviceName,
    sTransitionKey        := sTransitionKey
);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_init" Id="{0c826498-bbe5-4d0f-95cc-b97d4fbafab4}">
      <Declaration><![CDATA[(* Stores all FB_Init inputs into instance fields. Every non-value
   input is REFERENCE TO and is REF= bound for the lifetime of the FB
   (matches the rule: non-interface FB_Init inputs are taken by ref).
   Inline-init of fbStates above runs first, capturing the FB_Init
   params at construction time; this method then records the same
   references on THIS^ for body-side use and live caller writes.
   The file-reader busy/error inputs are bound straight to
   MOTION_GVL.fbPmpsFileReader inside fbStates' inline-init. *)
{attribute 'analysis' := '-33'}
METHOD FB_Init : BOOL
VAR_INPUT
    bInitRetains           : BOOL;
    bInCopyCode            : BOOL;
    aiMotionStage          : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage;
    astPositionState       : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                                            OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;
    fbFFHWO                : REFERENCE TO FB_HardwareFFOutput;
    fbArbiter              : REFERENCE TO FB_Arbiter;
    sDeviceName            : STRING;
    sTransitionKey         : STRING;
    bEnableBeamParams      : BOOL;
    bEnablePositionLimits  : BOOL;
    bReadDBNow             : BOOL;
    bFileReaderBusy       : REFERENCE TO BOOL;
    bFileReaderError      : REFERENCE TO BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.aiMotionStage    REF= aiMotionStage;
THIS^.astPositionState REF= astPositionState;
THIS^.fbFFHWO          REF= fbFFHWO;
THIS^.fbArbiter        REF= fbArbiter;
THIS^.sDeviceName      := sDeviceName;
THIS^.sTransitionKey   := sTransitionKey;
THIS^.bEnableBeamParams     := bEnableBeamParams;
THIS^.bEnablePositionLimits := bEnablePositionLimits;
THIS^.bReadDBNow            := bReadDBNow;
THIS^.bFileReaderBusy       REF= bFileReaderBusy;
THIS^.bFileReaderError      REF= bFileReaderError;]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>