<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_ATM" Id="{2f5a266c-a319-48e1-b797-55a7489c8358}" SpecialFunc="None">
    <Declaration><![CDATA[(* Arrival Time Monitor (ATM): thin ND-framework state-mover wrapper.
   Y mover via FB_PositionStatePMPSND (states OUT, TARGET1..TARGET5),
   plus a tick site for the in-beam thermocouple and flow meter.
   Caller-owned deps injected via FB_Init REFERENCE TO and forwarded to
   fbStates; device enum bridge and toggles re-forwarded each cycle. *)
{attribute 'call_after_init'}
FUNCTION_BLOCK FB_ATM
VAR_INPUT
    (* Device-specific state-enum bridges. Typed as E_ATM_States (UINT
       base) so the caller surface is enum-checked; the inline-init
       below binds them to FB_PositionStatePMPSND's REFERENCE TO UINT
       params via the shared UINT base. Callers drive moves with
       `fbATM.eEnumSet := E_ATM_States.TARGET1;` and read
       `fbATM.eEnumGet`. *)
    // Set this to a non-unknown value to request a new move.
    {attribute 'pytmc' := '
        pv: MMS:STATE:SET
        io: io
    '}
    eEnumSet : E_ATM_States;
END_VAR
VAR

    {attribute 'pytmc' := 'pv: STC:01'}
    fbTempSensor1 : FB_CC_TempSensor;

    {attribute 'pytmc' := 'pv: FWM'}
    fbFlowMeter : FB_AnalogInput := (iTermBits := 15, fTermMax := 60, fTermMin := 0);

    (* REFERENCE TO backing fields populated by FB_Init. Same names as
       FB_Init params; THIS^. disambiguates inside FB_Init.
       Live-bound to caller storage for the lifetime of the FB. *)
    {attribute 'no_copy'}
    aiMotionStage         : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage;
    {attribute 'no_copy'}
    astPositionState      : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                                            OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;
    {attribute 'no_copy'}
    fbFFHWO               : REFERENCE TO FB_HardwareFFOutput;
    {attribute 'no_copy'}
    fbArbiter             : REFERENCE TO FB_Arbiter;
    sDeviceName           : STRING;
    sTransitionKey        : STRING;
    bEnableMotion         : BOOL := TRUE;
    bEnableBeamParams     : BOOL;
    bEnablePositionLimits : BOOL;
    bReadDBNow            : BOOL;
    bFileReaderBusy       : REFERENCE TO BOOL;
    bFileReaderError      : REFERENCE TO BOOL;

    (* One configurator per ATM state (OUT + 5 targets). Writes the
       per-state sName and fDelta. Ticked cyclically in the body AFTER
       fbStates so its writes win over the template baseline
       FB_StateSetup applied via FB_CC_StatePMPSConfig. Idempotent once
       stPositionState.bUpdated trips. *)
    afbStateDefaults : ARRAY[1..6] OF FB_CC_InternalStateConfig[
        (stPositionState := astPositionState[1][E_ATM_States.OUT],
         sName           := 'OUT',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_ATM_States.TARGET1],
         sName           := 'TARGET1',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_ATM_States.TARGET2],
         sName           := 'TARGET2',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_ATM_States.TARGET3],
         sName           := 'TARGET3',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_ATM_States.TARGET4],
         sName           := 'TARGET4',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_ATM_States.TARGET5],
         sName           := 'TARGET5',
         fDelta          := FDELTA_DEFAULT)
    ];

    {attribute 'pytmc' := 'pv: MMS'}
    fbStates : FB_PositionStatePMPSND(
        aiMotionStage         := aiMotionStage,
        astPositionState      := astPositionState,
        nActiveMotorCount     := 1,
        eEnumSet              := eEnumSet,
        eEnumGet              := eEnumGet,
        bEnableMotion         := bEnableMotion,
        eMotionRequestPolicy  := E_MotionRequestPolicy.INTERRUPT,
        bEnableBeamParams     := bEnableBeamParams,
        bEnablePositionLimits := bEnablePositionLimits,
        bReadDBNow            := bReadDBNow,
        bFileReaderBusy       := bFileReaderBusy,
        bFileReaderError      := bFileReaderError,
        fbFFHWO               := fbFFHWO,
        fbArbiter             := fbArbiter,
        sDeviceName           := sDeviceName,
        sTransitionKey        := sTransitionKey
    );
    i : UINT;
END_VAR
VAR_OUTPUT
    // The current position state as an enum.
    {attribute 'pytmc' := '
        pv: MMS:STATE:GET
        io: i
    '}
    eEnumGet: E_ATM_States;
    // The PMPS database lookup associated with the current position state.
    stDbStateParams: ST_DbStateParams;
END_VAR
VAR CONSTANT
    (* ATM-wide default tolerance for state in-position detection,
       applied per-state by afbStateDefaults. *)
    FDELTA_DEFAULT : LREAL := 2;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF NOT __ISVALIDREF(aiMotionStage)
   OR NOT __ISVALIDREF(astPositionState)
   OR NOT __ISVALIDREF(fbFFHWO)
   OR NOT __ISVALIDREF(fbArbiter) THEN
    RETURN;
END_IF

(* Device-side per-state defaults (afbStateDefaults) are written
   once in FB_CC_InternalStateConfig.CallAfterInit; no cyclic tick. *)
fbStates(stDbStateParams=> stDbStateParams);

(* In-beam thermocouple: only faults when something is actually in the
   beam (i.e. not OUT). Driven by the PMPS DB temp setpoint. *)
fbTempSensor1(
    fFaultThreshold := fbStates.stDbStateParams.stReactiveParams.nTempSP,
    bVeto           := eEnumGet = E_ATM_States.OUT,
    sDevName        := sDeviceName,
    io_fbFFHWO      := fbFFHWO
);

fbFlowMeter();]]></ST>
    </Implementation>
    <Method Name="CallAfterInit" Id="{2f5a266d-a319-48e1-b797-55a7489c8359}">
      <Declaration><![CDATA[(* Auto-fired after FB_Init. fbStates' inline-init ran first and
   forwarded nil refs, so this re-supplies the now-valid refs via
   fbStates.CallAfterInitStateMover / CallAfterInitPMPS and writes the
   per-state device defaults. *)
{attribute 'call_after_init'}
METHOD CallAfterInit
]]></Declaration>
      <Implementation>
        <ST><![CDATA[afbStateDefaults[1].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_ATM_States.OUT]);
afbStateDefaults[2].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_ATM_States.TARGET1]);
afbStateDefaults[3].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_ATM_States.TARGET2]);
afbStateDefaults[4].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_ATM_States.TARGET3]);
afbStateDefaults[5].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_ATM_States.TARGET4]);
afbStateDefaults[6].CallAfterInit(stPositionState := THIS^.astPositionState[1][E_ATM_States.TARGET5]);

THIS^.fbStates.CallAfterInitStateMover(
    aiMotionStage         := aiMotionStage,
    astPositionState      := astPositionState,
    nActiveMotorCount     := 1,
    eEnumSet              := eEnumSet,
    eEnumGet              := eEnumGet,
    bEnableMotion         := bEnableMotion,
    eMotionRequestPolicy  := E_MotionRequestPolicy.INTERRUPT,
);

THIS^.fbStates.CallAfterInitPMPS(
    aiMotionStage         := aiMotionStage,
    astPositionState      := astPositionState,
    bEnableBeamParams     := bEnableBeamParams,
    bEnablePositionLimits := bEnablePositionLimits,
    bReadDBNow            := bReadDBNow,
    bFileReaderBusy       := bFileReaderBusy,
    bFileReaderError      := bFileReaderError,
    fbFFHWO               := fbFFHWO,
    fbArbiter             := fbArbiter,
    sDeviceName           := sDeviceName,
    sTransitionKey        := sTransitionKey
);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_init" Id="{2f5a266e-a319-48e1-b797-55a7489c835a}">
      <Declaration><![CDATA[(* Stores FB_Init inputs into instance fields; every non-value input is
   REFERENCE TO, REF= bound for the FB lifetime. fbStates inline-init
   captured these params at construction, so this records the same refs
   on THIS^ for body use and live caller writes. *)
{attribute 'analysis' := '-33'}
METHOD FB_Init : BOOL
VAR_INPUT
    bInitRetains           : BOOL;
    bInCopyCode            : BOOL;
    aiMotionStage          : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage;
    astPositionState       : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                                            OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;
    fbFFHWO                : REFERENCE TO FB_HardwareFFOutput;
    fbArbiter              : REFERENCE TO FB_Arbiter;
    sDeviceName            : STRING;
    sTransitionKey         : STRING;
    bEnableBeamParams      : BOOL;
    bEnablePositionLimits  : BOOL;
    bReadDBNow             : BOOL;
    bFileReaderBusy       : REFERENCE TO BOOL;
    bFileReaderError      : REFERENCE TO BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.aiMotionStage    REF= aiMotionStage;
THIS^.astPositionState REF= astPositionState;
THIS^.fbFFHWO          REF= fbFFHWO;
THIS^.fbArbiter        REF= fbArbiter;
THIS^.sDeviceName      := sDeviceName;
THIS^.sTransitionKey   := sTransitionKey;
THIS^.bEnableBeamParams     := bEnableBeamParams;
THIS^.bEnablePositionLimits := bEnablePositionLimits;
THIS^.bReadDBNow            := bReadDBNow;
THIS^.bFileReaderBusy       REF= bFileReaderBusy;
THIS^.bFileReaderError      REF= bFileReaderError;]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>