<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_ATM" Id="{2f5a266c-a319-48e1-b797-55a7489c8358}" SpecialFunc="None">
    <Declaration><![CDATA[(*
    Function block for Arrival Time Monitor (ATM) controls under the
    LCLS_Tc_Motion (ND) framework:
    - Y target-state mover via FB_PositionStatePMPSND with six states
      (OUT, TARGET1, TARGET2, TARGET3, TARGET4, TARGET5)
    - in-beam thermocouple (FB_CC_TempSensor)
    - flow meter (FB_AnalogInput)

    FB_ATM is a thin wrapper for the state-mover plumbing and a tick
    site for the two sub-devices. Motors, motion-stage interface
    array, position-state slot array, fast-fault output and arbiter
    are caller-owned; FB_ATM receives them by FB_Init REFERENCE TO and
    forwards them to fbStates via inline-init. The state enum bridge
    (eEnumSet / eEnumGet, UINT) and the four run-time toggles
    (bEnableMotion / bEnableBeamParams / bEnablePositionLimits /
    bReadDBNow, plain BOOL) are device-specific and live as classic
    VAR_INPUT; the body re-forwards them into fbStates each cycle.

    The legacy 1D FB also owned the X (align-to-beam) motor; under the
    ND framework, non-state-controlled motors are the integrator's
    concern and FB_ATM no longer touches them.

    Per-state configuration is split across two configurators that
    co-operate on each ST_PositionState slot:
      - integrator's FB_CC_StatePMPSConfig array (per-install, declared
        in the caller PRG) wraps motion-lib's FB_StateSetup and writes
        fPosition + sPmpsState plus a caller-owned stDefault baseline
        (bMoveOk / bValid / bUseRawCounts / template fDelta).
      - FB_ATM.afbStateDefaults (device-side, hardcoded here) writes
        per-state sName and fDelta last, overriding the template
        baseline that FB_StateSetup just laid down. Ordering matters:
        the integrator must tick its PMPS array BEFORE calling fbATM.
    Both configurators are idempotent once the parent state FB sets
    stPositionState.bUpdated := TRUE.

    The following IO link points are included and should be used:
    - FB_ATM.fbTempSensor1.{bError,bUnderrange,bOverrange,iRaw}
      -> thermocouple terminal inputs
    - FB_ATM.fbFlowMeter.iRaw -> flow meter current analog input
*)
{attribute 'call_after_init'}
FUNCTION_BLOCK FB_ATM
VAR_INPUT
    (* Device-specific state-enum bridges. Typed as E_ATM_States (UINT
       base) so the caller surface is enum-checked; the inline-init
       below binds them to FB_PositionStatePMPSND's REFERENCE TO UINT
       params via the shared UINT base. Callers drive moves with
       `fbATM.eEnumSet := E_ATM_States.TARGET1;` and read
       `fbATM.eEnumGet`. *)
    eEnumSet : E_ATM_States;
    eEnumGet : E_ATM_States;

    (* Run-time toggles forwarded into fbStates each cycle. PMPSND
       captures these by value in its own FB_Init, so the body
       re-writes fbStates.* every cycle to track live caller changes. *)
    bEnableMotion         : BOOL;
    bEnableBeamParams     : BOOL;
    bEnablePositionLimits : BOOL;
    bReadDBNow            : BOOL;
END_VAR
VAR
    fbStates : FB_PositionStatePMPSND(
        aiMotionStage         := aiMotionStage,
        astPositionState      := astPositionState,
        nActiveMotorCount     := 1,
        eEnumSet              := eEnumSet,
        eEnumGet              := eEnumGet,
        bEnableMotion         := bEnableMotion,
        eMotionRequestPolicy  := E_MotionRequestPolicy.INTERRUPT,
        bEnableBeamParams     := bEnableBeamParams,
        bEnablePositionLimits := bEnablePositionLimits,
        bReadDBNow            := bReadDBNow,
        bFileReaderBusy       := MOTION_GVL.fbPmpsFileReader.bBusy,
        bFileReaderError      := MOTION_GVL.fbPmpsFileReader.bError,
        fbFFHWO               := fbFFHWO,
        fbArbiter             := fbArbiter,
        sDeviceName           := sDeviceName,
        sTransitionKey        := sTransitionKey
    );

    {attribute 'pytmc' := 'pv: STC:01'}
    fbTempSensor1 : FB_CC_TempSensor;

    {attribute 'pytmc' := 'pv: FWM'}
    fbFlowMeter : FB_AnalogInput := (iTermBits := 15, fTermMax := 60, fTermMin := 0);

    (* REFERENCE TO backing fields populated by FB_Init. Same names as
       FB_Init params; THIS^. disambiguates inside FB_Init.
       Live-bound to caller storage for the lifetime of the FB. *)
    {attribute 'no_copy'}
    aiMotionStage         : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage;
    {attribute 'no_copy'}
    astPositionState      : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                                            OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;
    {attribute 'no_copy'}
    fbFFHWO               : REFERENCE TO FB_HardwareFFOutput;
    {attribute 'no_copy'}
    fbArbiter             : REFERENCE TO FB_Arbiter;
    {attribute 'no_copy'}
    sDeviceName           : REFERENCE TO STRING;
    {attribute 'no_copy'}
    sTransitionKey        : REFERENCE TO STRING;

    (* One configurator per ATM state (OUT + 5 targets). Writes the
       per-state sName and fDelta. Ticked cyclically in the body AFTER
       fbStates so its writes win over the template baseline
       FB_StateSetup applied via FB_CC_StatePMPSConfig. Idempotent once
       stPositionState.bUpdated trips. *)
    afbStateDefaults : ARRAY[1..6] OF FB_CC_DeviceStateDefaults[
        (stPositionState := astPositionState[1][E_ATM_States.OUT],
         sName           := 'OUT',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_ATM_States.TARGET1],
         sName           := 'TARGET1',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_ATM_States.TARGET2],
         sName           := 'TARGET2',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_ATM_States.TARGET3],
         sName           := 'TARGET3',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_ATM_States.TARGET4],
         sName           := 'TARGET4',
         fDelta          := FDELTA_DEFAULT),
        (stPositionState := astPositionState[1][E_ATM_States.TARGET5],
         sName           := 'TARGET5',
         fDelta          := FDELTA_DEFAULT)
    ];

    i : UINT;
END_VAR
VAR CONSTANT
    (* ATM-wide default tolerance for state in-position detection,
       applied per-state by afbStateDefaults. *)
    FDELTA_DEFAULT : LREAL := 2;

    (* ATM-wide default acceleration / deceleration applied to the
       active motion stage in CallAfterInit. Legacy: fAccel := 200
       (used for both accel and decel). The legacy per-state
       fOutDecel := 25 soft-landing on OUT is lost in the ND framework,
       which has no per-state accel/decel fields on ST_PositionState.
       Velocity stays integrator-owned per the legacy comment "this
       should be set per install"; the device call preserves whatever
       the integrator wrote via SetVelocity. *)
    FACCEL_DEFAULT : LREAL := 200;
    FDECEL_DEFAULT : LREAL := 200;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* Nil-ref guards: every REFERENCE TO backing field must be bound. *)
IF NOT __ISVALIDREF(aiMotionStage)
   OR NOT __ISVALIDREF(astPositionState)
   OR NOT __ISVALIDREF(fbFFHWO)
   OR NOT __ISVALIDREF(fbArbiter)
   OR NOT __ISVALIDREF(sDeviceName)
   OR NOT __ISVALIDREF(sTransitionKey) THEN
    RETURN;
END_IF

(* Apply device-side per-state defaults each cycle. Sleeps once the
   parent state FB sets stPositionState.bUpdated := TRUE. *)
FOR i := 1 TO 6 DO
    afbStateDefaults[i]();
END_FOR

(* PMPSND captures these in FB_Init only. fbStates' inline-init above
   forwarded them once at construction; re-write each cycle so live
   VAR_INPUT writes from the caller propagate. *)
fbStates.bEnableBeamParams     := bEnableBeamParams;
fbStates.bEnablePositionLimits := bEnablePositionLimits;
fbStates.bReadDBNow            := bReadDBNow;

fbStates(bEnableMotion := bEnableMotion);

(* In-beam thermocouple: only faults when something is actually in the
   beam (i.e. not OUT). Driven by the PMPS DB temp setpoint. *)
fbTempSensor1(
    fFaultThreshold := fbStates.stDbStateParams.stReactiveParams.nTempSP,
    bVeto           := eEnumGet = E_ATM_States.OUT,
    sDevName        := sDeviceName,
    io_fbFFHWO      := fbFFHWO
);

fbFlowMeter();]]></ST>
    </Implementation>
    <Method Name="CallAfterInit" Id="{2f5a266d-a319-48e1-b797-55a7489c8359}">
      <Declaration><![CDATA[(*
    {attribute 'call_after_init'} on FB_ATM causes TwinCAT to auto-fire
    THIS^.CallAfterInit() after FB_ATM.FB_Init completes.

    fbStates was constructed via inline-init in FB_ATM's VAR section,
    which ran BEFORE FB_ATM.FB_Init bound the REF fields on THIS^.
    Consequently fbStates' inline-init forwarded nil REFs into
    fbStates.FB_Init, and the auto-fired fbStates.CallAfterInit guards
    on those nil REFs and bails. This method re-supplies the now-valid
    refs through fbStates.CallAfterInitEx, which re-binds them and runs
    the full child-FB wiring chain (Core / ND / PMPSND).
*)
{attribute 'call_after_init'}
METHOD CallAfterInit
]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.fbStates.CallAfterInitEx(
    aiMotionStage         := aiMotionStage,
    astPositionState      := astPositionState,
    nActiveMotorCount     := 1,
    eEnumSet              := eEnumSet,
    eEnumGet              := eEnumGet,
    bEnableMotion         := bEnableMotion,
    eMotionRequestPolicy  := E_MotionRequestPolicy.INTERRUPT,
    bEnableBeamParams     := bEnableBeamParams,
    bEnablePositionLimits := bEnablePositionLimits,
    bReadDBNow            := bReadDBNow,
    bFileReaderBusy       := MOTION_GVL.fbPmpsFileReader.bBusy,
    bFileReaderError      := MOTION_GVL.fbPmpsFileReader.bError,
    fbFFHWO               := fbFFHWO,
    fbArbiter             := fbArbiter,
    sDeviceName           := sDeviceName,
    sTransitionKey        := sTransitionKey
);

(* Apply device-canonical accel / decel to the active motion stage.
   Velocity preserved from MotionParamsCmd (integrator-set via
   SetVelocity, legacy per-install convention); Jerk := 0. *)
aiMotionStage[1].SetMotionParam(
    Velocity     := aiMotionStage[1].MotionParamsCmd.Velocity,
    Acceleration := FACCEL_DEFAULT,
    Deceleration := FDECEL_DEFAULT,
    Jerk         := 0
);]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_init" Id="{2f5a266e-a319-48e1-b797-55a7489c835a}">
      <Declaration><![CDATA[(* Stores all FB_Init inputs into instance fields. Every non-value
   input is REFERENCE TO and is REF= bound for the lifetime of the FB
   (matches the rule: non-interface FB_Init inputs are taken by ref).
   Inline-init of fbStates above runs first, capturing the FB_Init
   params at construction time; this method then records the same
   references on THIS^ for body-side use and live caller writes.
   The file-reader busy/error inputs are bound straight to
   MOTION_GVL.fbPmpsFileReader inside fbStates' inline-init. *)
{attribute 'analysis' := '-33'}
METHOD FB_Init : BOOL
VAR_INPUT
    bInitRetains           : BOOL;
    bInCopyCode            : BOOL;
    aiMotionStage          : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage;
    astPositionState       : REFERENCE TO ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                                            OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;
    fbFFHWO                : REFERENCE TO FB_HardwareFFOutput;
    fbArbiter              : REFERENCE TO FB_Arbiter;
    sDeviceName            : REFERENCE TO STRING;
    sTransitionKey         : REFERENCE TO STRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.aiMotionStage    REF= aiMotionStage;
THIS^.astPositionState REF= astPositionState;
THIS^.fbFFHWO          REF= fbFFHWO;
THIS^.fbArbiter        REF= fbArbiter;
THIS^.sDeviceName      REF= sDeviceName;
THIS^.sTransitionKey   REF= sTransitionKey;]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>
