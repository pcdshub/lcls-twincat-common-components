<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_CC_DeviceStateDefaults" Id="{4d3a1c20-9b7e-4f6a-8d12-7e0c9f5b2a31}" SpecialFunc="None">
    <Declaration><![CDATA[(*
    Per-(state) writer of the device-FB-side fields of an
    ST_PositionState slot that FB_CC_StatePMPSConfig does not
    touch. Performs a one-shot direct write of sName (per-state
    label) and fDelta (per-state tolerance) from CallAfterInit.
    Owned by the device FB (e.g. FB_ATM), one instance per state,
    both fields hardcoded inside the device FB.

    Other slot fields (fPosition, sPmpsState, and the
    safety/baseline fields) are owned by FB_CC_StatePMPSConfig on
    the integrator side; the two helpers' writes do not overlap so
    their CallAfterInit ordering is irrelevant.

    The FB body is empty; the slot is never touched cyclically, so
    online-view edits persist.
*)
FUNCTION_BLOCK FB_CC_DeviceStateDefaults
VAR_INPUT
END_VAR
VAR
    {attribute 'no_copy'}
    stPositionState : REFERENCE TO ST_PositionState;
    sName           : STRING;
    fDelta          : LREAL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="CallAfterInit" Id="{aa6ca063-ddfd-4f28-83a1-576c0b66e12b}">
      <Declaration><![CDATA[(* One-shot write of the device-owned per-state fields (sName,
   fDelta) into the slot. *)
METHOD CallAfterInit
VAR_INPUT
    stPositionState : REFERENCE TO ST_PositionState;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.stPositionState REF= stPositionState;

IF __ISVALIDREF(THIS^.stPositionState) THEN
    THIS^.stPositionState.sName  := THIS^.sName;
    THIS^.stPositionState.fDelta := THIS^.fDelta;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_Init" Id="{4d3a1c20-9b7e-4f6a-8d12-7e0c9f5b2a32}">
      <Declaration><![CDATA[(* Stores the slot reference plus the per-state sName and fDelta
   at instantiation. *)
METHOD FB_Init : BOOL
VAR_INPUT
    bInitRetains    : BOOL;
    bInCopyCode     : BOOL;
    stPositionState : REFERENCE TO ST_PositionState;
    sName           : STRING;
    fDelta          : LREAL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.stPositionState REF= stPositionState;
THIS^.sName            := sName;
THIS^.fDelta           := fDelta;]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>