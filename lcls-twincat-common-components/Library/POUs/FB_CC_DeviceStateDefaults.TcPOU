<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_CC_DeviceStateDefaults" Id="{4d3a1c20-9b7e-4f6a-8d12-7e0c9f5b2a31}" SpecialFunc="None">
    <Declaration><![CDATA[(*
    Per-(state) writer of the device-side fields of a single
    ST_PositionState slot that the caller PRG cannot fully supply via
    FB_CC_StatePMPSConfig: the per-state sName. Owned by the device FB
    (e.g. FB_REF), one instance per state, with sName hardcoded.

    All other device-common fields (fDelta, bMoveOk, bValid,
    bUseRawCounts) are applied by FB_CC_StatePMPSConfig from the device
    FB's stDefault template, which the caller passes in by reference.
    The two helpers write disjoint slot fields so call order does not
    matter.

    Body re-applies cyclically until FB_PositionStateInternalND sets
    stPositionState.bUpdated := TRUE inside the parent state FB; from
    then on the helper sleeps. bForceUpdate is a runtime escape hatch.
*)
FUNCTION_BLOCK FB_CC_DeviceStateDefaults
VAR_INPUT
    bForceUpdate : BOOL;
END_VAR
VAR
    {attribute 'no_copy'}
    stPositionState : REFERENCE TO ST_PositionState;
    sName           : STRING;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF NOT __ISVALIDREF(stPositionState) THEN
    RETURN;
END_IF

IF bForceUpdate OR NOT stPositionState.bUpdated THEN
    stPositionState.sName := sName;
END_IF]]></ST>
    </Implementation>
    <Method Name="FB_Init" Id="{4d3a1c20-9b7e-4f6a-8d12-7e0c9f5b2a32}">
      <Declaration><![CDATA[(* Stores the slot reference and per-state name at instantiation. *)
METHOD FB_Init : BOOL
VAR_INPUT
    bInitRetains    : BOOL;
    bInCopyCode     : BOOL;
    stPositionState : REFERENCE TO ST_PositionState;
    sName           : STRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.stPositionState REF= stPositionState;
THIS^.sName            := sName;]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>
