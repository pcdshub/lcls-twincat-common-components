<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_CC_DeviceStateDefaults" Id="{4d3a1c20-9b7e-4f6a-8d12-7e0c9f5b2a31}" SpecialFunc="None">
    <Declaration><![CDATA[(*
    Per-(state) writer of the device-FB-side fields of an
    ST_PositionState slot that FB_CC_StatePMPSConfig does not
    touch. Completes the init by writing sName (per-state label)
    and fDelta (per-state tolerance). Owned by the device FB (e.g.
    FB_REF), one instance per state, both fields hardcoded inside
    the device FB.

    Disjoint from FB_CC_StatePMPSConfig (which writes fPosition,
    sPmpsState, and the device-common bools from its stDefault
    template), so call order does not matter.

    Body re-applies cyclically until FB_PositionStateInternalND sets
    stPositionState.bUpdated := TRUE inside the parent state FB; from
    then on the helper sleeps. bForceUpdate is a runtime escape hatch.
*)
FUNCTION_BLOCK FB_CC_DeviceStateDefaults
VAR_INPUT
    bForceUpdate : BOOL;
END_VAR
VAR
    {attribute 'no_copy'}
    stPositionState : REFERENCE TO ST_PositionState;
    sName           : STRING;
    fDelta          : LREAL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF NOT __ISVALIDREF(stPositionState) THEN
    RETURN;
END_IF

IF bForceUpdate OR NOT stPositionState.bUpdated THEN
    stPositionState.sName  := sName;
    stPositionState.fDelta := fDelta;
END_IF]]></ST>
    </Implementation>
    <Method Name="FB_Init" Id="{4d3a1c20-9b7e-4f6a-8d12-7e0c9f5b2a32}">
      <Declaration><![CDATA[(* Stores the slot reference plus the per-state sName and fDelta
   at instantiation. *)
METHOD FB_Init : BOOL
VAR_INPUT
    bInitRetains    : BOOL;
    bInCopyCode     : BOOL;
    stPositionState : REFERENCE TO ST_PositionState;
    sName           : STRING;
    fDelta          : LREAL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.stPositionState REF= stPositionState;
THIS^.sName            := sName;
THIS^.fDelta           := fDelta;]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>
