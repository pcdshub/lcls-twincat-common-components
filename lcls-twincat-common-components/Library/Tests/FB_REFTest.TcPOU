<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_REFTest" Id="{bc00a2b4-c887-49cb-85f5-b51e5f3fe97d}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_REFTest EXTENDS FB_TestSuite
VAR
    (* Caller-owned axis, persistent storage, and Y motor.
       In a real PRG the AxisRef would come from MAIN.Mxx. *)
    axRef    : AXIS_REF;
    fbPDS    : LCLS_Tc_DevAbs.FB_PersistentDataStorage;

    afbMotorsNC : ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF FB_MotionStageNC[
        (AxisRef := axRef, iPersistentDataStorage := fbPDS, sName := 'Y'),
        (AxisRef := axRef, iPersistentDataStorage := fbPDS, sName := ''),
        (AxisRef := axRef, iPersistentDataStorage := fbPDS, sName := ''),
        (AxisRef := axRef, iPersistentDataStorage := fbPDS, sName := '')
    ];
    aiMotionStage : ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage
                  := [afbMotorsNC[1], afbMotorsNC[2], afbMotorsNC[3], afbMotorsNC[4]];

    {attribute 'pytmc' := '
        pv: MMS
        astPositionState.array: 1..2
    '}
    astPositionState : ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                         OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;

    (* UINT bridge for the state enum. Callers assign with E_REF_States
       symbols (UNKNOWN/OUT/IN) -- both sides are UINT-underlying. *)
    eSet, eGet : UINT;

    fbFFHWO    : FB_HardwareFFOutput;
    fbArbiter  : FB_Arbiter(1);
    fbSubSysIO : FB_DummyArbIO;

    bFileBusy : BOOL;
    bFileErr  : BOOL;

    (* Per-cycle caller-owned BOOL flags passed by reference to FB_REF. *)
    bEnableMotion         : BOOL;
    bEnableBeamParams     : BOOL;
    bEnablePositionLimits : BOOL;
    bReadDBNow            : BOOL;
    fTermMax              : LREAL := 200;

    fbREF : FB_REF(
        aiMotionStage         := aiMotionStage,
        astPositionState      := astPositionState,
        eEnumSet              := eSet,
        eEnumGet              := eGet,
        bFileReaderBusy       := bFileBusy,
        bFileReaderError      := bFileErr,
        fbFFHWO               := fbFFHWO,
        fbArbiter             := fbArbiter,
        sDeviceName           := 'TST:REF',
        sTransitionKey        := 'TST:REF-TRANSITION',
        bEnableMotion         := bEnableMotion,
        bEnableBeamParams     := bEnableBeamParams,
        bEnablePositionLimits := bEnablePositionLimits,
        bReadDBNow            := bReadDBNow,
        fTermMax              := fTermMax
    );

    (* Per-install PMPS-side state config (caller-owned). Mirrors what
       a real PRG_xxL0_REF would declare. Picks up the device-common
       defaults via stDefault := fbREF.stDefault; fbREF writes only the
       per-state sName internally. *)
    afbStatePMPS : ARRAY[1..2] OF FB_CC_StatePMPSConfig[
        (stPositionState := astPositionState[1][E_REF_States.OUT],
         stDefault       := fbREF.stDefault,
         fPosition       := 10,
         sPmpsState      := 'TST:REF-OUT'),
        (stPositionState := astPositionState[1][E_REF_States.IN],
         stDefault       := fbREF.stDefault,
         fPosition       := 20,
         sPmpsState      := 'TST:REF-IN')
    ];

    bInit : BOOL;
    i     : UINT;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* Fake PMPS handling. *)
fbSubSysIO(
    LA  := fbArbiter,
    FFO := fbFFHWO
);

(* Caller-side PMPS configurators (per-install). *)
FOR i := 1 TO 2 DO
    afbStatePMPS[i]();
END_FOR

IF NOT bInit THEN
    bEnableMotion         := TRUE;
    bEnableBeamParams     := TRUE;
    bEnablePositionLimits := TRUE;
END_IF

bReadDBNow := NOT bInit;

fbPDS();
afbMotorsNC[1]();
fbREF();

TestStateMove();

bInit := TRUE;
]]></ST>
    </Implementation>
    <Method Name="TestStateMove" Id="{3a2a7314-4b65-4375-be43-beb65ac4cd39}">
      <Declaration><![CDATA[METHOD TestStateMove
VAR_INST
    tonTimer  : TON;
    nIterState: UINT := 0;
END_VAR
VAR CONSTANT
    nLastState: UINT := 2; (* E_REF_States.IN *)
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* Sanity check: can we at least move to every named state? *)
TEST('TestREFStateMove');

(* Prepare a timeout *)
tonTimer(IN := TRUE, PT := T#10s);

(* Start in Unknown, then go through the state positions one by one. *)
IF eGet = nIterState THEN
    nIterState := nIterState + 1;
    eSet       := nIterState;
END_IF

IF tonTimer.Q OR nIterState > nLastState THEN
    AssertFalse(tonTimer.Q, 'Timeout in REF move test');
    TEST_FINISHED();
END_IF
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>