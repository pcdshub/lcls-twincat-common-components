<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_REFTest" Id="{bc00a2b4-c887-49cb-85f5-b51e5f3fe97d}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_REFTest EXTENDS FB_TestSuite
VAR
    (* Caller-owned dependencies of FB_REF (passed by REFERENCE at FB_Init). *)
    axRef     : AXIS_REF;
    fbPDS     : LCLS_Tc_DevAbs.FB_PersistentDataStorage;
    fbFFHWO   : FB_HardwareFFOutput;
    fbArbiter : FB_Arbiter(1);
    fbSubSysIO: FB_DummyArbIO;

    bFileBusy : BOOL;
    bFileErr  : BOOL;

    (* Caller-owned per-cycle vars (REFERENCE TO ... fields of FB_REF). *)
    stOut, stIn           : ST_PositionState;
    eSet, eGet            : E_REF_States;
    stDbStateParams       : ST_DbStateParams;
    bEnableMotion         : BOOL;
    bEnableBeamParams     : BOOL;
    bEnablePositionLimits : BOOL;
    bReadDBNow            : BOOL;
    fTermMax              : LREAL := 200;

    fbREF : FB_REF(
        AxisRef                := axRef,
        iPersistentDataStorage := fbPDS,
        sDeviceName            := 'TST:REF',
        sTransitionKey         := 'TST:REF-TRANSITION',
        bFileReaderBusy        := bFileBusy,
        bFileReaderError       := bFileErr,
        fbFFHWO                := fbFFHWO,
        fbArbiter              := fbArbiter,
        stOut                  := stOut,
        stIn                   := stIn,
        eEnumSet               := eSet,
        eEnumGet               := eGet,
        stDbStateParams        := stDbStateParams,
        bEnableMotion          := bEnableMotion,
        bEnableBeamParams      := bEnableBeamParams,
        bEnablePositionLimits  := bEnablePositionLimits,
        bReadDBNow             := bReadDBNow,
        fTermMax               := fTermMax
    );

    bInit : BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* Fake PMPS handling. *)
fbSubSysIO(
    LA  := fbArbiter,
    FFO := fbFFHWO
);

(* One-shot per-state config and enables. *)
IF NOT bInit THEN
    stOut.fPosition  := 10;
    stOut.fDelta     := 0.5;
    stOut.sName      := 'OUT';
    stOut.sPmpsState := 'T0';
    stOut.bMoveOk    := TRUE;
    stOut.bValid     := TRUE;

    stIn.fPosition   := 20;
    stIn.fDelta      := 0.5;
    stIn.sName       := 'T1';
    stIn.sPmpsState  := 'T1';
    stIn.bMoveOk     := TRUE;
    stIn.bValid      := TRUE;

    bEnableMotion         := TRUE;
    bEnableBeamParams     := TRUE;
    bEnablePositionLimits := TRUE;
END_IF

bReadDBNow := NOT bInit;

fbPDS();
fbREF();

TestStateMove();

bInit := TRUE;
]]></ST>
    </Implementation>
    <Method Name="TestStateMove" Id="{3a2a7314-4b65-4375-be43-beb65ac4cd39}">
      <Declaration><![CDATA[METHOD TestStateMove
VAR_INST
    tonTimer  : TON;
    nIterState: UINT := 0;
END_VAR
VAR CONSTANT
    nLastState: UINT := 2; (* E_REF_States.IN *)
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* Sanity check: can we at least move to every named state? *)
TEST('TestREFStateMove');

(* Prepare a timeout *)
tonTimer(IN := TRUE, PT := T#10s);

(* Start in Unknown, then go through the state positions one by one. *)
IF eGet = nIterState THEN
    nIterState := nIterState + 1;
    eSet       := nIterState;
END_IF

IF tonTimer.Q OR nIterState > nLastState THEN
    AssertFalse(tonTimer.Q, 'Timeout in REF move test');
    TEST_FINISHED();
END_IF
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>