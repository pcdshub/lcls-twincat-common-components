<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_REFTest" Id="{bc00a2b4-c887-49cb-85f5-b51e5f3fe97d}" SpecialFunc="None">
    <Declaration><![CDATA[(*
    Single integration smoke for FB_REF. Goal: prove the FB_REF wiring
    (REFERENCE TO refs, CallAfterInit / CallAfterInitEx / CallAfterInitExEx
    chain, inline-init of fbStates, per-state name/fDelta defaults,
    PMPS state-key registration) still drives FB_MotionStageNC into the
    configured fPosition for a commanded state.

    The motion-stack itself (FB_MotionStageNC, FB_PositionStatePMPSND,
    FB_StateSetup, FB_AtPositionState, ...) is fully covered by the
    lcls-twincat-motion-abstraction test suite. This test only checks
    that the CC FB_REF wrapper does not break the contract.

    Procedure:
        1. Wait for first-scan motor setup + PMPS DB loaded.
        2. Command IN (configured fPosition = 20.0, fDelta = 2.0).
        3. Wait for eEnumGet = IN AND |fActPosition - 20.0| <= fDelta.
        4. TEST_FINISHED.
    On watchdog expiry: AssertTrue(FALSE, ...) with the step + observed
    eEnumGet + observed fActPosition so the failure mode is obvious in
    the TcUnit log.
*)
{attribute 'analysis' := '-33'}
FUNCTION_BLOCK FB_REFTest EXTENDS FB_TestSuite
VAR
    axRef    : AXIS_REF;
    fbPDS    : LCLS_Tc_DevAbs.FB_PersistentDataStorage;

    fbMotorY : FB_MotionStageNC(AxisRef := axRef, iPersistentDataStorage := fbPDS, sName := 'Y');

    (* FB_REF is single-motor (nActiveMotorCount := 1) but FB_Init takes
       a full MAX_STATE_MOTORS-sized array; slots 2..N stay as nil
       interfaces and are never indexed. *)
    aiMotionStage : ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage := [fbMotorY];

    {attribute 'pytmc' := '
        pv: MMS
        astPositionState.array: 1..2
    '}
    astPositionState : ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                         OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;

    fbFFHWO    : FB_HardwareFFOutput;
    fbArbiter  : FB_Arbiter(1);
    fbSubSysIO : FB_DummyArbIO;

    bEnableMotion         : BOOL;
    bEnableBeamParams     : BOOL;
    bEnablePositionLimits : BOOL;
    bReadDBNow            : BOOL;

    (* Bound to FB_REF as REFERENCE TO STRING. *)
    sDeviceName    : STRING := 'TST:REF';
    sTransitionKey : STRING := 'TST:REF-TRANSITION';

    fbREF : FB_REF(
        aiMotionStage    := aiMotionStage,
        astPositionState := astPositionState,
        fbFFHWO          := fbFFHWO,
        fbArbiter        := fbArbiter,
        sDeviceName      := sDeviceName,
        sTransitionKey   := sTransitionKey
    );

    (* Caller-owned per-install PMPS configurators. Match the FB_REF
       device-side defaults (sName / fDelta) declared inside FB_REF
       (OUT/IN, fDelta = 2.0). PMPS DB keys must match the fake doc
       seeded by FB_CC_PMPSTestSetup: 'TST:REF-OUT', 'TST:REF-IN'. *)
    stDefault : ST_PositionState := (
        bMoveOk       := TRUE,
        bValid        := TRUE,
        bUseRawCounts := FALSE
    );

    afbStatePMPS : ARRAY[1..2] OF FB_CC_StatePMPSConfig[
        (stPositionState := astPositionState[1][E_REF_States.OUT],
         stDefault       := stDefault,
         fPosition       := 10.0,
         sPmpsState      := 'TST:REF-OUT'),
        (stPositionState := astPositionState[1][E_REF_States.IN],
         stDefault       := stDefault,
         fPosition       := 20.0,
         sPmpsState      := 'TST:REF-IN')
    ];

    bFirstScan : BOOL := TRUE;
    i          : UINT;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[fbSubSysIO(LA := fbArbiter, FFO := fbFFHWO);

FOR i := 1 TO 2 DO
    afbStatePMPS[i]();
END_FOR

IF bFirstScan THEN
    fbMotorY.SetModeEnableLimits(
        LimBackward    := TRUE,
        LimForward     := TRUE,
        HomeEnable     := FALSE,
        BrakeMode      := E_StageBrakeMode.IF_ENABLED,
        EnableMode     := E_StageEnableMode.DURING_MOTION,
        HomeMode       := E_EpicsHomeCmd.LOW_LIMIT,
        UserEnable     := TRUE,
        HardwareEnable := TRUE
    );
    fbMotorY.SetVelocity(Velocity := 15.5);
    fbMotorY.RestoreMotionParams      := FALSE;
    fbMotorY.DoNotRestoreNcParameters := TRUE;

    bEnableMotion         := TRUE;
    bEnableBeamParams     := TRUE;
    bEnablePositionLimits := TRUE;
    bReadDBNow            := TRUE;

    bFirstScan := FALSE;
END_IF

fbPDS();
fbMotorY();
fbREF(
    bEnableMotion         := bEnableMotion,
    bEnableBeamParams     := bEnableBeamParams,
    bEnablePositionLimits := bEnablePositionLimits,
    bReadDBNow            := bReadDBNow
);

T01_StateMove_RequestIn_MotorReachesConfiguredPosition();
]]></ST>
    </Implementation>
    <Method Name="T01_StateMove_RequestIn_MotorReachesConfiguredPosition" Id="{bc00a201-0000-0000-0000-000000000001}">
      <Declaration><![CDATA[(*
    Wiring smoke for FB_REF. Commands IN (configured fPosition = 20.0)
    and asserts (a) eEnumGet reports IN and (b) the Y motor's actual
    position lands within fDelta (2.0) of the configured set point.

    Watchdog: 60s. Fail message includes the step number, the observed
    eEnumGet, and the observed fActPosition so a failure points at
    which part of the wiring chain broke.
*)
METHOD PRIVATE T01_StateMove_RequestIn_MotorReachesConfiguredPosition
VAR_INST
    fbTestTimer : TON := (IN := TRUE, PT := T#60S);
    nTestStep   : INT;
    fGoal       : LREAL := 20.0;
    fTolerance  : LREAL := 2.0;
    fObserved   : LREAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST(__POUNAME());

CASE nTestStep OF
    0:
        (* Wait for cold-start stabilisation: PMPS DB parsed, motor
           ready to accept moves, no residual error. *)
        IF NOT MOTION_GVL.fbPmpsFileReader.bBusy
           AND NOT MOTION_GVL.fbPmpsFileReader.bError
           AND fbMotorY.stMotionStatus.bStageReady
           AND NOT fbMotorY.stMotionStatus.bError THEN
            fbREF.eEnumSet := E_REF_States.IN;
            nTestStep      := 1;
        END_IF

    1:
        fObserved := fbMotorY.stMotionStatus.fActPosition;
        IF fbREF.eEnumGet = E_REF_States.IN
           AND NOT fbMotorY.stMotionStatus.bMoving
           AND ABS(fObserved - fGoal) <= fTolerance THEN
            AssertTrue(
                Condition := TRUE,
                Message   := 'T01: REF reached IN within tolerance');
            nTestStep := 2;
        END_IF
END_CASE

fbTestTimer();

IF nTestStep = 2 THEN
    TEST_FINISHED();
ELSIF fbTestTimer.Q THEN
    AssertTrue(
        Condition := FALSE,
        Message   := CONCAT(
            CONCAT(
                CONCAT('T01: timed out at step ', TO_STRING(nTestStep)),
                CONCAT(', eEnumGet=', TO_STRING(TO_UDINT(fbREF.eEnumGet)))),
            CONCAT(', fActPos=', TO_STRING(fObserved))));
    TEST_FINISHED();
END_IF
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>
