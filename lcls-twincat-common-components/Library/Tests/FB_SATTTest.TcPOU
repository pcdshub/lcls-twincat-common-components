<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_SATTTest" Id="{383787d3-728f-42f6-950b-c99d26391aa0}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_SATTTest EXTENDS FB_TestSuite
VAR
    (* Caller-owned axis, persistent storage, and Y motor.
       In a real PRG the AxisRef would come from MAIN.Mxx. *)
    axRef    : AXIS_REF;
    fbPDS    : LCLS_Tc_DevAbs.FB_PersistentDataStorage;

    (* FB_SXR_SATT_Stage is single-axis (nActiveMotorCount := 1), so
       only slot 1 holds a real motor. aiMotionStage is sized to
       MotionConstants.MAX_STATE_MOTORS to match FB_Init's fixed-size
       signature; slots 2-4 default-init to a nil interface and are
       never touched. *)
    fbMotorY      : FB_MotionStageNC(AxisRef := axRef, iPersistentDataStorage := fbPDS, sName := 'Y');
    aiMotionStage : ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage := [fbMotorY];

    {attribute 'pytmc' := '
        pv: MMS
        astPositionState.array: 1..9
    '}
    astPositionState : ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                         OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;

    fbFFHWO : FB_HardwareFFOutput;

    (* Per-cycle caller-owned BOOL flag, written into FB_SATT via
       VAR_INPUT call syntax in the cyclic body below. SATT has no
       PMPS toggles (no beam-params / position-limits / DB-now). *)
    bEnableMotion : BOOL;

    (* Device-name string bound to FB_SATT as REFERENCE TO STRING --
       a literal cannot be REF-bound, so it lives as a local here. *)
    sDeviceName : STRING := 'TST:SATT';

    fbSATT : FB_SXR_SATT_Stage(
        aiMotionStage    := aiMotionStage,
        astPositionState := astPositionState,
        fbFFHWO          := fbFFHWO,
        sDeviceName      := sDeviceName
    );

    (* Per-install state config (caller-owned). Mirrors what a real
       PRG_xxL0_SATT would declare. stDefault is the caller-owned
       baseline template that FB_CC_StatePMPSConfig's inner
       FB_StateSetup preloads from; fbSATT subsequently overrides
       per-state sName and fDelta via its own
       FB_CC_DeviceStateDefaults array.

       FILTER1 carries the PMPS state key the test exercises; the
       other filter slots leave sPmpsState blank, matching legacy
       behavior where the FB picks the first non-empty key. *)
    stDefault : ST_PositionState := (
        bMoveOk       := TRUE,
        bValid        := TRUE,
        bUseRawCounts := FALSE
    );

    afbStatePMPS : ARRAY[1..9] OF FB_CC_StatePMPSConfig[
        (stPositionState := astPositionState[1][E_SXR_SATT_Position.OUT],
         stDefault       := stDefault,
         fPosition       := 10,
         sPmpsState      := ''),
        (stPositionState := astPositionState[1][E_SXR_SATT_Position.FILTER1],
         stDefault       := stDefault,
         fPosition       := 20,
         sPmpsState      := 'TST:SATT-FILTER1'),
        (stPositionState := astPositionState[1][E_SXR_SATT_Position.FILTER2],
         stDefault       := stDefault,
         fPosition       := 30,
         sPmpsState      := ''),
        (stPositionState := astPositionState[1][E_SXR_SATT_Position.FILTER3],
         stDefault       := stDefault,
         fPosition       := 40,
         sPmpsState      := ''),
        (stPositionState := astPositionState[1][E_SXR_SATT_Position.FILTER4],
         stDefault       := stDefault,
         fPosition       := 50,
         sPmpsState      := ''),
        (stPositionState := astPositionState[1][E_SXR_SATT_Position.FILTER5],
         stDefault       := stDefault,
         fPosition       := 60,
         sPmpsState      := ''),
        (stPositionState := astPositionState[1][E_SXR_SATT_Position.FILTER6],
         stDefault       := stDefault,
         fPosition       := 70,
         sPmpsState      := ''),
        (stPositionState := astPositionState[1][E_SXR_SATT_Position.FILTER7],
         stDefault       := stDefault,
         fPosition       := 80,
         sPmpsState      := ''),
        (stPositionState := astPositionState[1][E_SXR_SATT_Position.FILTER8],
         stDefault       := stDefault,
         fPosition       := 90,
         sPmpsState      := '')
    ];

    bFirstScan : BOOL := TRUE;
    i          : UINT;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* Caller-side state configurators (per-install). *)
FOR i := 1 TO 9 DO
    afbStatePMPS[i]();
END_FOR

(* One-shot motor setup + initial caller-owned enable. *)
IF bFirstScan THEN
    fbMotorY.SetModeEnableLimits(
        LimBackward    := TRUE,
        LimForward     := TRUE,
        HomeEnable     := FALSE,
        BrakeMode      := E_StageBrakeMode.NO_BRAKE,
        EnableMode     := E_StageEnableMode.DURING_MOTION,
        HomeMode       := E_EpicsHomeCmd.NONE,
        UserEnable     := TRUE,
        HardwareEnable := TRUE
    );
    fbMotorY.SetVelocity(Velocity := 15.5);
    fbMotorY.RestoreMotionParams      := FALSE;
    fbMotorY.DoNotRestoreNcParameters := TRUE;

    bEnableMotion := TRUE;

    bFirstScan := FALSE;
END_IF

fbPDS();
fbMotorY();
fbSATT(bEnableMotion := bEnableMotion);

TestStateMove();
TestTempFFO();
]]></ST>
    </Implementation>
    <Method Name="AssertBothTempFault" Id="{95d6c1aa-c314-417f-8510-e65298bca360}">
      <Declaration><![CDATA[METHOD AssertBothTempFault
VAR_INPUT
    Message : STRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
AssertFalse(
    fbSATT.fbRTD_1.FFO.i_xOK,
    CONCAT('SATT RTD1 expected fault: ', Message)
);
AssertFalse(
    fbSATT.fbRTD_2.FFO.i_xOK,
    CONCAT('SATT RTD2 expected fault: ', Message)
);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AssertNeitherTempFault" Id="{5de84732-353a-4a55-9eb9-df3ae8bca03b}">
      <Declaration><![CDATA[METHOD AssertNeitherTempFault
VAR_INPUT
    Message : STRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
AssertTrue(
    fbSATT.fbRTD_1.FFO.i_xOK,
    CONCAT('SATT RTD1 expected ok: ', Message)
);
AssertTrue(
    fbSATT.fbRTD_2.FFO.i_xOK,
    CONCAT('SATT RTD2 expected ok: ', Message)
);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetSATTTemp" Id="{7ebc7bb7-f0d1-456e-9851-f9318ff9a3aa}">
      <Declaration><![CDATA[METHOD SetSATTTemp
VAR_INPUT
    iTempC : INT;
END_VAR
VAR
    ptr : POINTER TO INT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
ptr  := ADR(fbSATT.fbRTD_1.iRaw);
ptr^ := iTempC * 100;

ptr  := ADR(fbSATT.fbRTD_2.iRaw);
ptr^ := iTempC * 100;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="TestStateMove" Id="{6c59097f-e216-48c9-8846-19da78be43c4}">
      <Declaration><![CDATA[METHOD TestStateMove
VAR_INST
    tonTimer   : TON;
    nIterState : UINT := 0;
END_VAR
VAR CONSTANT
    nLastState : UINT := 9; (* E_SXR_SATT_Position.FILTER8 *)
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* Sanity check: can we at least move to every named state? *)
TEST('TestSATTStateMove');

(* Prepare a timeout *)
tonTimer(IN := TRUE, PT := T#20s);

(* Start in Unknown, then go through the state positions one by one. *)
IF fbSATT.eEnumGet = nIterState THEN
    nIterState      := nIterState + 1;
    fbSATT.eEnumSet := nIterState;
END_IF

IF tonTimer.Q OR nIterState > nLastState THEN
    AssertFalse(tonTimer.Q, 'Timeout in SATT move test');
    TEST_FINISHED();
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="TestTempFFO" Id="{f4f8a550-63b6-47ea-b8a6-24727446e218}">
      <Declaration><![CDATA[METHOD TestTempFFO
VAR_INST
    tonTimer    : TON;
    nStep       : UINT := 0;
    bOutChecked : BOOL := FALSE;
    bInChecked  : BOOL := FALSE;
END_VAR
VAR CONSTANT
    nLastStep : UINT := 3;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* Do we fault at the correct times?
   Parasitically depends on state move test. *)
TEST('TestSATTTempFFO');

(* Prepare a timeout *)
tonTimer(IN := TRUE, PT := T#10s);

CASE nStep OF
    0:
        (* Set the thermocouple temperatures to crazy high number. *)
        SetSATTTemp(100);
        nStep := nStep + 1;
    1:
        (* Wait till we see "OUT" state and one other state (OUT
           should be no fault). *)
        IF fbSATT.eEnumGet = E_SXR_SATT_Position.OUT THEN
            AssertNeitherTempFault('was in out position');
            bOutChecked := TRUE;
        ELSIF fbSATT.eEnumGet <> E_SXR_SATT_Position.UNKNOWN THEN
            AssertBothTempFault('was in a target position');
            bInChecked := TRUE;
        END_IF
        IF bOutChecked AND bInChecked THEN
            nStep := nStep + 1;
        END_IF
    2:
        (* Set the thermocouple temperatures to low again. *)
        SetSATTTemp(0);
        nStep := nStep + 1;
    3:
        AssertNeitherTempFault('has low temp reading');
        nStep := nStep + 1;
END_CASE

IF tonTimer.Q OR nStep > nLastStep THEN
    AssertFalse(tonTimer.Q, 'Timeout in SATT temp FFO test');
    TEST_FINISHED();
END_IF
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>
