<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_CC_PMPSTestSetup" Id="{cc000002-3a30-49c7-add4-72cbb7abbf6b}" SpecialFunc="None">
    <Declaration><![CDATA[
(*
    One-shot PMPS fake-DB seeder for the CC test suite. Mirrors
    LCLS_Tc_Motion.FB_PMPSTestSetup: one FB_PMPSJsonTestHelperEx
    instance per device, first call uses bNewDoc := TRUE, the rest
    use bNewDoc := FALSE so the document at PMPS_GVL.BP_jsonDoc
    accumulates every test device:

        { "TST:ATM": { "TST:ATM-TRANSITION": {...}, ... },
          "TST:LIC": { ... }, ... }

    Only sPmpsState is populated per row. The helper fills the rest
    of the JSON shape with default-zero values, which is enough for
    the wiring smoke tests to look up state keys and request a move.
    Tests that need richer beam params (rate, beam class, eV range,
    reactive temperature) set them on the relevant astParams_XXX
    entries before this FB ticks, or extend it.

    Call once per cycle in PRG_TEST BEFORE TcUnit.RUN(). After bDone
    latches on the first cycle, subsequent calls are no-ops.

    Single point of truth: PMPS_GVL.BP_jsonDoc is global and test
    FBs run concurrently. Seeding stays here so per-device writes
    cannot race on the same cycle.
*)
{attribute 'analysis' := '-33'}
FUNCTION_BLOCK FB_CC_PMPSTestSetup
VAR
    fbJsonHelper_ATM   : FB_PMPSJsonTestHelperEx;
    fbJsonHelper_LIC   : FB_PMPSJsonTestHelperEx;
    fbJsonHelper_PPM   : FB_PMPSJsonTestHelperEx;
    fbJsonHelper_REF   : FB_PMPSJsonTestHelperEx;
    fbJsonHelper_GBS   : FB_PMPSJsonTestHelperEx;
    fbJsonHelper_IPM   : FB_PMPSJsonTestHelperEx;
    fbJsonHelper_WFS   : FB_PMPSJsonTestHelperEx;
    fbJsonHelper_XPIM  : FB_PMPSJsonTestHelperEx;
    fbJsonHelper_SATT  : FB_PMPSJsonTestHelperEx;
    fbJsonHelper_SLITS : FB_PMPSJsonTestHelperEx;

    (* astParams_XXX[0] is the transition key; the rest are named-state
       keys in enum order. *)
    astParams_ATM   : ARRAY[0..6] OF ST_DbStateParams;
    astParams_LIC   : ARRAY[0..4] OF ST_DbStateParams;
    astParams_PPM   : ARRAY[0..4] OF ST_DbStateParams;
    astParams_REF   : ARRAY[0..2] OF ST_DbStateParams;
    astParams_GBS   : ARRAY[0..10] OF ST_DbStateParams;
    astParams_IPM   : ARRAY[0..5] OF ST_DbStateParams;
    astParams_WFS   : ARRAY[0..6] OF ST_DbStateParams;
    astParams_XPIM  : ARRAY[0..5] OF ST_DbStateParams;
    astParams_SATT  : ARRAY[0..1] OF ST_DbStateParams;
    astParams_SLITS : ARRAY[0..0] OF ST_DbStateParams;

    bDone : BOOL := FALSE;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[
IF bDone THEN
    RETURN;
END_IF

(* ---- TST:ATM ---- *)
astParams_ATM[0].sPmpsState := 'TST:ATM-TRANSITION';
astParams_ATM[1].sPmpsState := 'TST:ATM-OUT';
astParams_ATM[2].sPmpsState := 'TST:ATM-TARGET1';
astParams_ATM[3].sPmpsState := 'TST:ATM-TARGET2';
astParams_ATM[4].sPmpsState := 'TST:ATM-TARGET3';
astParams_ATM[5].sPmpsState := 'TST:ATM-TARGET4';
astParams_ATM[6].sPmpsState := 'TST:ATM-TARGET5';

(* ---- TST:LIC ---- *)
astParams_LIC[0].sPmpsState := 'TST:LIC-TRANSITION';
astParams_LIC[1].sPmpsState := 'TST:LIC-OUT';
astParams_LIC[2].sPmpsState := 'TST:LIC-MIRROR1';
astParams_LIC[3].sPmpsState := 'TST:LIC-MIRROR2';
astParams_LIC[4].sPmpsState := 'TST:LIC-TARGET';

(* ---- TST:PPM ---- *)
astParams_PPM[0].sPmpsState := 'TST:PPM-TRANSITION';
astParams_PPM[1].sPmpsState := 'TST:PPM-OUT';
astParams_PPM[2].sPmpsState := 'TST:PPM-POWERMETER';
astParams_PPM[3].sPmpsState := 'TST:PPM-YAG1';
astParams_PPM[4].sPmpsState := 'TST:PPM-YAG2';

(* ---- TST:REF ---- *)
astParams_REF[0].sPmpsState := 'TST:REF-TRANSITION';
astParams_REF[1].sPmpsState := 'TST:REF-OUT';
astParams_REF[2].sPmpsState := 'TST:REF-IN';

(* ---- TST:GBS ---- *)
astParams_GBS[0].sPmpsState  := 'TST:GBS-TRANSITION';
astParams_GBS[1].sPmpsState  := 'TST:GBS-OUT';
astParams_GBS[2].sPmpsState  := 'TST:GBS-TARGET1a';
astParams_GBS[3].sPmpsState  := 'TST:GBS-TARGET1b';
astParams_GBS[4].sPmpsState  := 'TST:GBS-TARGET2a';
astParams_GBS[5].sPmpsState  := 'TST:GBS-TARGET2b';
astParams_GBS[6].sPmpsState  := 'TST:GBS-TARGET3a';
astParams_GBS[7].sPmpsState  := 'TST:GBS-TARGET3b';
astParams_GBS[8].sPmpsState  := 'TST:GBS-TARGET4';
astParams_GBS[9].sPmpsState  := 'TST:GBS-TARGET5';
astParams_GBS[10].sPmpsState := 'TST:GBS-TARGET6';

(* ---- TST:IPM ---- *)
astParams_IPM[0].sPmpsState := 'TST:IPM-TRANSITION';
astParams_IPM[1].sPmpsState := 'TST:IPM-OUT';
astParams_IPM[2].sPmpsState := 'TST:IPM-TARGET1';
astParams_IPM[3].sPmpsState := 'TST:IPM-TARGET2';
astParams_IPM[4].sPmpsState := 'TST:IPM-TARGET3';
astParams_IPM[5].sPmpsState := 'TST:IPM-TARGET4';

(* ---- TST:WFS ---- *)
astParams_WFS[0].sPmpsState := 'TST:WFS-TRANSITION';
astParams_WFS[1].sPmpsState := 'TST:WFS-OUT';
astParams_WFS[2].sPmpsState := 'TST:WFS-TARGET1';
astParams_WFS[3].sPmpsState := 'TST:WFS-TARGET2';
astParams_WFS[4].sPmpsState := 'TST:WFS-TARGET3';
astParams_WFS[5].sPmpsState := 'TST:WFS-TARGET4';
astParams_WFS[6].sPmpsState := 'TST:WFS-TARGET5';

(* ---- TST:XPIM ---- *)
astParams_XPIM[0].sPmpsState := 'TST:XPIM-TRANSITION';
astParams_XPIM[1].sPmpsState := 'TST:XPIM-OUT';
astParams_XPIM[2].sPmpsState := 'TST:XPIM-DIAMOND';
astParams_XPIM[3].sPmpsState := 'TST:XPIM-RETICLE';
astParams_XPIM[4].sPmpsState := 'TST:XPIM-YAG';
astParams_XPIM[5].sPmpsState := 'TST:XPIM-POWERMETER';

(* ---- TST:SATT ---- *)
astParams_SATT[0].sPmpsState := 'TST:SATT-TRANSITION';
astParams_SATT[1].sPmpsState := 'TST:SATT-FILTER1';

(* ---- TST:SLITS (single PMPS key, aperture geometry not state-keyed) ---- *)
astParams_SLITS[0].sPmpsState := 'TST:SLITS';

(* First helper creates the root document, the rest append. *)
fbJsonHelper_ATM(
    astBeamParams := astParams_ATM,
    bExecute      := TRUE,
    sDevName      := 'TST:ATM',
    bNewDoc       := TRUE);

fbJsonHelper_LIC(
    astBeamParams := astParams_LIC,
    bExecute      := TRUE,
    sDevName      := 'TST:LIC',
    bNewDoc       := FALSE);

fbJsonHelper_PPM(
    astBeamParams := astParams_PPM,
    bExecute      := TRUE,
    sDevName      := 'TST:PPM',
    bNewDoc       := FALSE);

fbJsonHelper_REF(
    astBeamParams := astParams_REF,
    bExecute      := TRUE,
    sDevName      := 'TST:REF',
    bNewDoc       := FALSE);

fbJsonHelper_GBS(
    astBeamParams := astParams_GBS,
    bExecute      := TRUE,
    sDevName      := 'TST:GBS',
    bNewDoc       := FALSE);

fbJsonHelper_IPM(
    astBeamParams := astParams_IPM,
    bExecute      := TRUE,
    sDevName      := 'TST:IPM',
    bNewDoc       := FALSE);

fbJsonHelper_WFS(
    astBeamParams := astParams_WFS,
    bExecute      := TRUE,
    sDevName      := 'TST:WFS',
    bNewDoc       := FALSE);

fbJsonHelper_XPIM(
    astBeamParams := astParams_XPIM,
    bExecute      := TRUE,
    sDevName      := 'TST:XPIM',
    bNewDoc       := FALSE);

fbJsonHelper_SATT(
    astBeamParams := astParams_SATT,
    bExecute      := TRUE,
    sDevName      := 'TST:SATT',
    bNewDoc       := FALSE);

fbJsonHelper_SLITS(
    astBeamParams := astParams_SLITS,
    bExecute      := TRUE,
    sDevName      := 'TST:SLITS',
    bNewDoc       := FALSE);

bDone := TRUE;
]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>
