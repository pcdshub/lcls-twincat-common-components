<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_CC_PMPSTestSetup" Id="{cc000002-3a30-49c7-add4-72cbb7abbf6b}" SpecialFunc="None">
    <Declaration><![CDATA[
(*
    One-shot PMPS fake-DB seeder for the CC test suite. Runs once at
    PLC startup; on the first scan it writes a single in-memory JSON
    document into PMPS_GVL.BP_jsonDoc containing every device the test
    suite touches:

        { "TST:ATM":   { "TST:ATM-TRANSITION": {...}, "TST:ATM-OUT": {...}, ... },
          "TST:LIC":   { ... },
          "TST:PPM":   { ... },
          "TST:REF":   { ... },
          "TST:GBS":   { ... },
          "TST:IPM":   { ... },
          "TST:WFS":   { ... },
          "TST:XPIM":  { ... },
          "TST:SATT":  { ... },
          "TST:SLITS": { ... } }

    Mirrors how a real device PRG sees BP_jsonDoc after EPICS uploads
    the JSON file and FB_Standard_PMPSDB has parsed it down to the
    "PLC name" level.

    Per-state beam params:
      stBeamParams.nRate / nBeamClass / neVRange / nTran / nMachineMode
      drive the PMPS arbitration path.
    Per-state reactive params:
      stReactiveParams.nTempSP feeds FB_CC_TempSensor /
      FB_JsonDocToSafeBP for ATM / PPM / SLITS_POWER RTD thresholds.

    Design follows lcls-twincat-motion-abstraction.FB_PMPSTestSetup:
    one helper instance per device, first call uses bNewDoc := TRUE,
    every subsequent call uses bNewDoc := FALSE so the root document
    accumulates devices instead of being replaced.

    Call this in PRG_TEST BEFORE TcUnit.RUN() each cycle. After bDone
    latches, subsequent calls are no-ops.

    Single point of truth: every device test runs concurrently and
    PMPS_GVL.BP_jsonDoc is global. Seeding MUST happen here, once,
    before any test FB ticks. Do not move per-device seeding into
    individual test FBs: concurrent writes to BP_jsonDoc on the same
    cycle will race and corrupt the document.
*)
{attribute 'analysis' := '-33'}
FUNCTION_BLOCK FB_CC_PMPSTestSetup
VAR
    fbJsonHelper_ATM   : FB_PMPSJsonTestHelperEx;
    fbJsonHelper_LIC   : FB_PMPSJsonTestHelperEx;
    fbJsonHelper_PPM   : FB_PMPSJsonTestHelperEx;
    fbJsonHelper_REF   : FB_PMPSJsonTestHelperEx;
    fbJsonHelper_GBS   : FB_PMPSJsonTestHelperEx;
    fbJsonHelper_IPM   : FB_PMPSJsonTestHelperEx;
    fbJsonHelper_WFS   : FB_PMPSJsonTestHelperEx;
    fbJsonHelper_XPIM  : FB_PMPSJsonTestHelperEx;
    fbJsonHelper_SATT  : FB_PMPSJsonTestHelperEx;
    fbJsonHelper_SLITS : FB_PMPSJsonTestHelperEx;

    (* Per-device beam-param arrays. astParams_XXX[0] is the
       transition key, rest are named-state keys in enum order. *)
    astParams_ATM   : ARRAY[0..6] OF ST_DbStateParams;
    astParams_LIC   : ARRAY[0..4] OF ST_DbStateParams;
    astParams_PPM   : ARRAY[0..4] OF ST_DbStateParams;
    astParams_REF   : ARRAY[0..2] OF ST_DbStateParams;
    astParams_GBS   : ARRAY[0..10] OF ST_DbStateParams;
    astParams_IPM   : ARRAY[0..5] OF ST_DbStateParams;
    astParams_WFS   : ARRAY[0..6] OF ST_DbStateParams;
    astParams_XPIM  : ARRAY[0..5] OF ST_DbStateParams;
    astParams_SATT  : ARRAY[0..1] OF ST_DbStateParams;
    astParams_SLITS : ARRAY[0..0] OF ST_DbStateParams;

    bDone : BOOL := FALSE;
    nIter : UINT;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[
IF bDone THEN
    RETURN;
END_IF

(* ---- TST:ATM (transition + 6 named states) ---- *)
astParams_ATM[0].sPmpsState                := 'TST:ATM-TRANSITION';
astParams_ATM[0].stBeamParams              := PMPS_GVL.cstFullBeam;
astParams_ATM[0].stBeamParams.nRate        := 0;
astParams_ATM[1].sPmpsState                := 'TST:ATM-OUT';
astParams_ATM[1].stBeamParams              := PMPS_GVL.cstFullBeam;
astParams_ATM[2].sPmpsState                := 'TST:ATM-TARGET1';
astParams_ATM[2].stBeamParams              := PMPS_GVL.cstFullBeam;
astParams_ATM[3].sPmpsState                := 'TST:ATM-TARGET2';
astParams_ATM[3].stBeamParams              := PMPS_GVL.cstFullBeam;
astParams_ATM[4].sPmpsState                := 'TST:ATM-TARGET3';
astParams_ATM[4].stBeamParams              := PMPS_GVL.cstFullBeam;
astParams_ATM[5].sPmpsState                := 'TST:ATM-TARGET4';
astParams_ATM[5].stBeamParams              := PMPS_GVL.cstFullBeam;
astParams_ATM[6].sPmpsState                := 'TST:ATM-TARGET5';
astParams_ATM[6].stBeamParams              := PMPS_GVL.cstFullBeam;
(* ATM has a thermocouple FFO: seed a reactive_temp setpoint that the
   test can drive raw temperature above to force a fault. *)
FOR nIter := 0 TO 6 DO
    astParams_ATM[nIter].stReactiveParams.nTempSP := 50;
END_FOR

(* ---- TST:LIC (transition + 4 named states) ---- *)
astParams_LIC[0].sPmpsState         := 'TST:LIC-TRANSITION';
astParams_LIC[0].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_LIC[0].stBeamParams.nRate := 0;
astParams_LIC[1].sPmpsState         := 'TST:LIC-OUT';
astParams_LIC[1].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_LIC[2].sPmpsState         := 'TST:LIC-MIRROR1';
astParams_LIC[2].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_LIC[3].sPmpsState         := 'TST:LIC-MIRROR2';
astParams_LIC[3].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_LIC[4].sPmpsState         := 'TST:LIC-TARGET';
astParams_LIC[4].stBeamParams       := PMPS_GVL.cstFullBeam;

(* ---- TST:PPM (transition + 4 named states) ---- *)
astParams_PPM[0].sPmpsState         := 'TST:PPM-TRANSITION';
astParams_PPM[0].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_PPM[0].stBeamParams.nRate := 0;
astParams_PPM[1].sPmpsState         := 'TST:PPM-OUT';
astParams_PPM[1].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_PPM[2].sPmpsState         := 'TST:PPM-POWERMETER';
astParams_PPM[2].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_PPM[3].sPmpsState         := 'TST:PPM-YAG1';
astParams_PPM[3].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_PPM[4].sPmpsState         := 'TST:PPM-YAG2';
astParams_PPM[4].stBeamParams       := PMPS_GVL.cstFullBeam;

(* ---- TST:REF (transition + 2 named states)
   REF is a reference / alignment laser, not an X-ray attenuator: both
   OUT and IN are authorised under cstFullBeam. The transition row
   drops nRate to 0 as a conservative beam-down default while the Y
   motor is between named states. Distinct nRequestAssertionID per
   state so arbitration traces in the FFO log are identifiable.
   Consumed by FB_REFTest. ---- *)
astParams_REF[0].sPmpsState          := 'TST:REF-TRANSITION';
astParams_REF[0].nRequestAssertionID := 500;
astParams_REF[0].stBeamParams        := PMPS_GVL.cstFullBeam;
astParams_REF[0].stBeamParams.nRate  := 0;
astParams_REF[1].sPmpsState          := 'TST:REF-OUT';
astParams_REF[1].nRequestAssertionID := 501;
astParams_REF[1].stBeamParams        := PMPS_GVL.cstFullBeam;
astParams_REF[2].sPmpsState          := 'TST:REF-IN';
astParams_REF[2].nRequestAssertionID := 502;
astParams_REF[2].stBeamParams        := PMPS_GVL.cstFullBeam;

(* ---- TST:GBS (transition + 10 named states) ---- *)
astParams_GBS[0].sPmpsState         := 'TST:GBS-TRANSITION';
astParams_GBS[0].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_GBS[0].stBeamParams.nRate := 0;
astParams_GBS[1].sPmpsState         := 'TST:GBS-OUT';
astParams_GBS[1].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_GBS[2].sPmpsState         := 'TST:GBS-TARGET1a';
astParams_GBS[2].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_GBS[3].sPmpsState         := 'TST:GBS-TARGET1b';
astParams_GBS[3].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_GBS[4].sPmpsState         := 'TST:GBS-TARGET2a';
astParams_GBS[4].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_GBS[5].sPmpsState         := 'TST:GBS-TARGET2b';
astParams_GBS[5].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_GBS[6].sPmpsState         := 'TST:GBS-TARGET3a';
astParams_GBS[6].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_GBS[7].sPmpsState         := 'TST:GBS-TARGET3b';
astParams_GBS[7].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_GBS[8].sPmpsState         := 'TST:GBS-TARGET4';
astParams_GBS[8].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_GBS[9].sPmpsState         := 'TST:GBS-TARGET5';
astParams_GBS[9].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_GBS[10].sPmpsState        := 'TST:GBS-TARGET6';
astParams_GBS[10].stBeamParams      := PMPS_GVL.cstFullBeam;

(* ---- TST:IPM (transition + 5 named states) ---- *)
astParams_IPM[0].sPmpsState         := 'TST:IPM-TRANSITION';
astParams_IPM[0].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_IPM[0].stBeamParams.nRate := 0;
astParams_IPM[1].sPmpsState         := 'TST:IPM-OUT';
astParams_IPM[1].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_IPM[2].sPmpsState         := 'TST:IPM-TARGET1';
astParams_IPM[2].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_IPM[3].sPmpsState         := 'TST:IPM-TARGET2';
astParams_IPM[3].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_IPM[4].sPmpsState         := 'TST:IPM-TARGET3';
astParams_IPM[4].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_IPM[5].sPmpsState         := 'TST:IPM-TARGET4';
astParams_IPM[5].stBeamParams       := PMPS_GVL.cstFullBeam;

(* ---- TST:WFS (transition + 6 named states) ---- *)
astParams_WFS[0].sPmpsState         := 'TST:WFS-TRANSITION';
astParams_WFS[0].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_WFS[0].stBeamParams.nRate := 0;
astParams_WFS[1].sPmpsState         := 'TST:WFS-OUT';
astParams_WFS[1].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_WFS[2].sPmpsState         := 'TST:WFS-TARGET1';
astParams_WFS[2].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_WFS[3].sPmpsState         := 'TST:WFS-TARGET2';
astParams_WFS[3].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_WFS[4].sPmpsState         := 'TST:WFS-TARGET3';
astParams_WFS[4].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_WFS[5].sPmpsState         := 'TST:WFS-TARGET4';
astParams_WFS[5].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_WFS[6].sPmpsState         := 'TST:WFS-TARGET5';
astParams_WFS[6].stBeamParams       := PMPS_GVL.cstFullBeam;

(* ---- TST:XPIM (transition + 5 named states) ---- *)
astParams_XPIM[0].sPmpsState         := 'TST:XPIM-TRANSITION';
astParams_XPIM[0].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_XPIM[0].stBeamParams.nRate := 0;
astParams_XPIM[1].sPmpsState         := 'TST:XPIM-OUT';
astParams_XPIM[1].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_XPIM[2].sPmpsState         := 'TST:XPIM-DIAMOND';
astParams_XPIM[2].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_XPIM[3].sPmpsState         := 'TST:XPIM-RETICLE';
astParams_XPIM[3].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_XPIM[4].sPmpsState         := 'TST:XPIM-YAG';
astParams_XPIM[4].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_XPIM[5].sPmpsState         := 'TST:XPIM-POWERMETER';
astParams_XPIM[5].stBeamParams       := PMPS_GVL.cstFullBeam;

(* ---- TST:SATT (only keys currently exercised by FB_SATTTest) ---- *)
astParams_SATT[0].sPmpsState         := 'TST:SATT-TRANSITION';
astParams_SATT[0].stBeamParams       := PMPS_GVL.cstFullBeam;
astParams_SATT[0].stBeamParams.nRate := 0;
astParams_SATT[1].sPmpsState         := 'TST:SATT-FILTER1';
astParams_SATT[1].stBeamParams       := PMPS_GVL.cstFullBeam;

(* ---- TST:SLITS (single PMPS key, aperture geometry not state-keyed) ---- *)
astParams_SLITS[0].sPmpsState                  := 'TST:SLITS';
astParams_SLITS[0].stBeamParams                := PMPS_GVL.cstFullBeam;
astParams_SLITS[0].stReactiveParams.nTempSP    := 50;

(* ---- Write the document. First helper creates a fresh root; the
   rest append to it. ---- *)
fbJsonHelper_ATM(
    astBeamParams := astParams_ATM,
    bExecute      := TRUE,
    sDevName      := 'TST:ATM',
    bNewDoc       := TRUE);

fbJsonHelper_LIC(
    astBeamParams := astParams_LIC,
    bExecute      := TRUE,
    sDevName      := 'TST:LIC',
    bNewDoc       := FALSE);

fbJsonHelper_PPM(
    astBeamParams := astParams_PPM,
    bExecute      := TRUE,
    sDevName      := 'TST:PPM',
    bNewDoc       := FALSE);

fbJsonHelper_REF(
    astBeamParams := astParams_REF,
    bExecute      := TRUE,
    sDevName      := 'TST:REF',
    bNewDoc       := FALSE);

fbJsonHelper_GBS(
    astBeamParams := astParams_GBS,
    bExecute      := TRUE,
    sDevName      := 'TST:GBS',
    bNewDoc       := FALSE);

fbJsonHelper_IPM(
    astBeamParams := astParams_IPM,
    bExecute      := TRUE,
    sDevName      := 'TST:IPM',
    bNewDoc       := FALSE);

fbJsonHelper_WFS(
    astBeamParams := astParams_WFS,
    bExecute      := TRUE,
    sDevName      := 'TST:WFS',
    bNewDoc       := FALSE);

fbJsonHelper_XPIM(
    astBeamParams := astParams_XPIM,
    bExecute      := TRUE,
    sDevName      := 'TST:XPIM',
    bNewDoc       := FALSE);

fbJsonHelper_SATT(
    astBeamParams := astParams_SATT,
    bExecute      := TRUE,
    sDevName      := 'TST:SATT',
    bNewDoc       := FALSE);

fbJsonHelper_SLITS(
    astBeamParams := astParams_SLITS,
    bExecute      := TRUE,
    sDevName      := 'TST:SLITS',
    bNewDoc       := FALSE);

bDone := TRUE;
]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>
