astParams_REF[2].stBeamParams.nBeamClass := 2#1000_0000;
astParams_REF[2].stBeamParams.neVRange   := 2#1111_1111_1111_1111_1111_1111_1111_1111;
astParams_REF[2].stBeamParams.nRate	:= 110;
astParams_REF[2].stBeamParams.nTran	:= 12.5;
astParams_REF[2].stBeamParams.nMachineMode	:= 1;


