(* ---- AT1K4:L2SI (single reactive-temp key; the SATT filters are not
   real PMPS states, so only the RTD reactive-temperature key is
   seeded). nTempSP is the RTD fault threshold in degC: the SATT temp
   FFO test faults at 100degC and clears at 0degC, so any threshold in
   (0, 100) works. *)
astParams_SATT[0].sPmpsState                 := 'AT1K4:L2SI-RTD';
astParams_SATT[0].nRequestAssertionID        := 1100;
astParams_SATT[0].stReactiveParams.nTempSP   := 30;
astParams_SATT[0].stBeamParams.nBeamClass    := 2#0000_0001;
astParams_SATT[0].stBeamParams.neVRange      := 2#1111_1111_1111_1111_1111_1111_1111_1111;
astParams_SATT[0].stBeamParams.nRate         := 10;
astParams_SATT[0].stBeamParams.nTran         := 12;
astParams_SATT[0].stBeamParams.nMachineMode  := 2;

(* ---- SL1L0:POWER (single reactive-temp key; aperture geometry is
   not state-keyed). nTempSP is the RTD fault threshold in degC: the
   SLITS temp FFO test faults at 100degC and clears at 0degC, so any
   threshold in (0, 100) works. *)
astParams_SLITS[0].sPmpsState                := 'SL1L0:POWER-RTD';
astParams_SLITS[0].nRequestAssertionID       := 1200;
astParams_SLITS[0].stReactiveParams.nTempSP  := 30;
astParams_SLITS[0].stBeamParams.nBeamClass   := 2#0000_0001;
astParams_SLITS[0].stBeamParams.neVRange     := 2#1111_1111_1111_1111_1111_1111_1111_1111;
astParams_SLITS[0].stBeamParams.nRate        := 10;
astParams_SLITS[0].stBeamParams.nTran        := 12;
astParams_SLITS[0].stBeamParams.nMachineMode := 2;

