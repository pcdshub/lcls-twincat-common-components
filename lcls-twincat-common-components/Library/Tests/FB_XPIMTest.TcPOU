<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_XPIMTest" Id="{fe1291e2-e066-4812-8d3e-bf776c10c3c5}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_XPIMTest EXTENDS FB_TestSuite
VAR
    (* Caller-owned axis, persistent storage, and Y motor.
       In a real PRG the AxisRef would come from MAIN.Mxx. *)
    axRef    : AXIS_REF;
    fbPDS    : LCLS_Tc_DevAbs.FB_PersistentDataStorage;

    (* FB_XPIM is single-axis (nActiveMotorCount := 1), so only slot 1
       holds a real motor. aiMotionStage is sized to
       MotionConstants.MAX_STATE_MOTORS to match FB_XPIM.FB_Init's
       fixed-size signature; slots 2-4 default-init to a nil interface
       and are never touched. *)
    fbMotorY : FB_MotionStageNC(AxisRef := axRef, iPersistentDataStorage := fbPDS, sName := 'Y');
    aiMotionStage : ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage := [fbMotorY];

    {attribute 'pytmc' := '
        pv: MMS
        astPositionState.array: 1..4
    '}
    astPositionState : ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                         OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;

    fbFFHWO    : FB_HardwareFFOutput;
    fbArbiter  : FB_Arbiter(1);
    fbSubSysIO : FB_DummyArbIO;

    (* EL6 serial terminal buffers, caller-owned. In a real PRG these
       would be linked to physical EL6xxx terminal IO; here they are
       just standalone locals so the FB_XPIM.FB_Init REFERENCE TO
       inputs have something to bind. *)
    stEl6In  : EL6inData22b;
    stEl6Out : EL6outData22b;

    sDeviceName    : STRING := 'TST:XPIM';
    sTransitionKey : STRING := 'TST:XPIM-TRANSITION';

    (* Caller-owned file-reader status, bound to FB_XPIM by REFERENCE
       TO. In a real PRG these point at MOTION_GVL.fbPmpsFileReader;
       here they stay FALSE so the DB read proceeds. *)
    bFileReaderBusy  : BOOL;
    bFileReaderError : BOOL;

    fbXPIM : FB_XPIM(
        aiMotionStage         := aiMotionStage,
        astPositionState      := astPositionState,
        fbFFHWO               := fbFFHWO,
        fbArbiter             := fbArbiter,
        sDeviceName           := sDeviceName,
        sTransitionKey        := sTransitionKey,
        bEnableBeamParams     := TRUE,
        bEnablePositionLimits := TRUE,
        bReadDBNow            := TRUE,
        bFileReaderBusy       := bFileReaderBusy,
        bFileReaderError      := bFileReaderError,
        stEl6In               := stEl6In,
        stEl6Out              := stEl6Out
    );

    (* Per-install PMPS-side state config (caller-owned). Mirrors what
       a real PRG_xxL0_XPIM would declare. stDefault is the caller-owned
       baseline template that FB_CC_StatePMPSConfig's inner FB_StateSetup
       preloads from; fbXPIM subsequently overrides per-state sName and
       fDelta via its own FB_CC_DeviceStateDefaults array. *)
    stDefault : ST_PositionState := (
        bMoveOk       := TRUE,
        bValid        := TRUE,
        bUseRawCounts := FALSE
    );

    afbStatePMPS : ARRAY[1..4] OF FB_CC_StatePMPSConfig[
        (stPositionState := astPositionState[1][E_XPIM_States.OUT],
         stDefault       := stDefault,
         fPosition       := 10,
         sPmpsState      := 'TST:XPIM-OUT'),
        (stPositionState := astPositionState[1][E_XPIM_States.YAG],
         stDefault       := stDefault,
         fPosition       := 20,
         sPmpsState      := 'TST:XPIM-YAG'),
        (stPositionState := astPositionState[1][E_XPIM_States.DIAMOND],
         stDefault       := stDefault,
         fPosition       := 30,
         sPmpsState      := 'TST:XPIM-DIAMOND'),
        (stPositionState := astPositionState[1][E_XPIM_States.RETICLE],
         stDefault       := stDefault,
         fPosition       := 40,
         sPmpsState      := 'TST:XPIM-RETICLE')
    ];

    bFirstScan : BOOL := TRUE;
    i          : UINT;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* Fake PMPS handling. *)
fbSubSysIO(
    LA  := fbArbiter,
    FFO := fbFFHWO
);

(* Caller-side PMPS configurators write each slot once in
   FB_CC_StatePMPSConfig.CallAfterInit; no cyclic tick. *)

(* One-shot motor setup + initial caller-owned enables. Limits,
   brake/enable modes, home cmd, user/hardware enables, default
   velocity; skip NC param restore. *)
IF bFirstScan THEN
    fbMotorY.SetModeEnableLimits(
        LimBackward    := TRUE,
        LimForward     := TRUE,
        HomeEnable     := FALSE,
        BrakeMode      := E_StageBrakeMode.IF_ENABLED,
        EnableMode     := E_StageEnableMode.DURING_MOTION,
        HomeMode       := E_EpicsHomeCmd.LOW_LIMIT,
        UserEnable     := TRUE,
        HardwareEnable := TRUE
    );
    fbMotorY.SetVelocity(Velocity := 15.5);
    fbMotorY.RestoreMotionParams      := FALSE;
    fbMotorY.DoNotRestoreNcParameters := TRUE;
    bFileReaderBusy  := TRUE;
    bFileReaderError := FALSE;
    bFirstScan := FALSE;
END_IF

fbPDS();
fbMotorY();
fbXPIM();

TestStateMove();

bFileReaderBusy  := FALSE;
bFileReaderError := FALSE;]]></ST>
    </Implementation>
    <Method Name="TestStateMove" Id="{fe1291e3-e066-4812-8d3e-bf776c10c3c6}">
      <Declaration><![CDATA[(*
    Smoke test for XPIM state-move wiring. Walks OUT then YAG and
    asserts each lands within fTolerance of the configured fPosition.
    Mirrors FB_REFTest: stageReady gate up front, NOT bMoving +
    position-tolerance check per state, 60s watchdog, on timeout
    AssertTrue(FALSE, ...) with the current step and observed
    position. Two moves is enough to exercise the FB wiring; the
    motion stack itself is covered by the
    lcls-twincat-motion-abstraction test suite.
*)
METHOD TestStateMove
VAR_INST
    tonTimer  : TON;
    nTestStep : INT := 0;
    fObserved : LREAL;
END_VAR
VAR CONSTANT
    fTolerance : LREAL := 2.0;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('TestXPIMStateMove');

tonTimer(IN := TRUE, PT := T#60s);
fObserved := fbMotorY.stMotionStatus.fActPosition;

CASE nTestStep OF
    0:
        IF fbMotorY.stMotionStatus.bStageReady
           AND NOT fbMotorY.stMotionStatus.bError THEN
            fbXPIM.eEnumSet := E_XPIM_States.OUT;
            nTestStep       := 1;
        END_IF
    1:
        (* OUT is configured at fPosition := 10 in afbStatePMPS[1]. *)
        IF fbXPIM.eEnumGet = E_XPIM_States.OUT
           AND NOT fbMotorY.stMotionStatus.bMoving
           AND ABS(fObserved - 10.0) <= fTolerance THEN
            fbXPIM.eEnumSet := E_XPIM_States.YAG;
            nTestStep       := 2;
        END_IF
    2:
        (* YAG is configured at fPosition := 20 in afbStatePMPS[2]. *)
        IF fbXPIM.eEnumGet = E_XPIM_States.YAG
           AND NOT fbMotorY.stMotionStatus.bMoving
           AND ABS(fObserved - 20.0) <= fTolerance THEN
            AssertTrue(
                Condition := TRUE,
                Message   := 'TestXPIMStateMove: OUT then YAG reached within tolerance');
            nTestStep := 3;
        END_IF
END_CASE

IF nTestStep = 3 THEN
    TEST_FINISHED();
ELSIF tonTimer.Q THEN
    AssertTrue(
        Condition := FALSE,
        Message   := CONCAT(
            CONCAT(
                CONCAT('TestXPIMStateMove: timed out at step ', TO_STRING(nTestStep)),
                CONCAT(', eEnumGet=', TO_STRING(TO_UDINT(fbXPIM.eEnumGet)))),
            CONCAT(', fActPos=', TO_STRING(fObserved))));
    TEST_FINISHED();
END_IF
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>