<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_ATMTest" Id="{7b7c37ef-d7db-42bb-948f-8b077a7ccce5}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_ATMTest EXTENDS FB_TestSuite
VAR
    (* Caller-owned axis, persistent storage, and Y motor.
       In a real PRG the AxisRef would come from MAIN.Mxx. *)
    axRef    : AXIS_REF;
    fbPDS    : LCLS_Tc_DevAbs.FB_PersistentDataStorage;

    (* FB_ATM is single-axis (nActiveMotorCount := 1), so only slot 1
       holds a real motor. aiMotionStage is sized to
       MotionConstants.MAX_STATE_MOTORS to match FB_ATM.FB_Init's
       fixed-size signature; slots 2-4 default-init to a nil interface
       and are never touched. *)
    fbMotorY : FB_MotionStageNC(AxisRef := axRef, iPersistentDataStorage := fbPDS, sName := 'Y');
    aiMotionStage : ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage := [fbMotorY];

    {attribute 'pytmc' := '
        pv: MMS
        astPositionState.array: 1..6
    '}
    astPositionState : ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                         OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;

    fbFFHWO    : FB_HardwareFFOutput;
    fbArbiter  : FB_Arbiter(1);
    fbSubSysIO : FB_DummyArbIO;

    (* Per-cycle caller-owned BOOL flags passed by reference to FB_ATM. *)
    bEnableMotion         : BOOL;
    bEnableBeamParams     : BOOL;
    bEnablePositionLimits : BOOL;
    bReadDBNow            : BOOL;

    (* Device-name strings bound to FB_ATM as REFERENCE TO STRING --
       a literal cannot be REF-bound, so they live as locals here. *)
    sDeviceName    : STRING := 'TST:ATM';
    sTransitionKey : STRING := 'TST:ATM-TRANSITION';

    fbATM : FB_ATM(
        aiMotionStage         := aiMotionStage,
        astPositionState      := astPositionState,
        fbFFHWO               := fbFFHWO,
        fbArbiter             := fbArbiter,
        sDeviceName           := sDeviceName,
        sTransitionKey        := sTransitionKey,
        bEnableMotion         := bEnableMotion,
        bEnableBeamParams     := bEnableBeamParams,
        bEnablePositionLimits := bEnablePositionLimits,
        bReadDBNow            := bReadDBNow
    );

    (* Per-install PMPS-side state config (caller-owned). Mirrors what
       a real PRG_xxL0_ATM would declare. stDefault is the caller-owned
       baseline template that FB_CC_StatePMPSConfig's inner FB_StateSetup
       preloads from; fbATM subsequently overrides per-state sName and
       fDelta via its own FB_CC_DeviceStateDefaults array. *)
    stDefault : ST_PositionState := (
        bMoveOk       := TRUE,
        bValid        := TRUE,
        bUseRawCounts := FALSE
    );

    afbStatePMPS : ARRAY[1..6] OF FB_CC_StatePMPSConfig[
        (stPositionState := astPositionState[1][E_ATM_States.OUT],
         stDefault       := stDefault,
         fPosition       := 10,
         sPmpsState      := 'TST:ATM-OUT'),
        (stPositionState := astPositionState[1][E_ATM_States.TARGET1],
         stDefault       := stDefault,
         fPosition       := 20,
         sPmpsState      := 'TST:ATM-TARGET1'),
        (stPositionState := astPositionState[1][E_ATM_States.TARGET2],
         stDefault       := stDefault,
         fPosition       := 30,
         sPmpsState      := 'TST:ATM-TARGET2'),
        (stPositionState := astPositionState[1][E_ATM_States.TARGET3],
         stDefault       := stDefault,
         fPosition       := 40,
         sPmpsState      := 'TST:ATM-TARGET3'),
        (stPositionState := astPositionState[1][E_ATM_States.TARGET4],
         stDefault       := stDefault,
         fPosition       := 50,
         sPmpsState      := 'TST:ATM-TARGET4'),
        (stPositionState := astPositionState[1][E_ATM_States.TARGET5],
         stDefault       := stDefault,
         fPosition       := 60,
         sPmpsState      := 'TST:ATM-TARGET5')
    ];

    bFirstScan : BOOL := TRUE;
    i          : UINT;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* Fake PMPS handling. *)
fbSubSysIO(
    LA  := fbArbiter,
    FFO := fbFFHWO
);

(* Caller-side PMPS configurators (per-install). *)
FOR i := 1 TO 6 DO
    afbStatePMPS[i]();
END_FOR

(* One-shot motor setup + initial caller-owned enables. Limits,
   brake/enable modes, home cmd, user/hardware enables, default
   velocity; skip NC param restore. *)
IF bFirstScan THEN
    fbMotorY.SetModeEnableLimits(
        LimBackward    := TRUE,
        LimForward     := TRUE,
        HomeEnable     := FALSE,
        BrakeMode      := E_StageBrakeMode.IF_ENABLED,
        EnableMode     := E_StageEnableMode.DURING_MOTION,
        HomeMode       := E_EpicsHomeCmd.LOW_LIMIT,
        UserEnable     := TRUE,
        HardwareEnable := TRUE
    );
    fbMotorY.SetVelocity(Velocity := 15.5);
    fbMotorY.RestoreMotionParams      := FALSE;
    fbMotorY.DoNotRestoreNcParameters := TRUE;

    bEnableMotion         := TRUE;
    bEnableBeamParams     := TRUE;
    bEnablePositionLimits := TRUE;
    bReadDBNow            := TRUE;

    bFirstScan := FALSE;
END_IF

fbPDS();
fbMotorY();
fbATM();

TestStateMove();
TestTempFFO();
]]></ST>
    </Implementation>
    <Method Name="SetATMTemp" Id="{7b7c37f0-d7db-42bb-948f-8b077a7ccce6}">
      <Declaration><![CDATA[METHOD SetATMTemp
VAR_INPUT
    iTempC : INT;
END_VAR
VAR
    ptr : POINTER TO INT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[ptr  := ADR(fbATM.fbTempSensor1.iRaw);
ptr^ := iTempC * 10;]]></ST>
      </Implementation>
    </Method>
    <Method Name="TestStateMove" Id="{7b7c37f1-d7db-42bb-948f-8b077a7ccce7}">
      <Declaration><![CDATA[METHOD TestStateMove
VAR_INST
    tonTimer   : TON;
    nIterState : UINT := 0;
END_VAR
VAR CONSTANT
    nLastState : UINT := 6; (* E_ATM_States.TARGET5 *)
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* Sanity check: can we at least move to every named state? *)
TEST('TestATMStateMove');

(* Prepare a timeout *)
tonTimer(IN := TRUE, PT := T#10s);

(* Start in Unknown, then go through the state positions one by one. *)
IF fbATM.eEnumGet = nIterState THEN
    nIterState     := nIterState + 1;
    fbATM.eEnumSet := nIterState;
END_IF

IF tonTimer.Q OR nIterState > nLastState THEN
    AssertFalse(tonTimer.Q, 'Timeout in ATM move test');
    TEST_FINISHED();
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="TestTempFFO" Id="{7b7c37f2-d7db-42bb-948f-8b077a7ccce8}">
      <Declaration><![CDATA[METHOD TestTempFFO
VAR_INST
    tonTimer    : TON;
    nStep       : UINT := 0;
    bOutChecked : BOOL := FALSE;
    bInChecked  : BOOL := FALSE;
END_VAR
VAR CONSTANT
    nLastStep : UINT := 3;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* Do we fault at the correct times?
   Parasitically depends on state move test. *)
TEST('TestATMTempFFO');

(* Prepare a timeout *)
tonTimer(IN := TRUE, PT := T#10s);

CASE nStep OF
    0:
        (* Set the thermocouple temperature to crazy high number. *)
        SetATMTemp(100);
        nStep := nStep + 1;
    1:
        (* Wait till we see "OUT" state and one other state (OUT
           should be no fault). *)
        IF fbATM.eEnumGet = E_ATM_States.OUT THEN
            AssertTrue(
                fbATM.fbTempSensor1.FFO.i_xOK,
                'Faulted even in out position!'
            );
            bOutChecked := TRUE;
        ELSIF fbATM.eEnumGet <> E_ATM_States.Unknown THEN
            AssertFalse(
                fbATM.fbTempSensor1.FFO.i_xOK,
                'No fault even for an in position!'
            );
            bInChecked := TRUE;
        END_IF
        IF bOutChecked AND bInChecked THEN
            nStep := nStep + 1;
        END_IF
    2:
        (* Set the thermocouple temperature to low again. *)
        SetATMTemp(0);
        nStep := nStep + 1;
    3:
        AssertTrue(
            fbATM.fbTempSensor1.FFO.i_xOK,
            'Faulted even with low temp!'
        );
        nStep := nStep + 1;
END_CASE

IF tonTimer.Q OR nStep > nLastStep THEN
    AssertFalse(tonTimer.Q, 'Timeout in ATM temp FFO test');
    TEST_FINISHED();
END_IF
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>
