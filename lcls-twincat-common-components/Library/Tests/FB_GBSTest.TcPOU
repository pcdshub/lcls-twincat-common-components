<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_GBSTest" Id="{2c4e0000-0000-0000-0000-000000000001}" SpecialFunc="None">
    <Declaration><![CDATA[(*
    Integration smoke for FB_GBS. Two tests:

    TestStateMove - proves the FB_GBS wiring (REFERENCE TO refs,
      CallAfterInit / CallAfterInitStateMover / CallAfterInitPMPS chain,
      inline-init of fbStates, per-state name/fDelta defaults, PMPS
      state-key registration) still drives FB_MotionStageNC into the
      configured fPosition for a commanded state. Walks OUT then
      TARGET1a and asserts each lands within fTolerance.

    TestTempFFO - proves the two in-beam RTDs (fbRTD1 / fbRTD2) fault
      only when something is in the beam. They are vetoed while OUT
      (bVeto := eEnumGet = OUT) and active in any target state, with
      the fault threshold taken from the PMPS DB reactive temp setpoint
      (seeded to 30 by FB_CC_PMPSTestSetup). Parasitically rides the
      state-move test to observe both an OUT and a target state.

    The motion stack itself is covered by the
    lcls-twincat-motion-abstraction suite; this test only checks that
    the CC FB_GBS wrapper does not break the contract.

    On watchdog expiry: AssertTrue(FALSE, ...) with the step, observed
    eEnumGet, and observed fActPosition so the failure mode is obvious.
*)
{attribute 'analysis' := '-33'}
FUNCTION_BLOCK FB_GBSTest EXTENDS FB_TestSuite
VAR
    (* Caller-owned axis, persistent storage, and Y motor.
       In a real PRG the AxisRef would come from MAIN.Mxx. *)
    axRef    : AXIS_REF;
    fbPDS    : LCLS_Tc_DevAbs.FB_PersistentDataStorage;

    (* FB_GBS is single-axis (nActiveMotorCount := 1), so only slot 1
       holds a real motor. aiMotionStage is sized to
       MotionConstants.MAX_STATE_MOTORS to match FB_GBS.FB_Init's
       fixed-size signature; slots 2-4 default-init to a nil interface
       and are never touched. *)
    fbMotorY : FB_MotionStageNC(AxisRef := axRef, iPersistentDataStorage := fbPDS, sName := 'Y');
    aiMotionStage : ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage := [fbMotorY];

    {attribute 'pytmc' := '
        pv: MMS
        astPositionState.array: 1..4
    '}
    astPositionState : ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                         OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;

    fbFFHWO    : FB_HardwareFFOutput;
    fbArbiter  : FB_Arbiter(1);
    fbSubSysIO : FB_DummyArbIO;

    sDeviceName    : STRING := 'TST:GBS';
    sTransitionKey : STRING := 'TST:GBS-TRANSITION';

    (* Caller-owned file-reader status, bound to FB_GBS by REFERENCE
       TO. In a real PRG these point at MOTION_GVL.fbPmpsFileReader;
       here they stay FALSE so the DB read proceeds. *)
    bFileReaderBusy  : BOOL;
    bFileReaderError : BOOL;

    fbGBS : FB_GBS(
        aiMotionStage         := aiMotionStage,
        astPositionState      := astPositionState,
        fbFFHWO               := fbFFHWO,
        fbArbiter             := fbArbiter,
        sDeviceName           := sDeviceName,
        sTransitionKey        := sTransitionKey,
        bEnableBeamParams     := TRUE,
        bEnablePositionLimits := TRUE,
        bReadDBNow            := TRUE,
        bFileReaderBusy       := bFileReaderBusy,
        bFileReaderError      := bFileReaderError
    );

    (* Per-install PMPS-side state config (caller-owned). Mirrors what
       a real PRG_xxL0_GBS would declare. stDefault is the caller-owned
       baseline template that FB_CC_StatePMPSConfig's inner FB_StateSetup
       preloads from; fbGBS subsequently overrides per-state sName and
       fDelta via its own FB_CC_DeviceStateDefaults array. sPmpsState
       keys match the fake DB seeded by FB_CC_PMPSTestSetup. *)
    stDefault : ST_PositionState := (
        bMoveOk       := TRUE,
        bValid        := TRUE,
        bUseRawCounts := FALSE
    );

    afbStatePMPS : ARRAY[1..10] OF FB_CC_StatePMPSConfig[
        (stPositionState := astPositionState[1][E_GBS_States.OUT],
         stDefault       := stDefault,
         fPosition       := 10,
         sPmpsState      := 'TST:GBS-OUT'),
        (stPositionState := astPositionState[1][E_GBS_States.TARGET1a],
         stDefault       := stDefault,
         fPosition       := 20,
         sPmpsState      := 'TST:GBS-TARGET1a'),
        (stPositionState := astPositionState[1][E_GBS_States.TARGET1b],
         stDefault       := stDefault,
         fPosition       := 30,
         sPmpsState      := 'TST:GBS-TARGET1b'),
        (stPositionState := astPositionState[1][E_GBS_States.TARGET2a],
         stDefault       := stDefault,
         fPosition       := 40,
         sPmpsState      := 'TST:GBS-TARGET2a'),
        (stPositionState := astPositionState[1][E_GBS_States.TARGET2b],
         stDefault       := stDefault,
         fPosition       := 50,
         sPmpsState      := 'TST:GBS-TARGET2b'),
        (stPositionState := astPositionState[1][E_GBS_States.TARGET3a],
         stDefault       := stDefault,
         fPosition       := 60,
         sPmpsState      := 'TST:GBS-TARGET3a'),
        (stPositionState := astPositionState[1][E_GBS_States.TARGET3b],
         stDefault       := stDefault,
         fPosition       := 70,
         sPmpsState      := 'TST:GBS-TARGET3b'),
        (stPositionState := astPositionState[1][E_GBS_States.TARGET4],
         stDefault       := stDefault,
         fPosition       := 80,
         sPmpsState      := 'TST:GBS-TARGET4'),
        (stPositionState := astPositionState[1][E_GBS_States.TARGET5],
         stDefault       := stDefault,
         fPosition       := 90,
         sPmpsState      := 'TST:GBS-TARGET5'),
        (stPositionState := astPositionState[1][E_GBS_States.TARGET6],
         stDefault       := stDefault,
         fPosition       := 100,
         sPmpsState      := 'TST:GBS-TARGET6')
    ];

    bFirstScan : BOOL := TRUE;
    i          : UINT;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[TestStateMove();
TestTempFFO();
]]></ST>
    </Implementation>
    <Method Name="AssertBothTempFault" Id="{2c4e0000-0000-0000-0000-000000000010}">
      <Declaration><![CDATA[METHOD AssertBothTempFault
VAR_INPUT
    Message : STRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[AssertFalse(
    fbGBS.fbRTD1.FFO.i_xOK,
    CONCAT('GBS RTD1 expected fault: ', Message)
);
AssertFalse(
    fbGBS.fbRTD2.FFO.i_xOK,
    CONCAT('GBS RTD2 expected fault: ', Message)
);]]></ST>
      </Implementation>
    </Method>
    <Method Name="AssertNeitherTempFault" Id="{2c4e0000-0000-0000-0000-000000000011}">
      <Declaration><![CDATA[METHOD AssertNeitherTempFault
VAR_INPUT
    Message : STRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[AssertTrue(
    fbGBS.fbRTD1.FFO.i_xOK,
    CONCAT('GBS RTD1 expected ok: ', Message)
);
AssertTrue(
    fbGBS.fbRTD2.FFO.i_xOK,
    CONCAT('GBS RTD2 expected ok: ', Message)
);]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetGBSTemp" Id="{2c4e0000-0000-0000-0000-000000000012}">
      <Declaration><![CDATA[METHOD SetGBSTemp
VAR_INPUT
    iTempC : INT;
END_VAR
VAR
    ptr : POINTER TO INT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[ptr  := ADR(fbGBS.fbRTD1.iRaw);
ptr^ := iTempC * 10;

ptr  := ADR(fbGBS.fbRTD2.iRaw);
ptr^ := iTempC * 10;]]></ST>
      </Implementation>
    </Method>
    <Method Name="TestStateMove" Id="{2c4e0000-0000-0000-0000-000000000002}">
      <Declaration><![CDATA[(*
    Smoke test for GBS state-move wiring. Walks OUT then TARGET1a and
    asserts each lands within fTolerance of the configured fPosition.
    Mirrors FB_PPMTest: stageReady gate up front, NOT bMoving +
    position-tolerance check per state, 60s watchdog, on timeout
    AssertTrue(FALSE, ...) with the current step and observed position.
    Two moves is enough to exercise the FB wiring; the motion stack
    itself is covered by the lcls-twincat-motion-abstraction suite.
*)
METHOD TestStateMove
VAR_INST
    tonTimer  : TON;
    nTestStep : INT := 0;
    fObserved : LREAL;
END_VAR
VAR CONSTANT
    fTolerance : LREAL := 2.0;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('TestGBSStateMove');

tonTimer(IN := TRUE, PT := T#60s);
fObserved := fbMotorY.stMotionStatus.fActPosition;

CASE nTestStep OF
    0:
        IF bFirstScan THEN
            fbMotorY.SetModeEnableLimits(
                LimBackward    := TRUE,
                LimForward     := TRUE,
                HomeEnable     := FALSE,
                BrakeMode      := E_StageBrakeMode.IF_ENABLED,
                EnableMode     := E_StageEnableMode.DURING_MOTION,
                HomeMode       := E_EpicsHomeCmd.LOW_LIMIT,
                UserEnable     := TRUE,
                HardwareEnable := TRUE
            );
            fbMotorY.SetVelocity(Velocity := 15.5);
            fbMotorY.RestoreMotionParams      := FALSE;
            fbMotorY.DoNotRestoreNcParameters := TRUE;
            bFileReaderBusy  := TRUE;
            bFileReaderError := FALSE;
            bFirstScan := FALSE;
        END_IF
        nTestStep      := 1;
    1:
        IF fbMotorY.stMotionStatus.bStageReady
           AND NOT fbMotorY.stMotionStatus.bError THEN
            fbGBS.eEnumSet := E_GBS_States.OUT;
            nTestStep      := 2;
        END_IF
    2:
        (* OUT is configured at fPosition := 10 in afbStatePMPS[1]. *)
        IF fbGBS.eEnumGet = E_GBS_States.OUT
           AND NOT fbMotorY.stMotionStatus.bMoving
           AND ABS(fObserved - 10.0) <= fTolerance THEN
            fbGBS.eEnumSet := E_GBS_States.TARGET1a;
            nTestStep      := 3;
        END_IF
    3:
        (* TARGET1a is configured at fPosition := 20 in afbStatePMPS[2]. *)
        IF fbGBS.eEnumGet = E_GBS_States.TARGET1a
           AND NOT fbMotorY.stMotionStatus.bMoving
           AND ABS(fObserved - 20.0) <= fTolerance THEN
            AssertTrue(
                Condition := TRUE,
                Message   := 'TestGBSStateMove: OUT then TARGET1a reached within tolerance');
            nTestStep := 4;
        END_IF
END_CASE

(* Fake PMPS handling. *)
fbSubSysIO(
    LA  := fbArbiter,
    FFO := fbFFHWO
);

fbPDS();
fbMotorY();
fbGBS();

bFileReaderBusy  := FALSE;
bFileReaderError := FALSE;

IF nTestStep = 4 THEN
    TEST_FINISHED();
ELSIF tonTimer.Q THEN
    AssertTrue(
        Condition := FALSE,
        Message   := CONCAT(
            CONCAT(
                CONCAT('TestGBSStateMove: timed out at step ', TO_STRING(nTestStep)),
                CONCAT(', eEnumGet=', TO_STRING(TO_UDINT(fbGBS.eEnumGet)))),
            CONCAT(', fActPos=', TO_STRING(fObserved))));
    TEST_FINISHED();
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="TestTempFFO" Id="{2c4e0000-0000-0000-0000-000000000003}">
      <Declaration><![CDATA[(*
    In-beam RTD gating test. The two GBS RTDs are vetoed while OUT and
    active in any target state, faulting when the reading exceeds the
    DB reactive temp setpoint (30). Parasitically rides the state-move
    test: with the temperature held high it asserts no fault while OUT
    and a fault once in a target, then drops the temperature and
    asserts the fault clears.
*)
METHOD TestTempFFO
VAR_INST
    tonTimer    : TON;
    nStep       : UINT := 0;
    bOutChecked : BOOL := FALSE;
    bInChecked  : BOOL := FALSE;
END_VAR
VAR CONSTANT
    nLastStep : UINT := 3;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[(* Do we fault at the correct times?
   Parasitically depends on the state-move test. *)
TEST('TestGBSTempFFO');

(* Prepare a timeout *)
tonTimer(IN := TRUE, PT := T#10s);

CASE nStep OF
    0:
        (* Set both RTD readings well above the 30 setpoint. *)
        SetGBSTemp(100);
        nStep := nStep + 1;
    1:
        (* Wait to observe both an OUT state (vetoed, no fault) and a
           target state (in beam, fault). *)
        IF fbGBS.eEnumGet = E_GBS_States.OUT THEN
            AssertNeitherTempFault('was in out position');
            bOutChecked := TRUE;
        ELSIF fbGBS.eEnumGet <> E_GBS_States.Unknown THEN
            AssertBothTempFault('was in a target position');
            bInChecked := TRUE;
        END_IF
        IF bOutChecked AND bInChecked THEN
            nStep := nStep + 1;
        END_IF
    2:
        (* Drop both RTD readings below the setpoint again. *)
        SetGBSTemp(0);
        nStep := nStep + 1;
    3:
        AssertNeitherTempFault('has low temp reading');
        nStep := nStep + 1;
END_CASE

IF tonTimer.Q OR nStep > nLastStep THEN
    AssertFalse(tonTimer.Q, 'Timeout in GBS temp FFO test');
    TEST_FINISHED();
END_IF
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>