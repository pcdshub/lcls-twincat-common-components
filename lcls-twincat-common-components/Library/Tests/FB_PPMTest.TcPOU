<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_PPMTest" Id="{4fe2b094-7b68-4ad1-a845-3ae72e5e51ed}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_PPMTest EXTENDS FB_TestSuite
VAR
    (* Caller-owned axis, persistent storage, and Y motor.
       In a real PRG the AxisRef would come from MAIN.Mxx. *)
    axRef    : AXIS_REF;
    fbPDS    : LCLS_Tc_DevAbs.FB_PersistentDataStorage;

    (* FB_PPM is single-axis (nActiveMotorCount := 1), so only slot 1
       holds a real motor. aiMotionStage is sized to
       MotionConstants.MAX_STATE_MOTORS to match FB_PPM.FB_Init's
       fixed-size signature; slots 2-4 default-init to a nil interface
       and are never touched. *)
    fbMotorY : FB_MotionStageNC(AxisRef := axRef, iPersistentDataStorage := fbPDS, sName := 'Y');
    aiMotionStage : ARRAY[1..MotionConstants.MAX_STATE_MOTORS] OF I_MotionStage := [fbMotorY];

    {attribute 'pytmc' := '
        pv: MMS
        astPositionState.array: 1..4
    '}
    astPositionState : ARRAY[1..MotionConstants.MAX_STATE_MOTORS]
                         OF ARRAY[1..GeneralConstants.MAX_STATES] OF ST_PositionState;

    fbFFHWO    : FB_HardwareFFOutput;
    fbArbiter  : FB_Arbiter(1);
    fbSubSysIO : FB_DummyArbIO;

    sDeviceName    : STRING := 'TST:PPM';
    sTransitionKey : STRING := 'TST:PPM-TRANSITION';

    fbPPM : FB_PPM(
        aiMotionStage         := aiMotionStage,
        astPositionState      := astPositionState,
        fbFFHWO               := fbFFHWO,
        fbArbiter             := fbArbiter,
        sDeviceName           := sDeviceName,
        sTransitionKey        := sTransitionKey,
        bEnableBeamParams     := TRUE,
        bEnablePositionLimits := TRUE,
        bReadDBNow            := TRUE
    );

    (* Per-install PMPS-side state config (caller-owned). Mirrors what
       a real PRG_xxL0_PPM would declare. stDefault is the caller-owned
       baseline template that FB_CC_StatePMPSConfig's inner FB_StateSetup
       preloads from; fbPPM subsequently overrides per-state sName and
       fDelta via its own FB_CC_DeviceStateDefaults array. *)
    stDefault : ST_PositionState := (
        bMoveOk       := TRUE,
        bValid        := TRUE,
        bUseRawCounts := FALSE
    );

    afbStatePMPS : ARRAY[1..4] OF FB_CC_StatePMPSConfig[
        (stPositionState := astPositionState[1][E_PPM_States.OUT],
         stDefault       := stDefault,
         fPosition       := 10,
         sPmpsState      := 'TST:PPM-OUT'),
        (stPositionState := astPositionState[1][E_PPM_States.POWERMETER],
         stDefault       := stDefault,
         fPosition       := 20,
         sPmpsState      := 'TST:PPM-POWERMETER'),
        (stPositionState := astPositionState[1][E_PPM_States.YAG1],
         stDefault       := stDefault,
         fPosition       := 30,
         sPmpsState      := 'TST:PPM-YAG1'),
        (stPositionState := astPositionState[1][E_PPM_States.YAG2],
         stDefault       := stDefault,
         fPosition       := 40,
         sPmpsState      := 'TST:PPM-YAG2')
    ];

    bFirstScan : BOOL := TRUE;
    i          : UINT;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* Fake PMPS handling. *)
fbSubSysIO(
    LA  := fbArbiter,
    FFO := fbFFHWO
);

(* Caller-side PMPS configurators write each slot once in
   FB_CC_StatePMPSConfig.CallAfterInit; no cyclic tick. *)

(* One-shot motor setup + initial caller-owned enables. Limits,
   brake/enable modes, home cmd, user/hardware enables, default
   velocity; skip NC param restore. *)
IF bFirstScan THEN
    fbMotorY.SetModeEnableLimits(
        LimBackward    := TRUE,
        LimForward     := TRUE,
        HomeEnable     := FALSE,
        BrakeMode      := E_StageBrakeMode.IF_ENABLED,
        EnableMode     := E_StageEnableMode.DURING_MOTION,
        HomeMode       := E_EpicsHomeCmd.LOW_LIMIT,
        UserEnable     := TRUE,
        HardwareEnable := TRUE
    );
    fbMotorY.SetVelocity(Velocity := 15.5);
    fbMotorY.RestoreMotionParams      := FALSE;
    fbMotorY.DoNotRestoreNcParameters := TRUE;

    bFirstScan := FALSE;
END_IF

fbPDS();
fbMotorY();
fbPPM();

TestStateMove();
TestTempFFO();
]]></ST>
    </Implementation>
    <Method Name="AssertBothTempFault" Id="{8909043d-b06e-4fe1-af75-98d367a5485d}">
      <Declaration><![CDATA[METHOD AssertBothTempFault
VAR_INPUT
    Message : STRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[AssertFalse(
    fbPPM.fbYagTempSensor.FFO.i_xOK,
    CONCAT('PPM yag temp sensor expected fault: ', Message)
);
AssertFalse(
    fbPPM.fbPowerMeter.fbTempSensor.FFO.i_xOK,
    CONCAT('PPM pm temp sensor expected fault: ', Message)
);]]></ST>
      </Implementation>
    </Method>
    <Method Name="AssertNeitherTempFault" Id="{67f64774-b93e-4edd-9385-2e45e7e5bb02}">
      <Declaration><![CDATA[METHOD AssertNeitherTempFault
VAR_INPUT
    Message : STRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[AssertTrue(
    fbPPM.fbYagTempSensor.FFO.i_xOK,
    CONCAT('PPM yag temp sensor expected ok: ', Message)
);
AssertTrue(
    fbPPM.fbPowerMeter.fbTempSensor.FFO.i_xOK,
    CONCAT('PPM pm temp sensor expected ok: ', Message)
);]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetPPMTemp" Id="{a562a0a3-b773-435c-a674-0d23a2ebaa9b}">
      <Declaration><![CDATA[METHOD SetPPMTemp
VAR_INPUT
    iTempC : INT;
END_VAR
VAR
    ptr : POINTER TO INT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[ptr  := ADR(fbPPM.fbYagTempSensor.iRaw);
ptr^ := iTempC * 10;

ptr  := ADR(fbPPM.fbPowerMeter.fbTempSensor.iRaw);
ptr^ := iTempC * 10;]]></ST>
      </Implementation>
    </Method>
    <Method Name="TestStateMove" Id="{6d196413-6cf3-4cc4-b625-5ae4ecbdc9a3}">
      <Declaration><![CDATA[METHOD TestStateMove
VAR_INST
    tonTimer   : TON;
    nIterState : UINT := 0;
END_VAR
VAR CONSTANT
    nLastState : UINT := 4; (* E_PPM_States.YAG2 *)
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* Sanity check: can we at least move to every named state? *)
TEST('TestPPMStateMove');

(* Prepare a timeout *)
tonTimer(IN := TRUE, PT := T#10s);

(* Start in Unknown, then go through the state positions one by one. *)
IF fbPPM.eEnumGet = nIterState THEN
    nIterState     := nIterState + 1;
    fbPPM.eEnumSet := nIterState;
END_IF

IF tonTimer.Q OR nIterState > nLastState THEN
    AssertFalse(tonTimer.Q, 'Timeout in PPM move test');
    TEST_FINISHED();
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="TestTempFFO" Id="{22555386-8565-4705-8fa4-8f0ccd016d60}">
      <Declaration><![CDATA[METHOD TestTempFFO
VAR_INST
    tonTimer    : TON;
    nStep       : UINT := 0;
    bOutChecked : BOOL := FALSE;
    bInChecked  : BOOL := FALSE;
END_VAR
VAR CONSTANT
    nLastStep : UINT := 3;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* Do we fault at the correct times?
   Parasitically depends on state move test. *)
TEST('TestPPMTempFFO');

(* Prepare a timeout *)
tonTimer(IN := TRUE, PT := T#10s);

CASE nStep OF
    0:
        (* Set the thermocouple temperatures to crazy high number. *)
        SetPPMTemp(100);
        nStep := nStep + 1;
    1:
        (* Wait till we see "OUT" state and one other state (OUT
           should be no fault). *)
        IF fbPPM.eEnumGet = E_PPM_States.OUT THEN
            AssertNeitherTempFault('was in out position');
            bOutChecked := TRUE;
        ELSIF fbPPM.eEnumGet <> E_PPM_States.Unknown THEN
            AssertBothTempFault('was in a target position');
            bInChecked := TRUE;
        END_IF
        IF bOutChecked AND bInChecked THEN
            nStep := nStep + 1;
        END_IF
    2:
        (* Set the thermocouple temperatures to low again. *)
        SetPPMTemp(0);
        nStep := nStep + 1;
    3:
        AssertNeitherTempFault('has low temp reading');
        nStep := nStep + 1;
END_CASE

IF tonTimer.Q OR nStep > nLastStep THEN
    AssertFalse(tonTimer.Q, 'Timeout in PPM temp FFO test');
    TEST_FINISHED();
END_IF
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>
